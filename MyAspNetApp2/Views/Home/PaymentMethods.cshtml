@{
    ViewData["Title"] = "Payment Methods";
}

<div class="profile-layout-container">
    <div class="sidebar-wrapper">
        <partial name="_ProfileSideBar" />
    </div>

    <div class="main-content-wrapper">
        <div class="account-details-full-width">

            <button class="btn-primary-action">
                <i class="bi bi-plus-lg"></i> Add Payment Method
            </button>

            <div class="section-header-row">
                <h5 class="section-title">BILLING ADDRESS</h5>
                <a href="#" class="edit-link">Edit <i class="bi bi-pencil"></i></a>
            </div>

            <div class="info-group-card">
                <div class="info-row">
                    <span class="info-label text-muted">Region, Province, City, Barangay</span>
                </div>
                <div class="info-row">
                    <span class="info-label text-muted">Postal Code</span>
                </div>
                <div class="info-row no-border">
                    <span class="info-label text-muted">Street Name, Building, House No.</span>
                </div>
            </div>
        </div>

        <!-- div class="footer-spacer">
                <partial name="_Footer" />
            </div-->
    </div>
</div>

<style>
    /* --- CORE LAYOUT & SIDE-TO-SIDE EXPANSION --- */
    .profile-layout-container {
        display: flex;
        width: 100%;
        min-height: 100vh;
        background-color: #fff;
    }

    .sidebar-wrapper {
        width: 280px;
        flex-shrink: 0;
        border-right: 1px solid #e0e0e0; /* Matches dashboard separation */
    }

    /* --- THE SPACE FIX --- */
    .main-content-wrapper {
        flex: 1;
        background-color: #ffffff;
        padding: 10px 60px 40px 60px; /* Reduced top padding to 10px */
        margin-top: 10px; /* Reduced margin-top to pull content up */
    }

    .account-details-full-width {
        width: 100%; /* Allows cards to expand to the edges */
    }

    /* --- ACTION BUTTON --- */
    .btn-primary-action {
        width: 100%;
        background-color: #000;
        color: #fff;
        border: none;
        padding: 18px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 15px;
        cursor: pointer;
        transition: background-color 0.2s;
    }

        .btn-primary-action:hover {
            background-color: #222;
        }

    /* --- SECTION HEADERS --- */
    .section-header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 25px; /* Spacing between button and address section */
        margin-bottom: 12px;
    }

    .section-title {
        font-weight: 700;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
        margin: 0;
        color: #000;
    }

    .edit-link {
        color: #000;
        text-decoration: none;
        font-weight: 500;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    /* --- GREY CARDS --- */
    .info-group-card {
        background-color: #e0e0e0;
        border-radius: 12px;
        width: 100%;
        overflow: hidden;
    }

    .info-row {
        padding: 18px 30px;
        border-bottom: 1px solid #c0c0c0;
    }

        .info-row.no-border {
            border-bottom: none;
        }

    .info-label.text-muted {
        color: #555 !important;
        font-weight: 400;
        font-size: 1rem;
    }

    .footer-spacer {
        margin-top: 60px;
    }

    /* --- MOBILE RESPONSIVENESS --- */
    @@media (max-width: 768px) {
        .sidebar-wrapper {
            display: none;
        }

        .main-content-wrapper {
            padding: 15px;
            margin-top: 100px; /* Room for mobile toggle */
        }

        .btn-primary-action {
            padding: 15px;
            font-size: 1rem;
        }
    }
</style>