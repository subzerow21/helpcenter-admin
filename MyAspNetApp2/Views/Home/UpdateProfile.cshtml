@{
    ViewData["Title"] = "Account Details";
}

<div class="profile-layout-container">
    
     <partial name="_ProfileSideBar" />
    

    <div class="main-content-wrapper">
        <div class="account-details-full-width">

            <div class="info-group-card">
                <div class="info-row" id="name-row">
                    <span class="info-label">Full Name</span>
                    <span class="info-value">Consumer Name <i class="bi bi-chevron-right"></i></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Motto</span>
                    <span class="info-value text-muted">Set now <i class="bi bi-chevron-right"></i></span>
                </div>
            </div>

            <div class="info-group-card">
                <div class="info-row">
                    <span class="info-label">Gender</span>
                    <span class="info-value text-muted">Set now <i class="bi bi-chevron-right"></i></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Birthday</span>
                    <span class="info-value text-muted">Set now <i class="bi bi-chevron-right"></i></span>
                </div>
            </div>

            <div class="info-group-card">
                <div class="info-row">
                    <span class="info-label">Phone</span>
                    <span class="info-value text-muted">Set now <i class="bi bi-chevron-right"></i></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Email</span>
                    <span class="info-value text-muted">Set now <i class="bi bi-chevron-right"></i></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Password</span>
                    <span class="info-value">Update <i class="bi bi-chevron-right"></i></span>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="nameModal" class="modal-overlay">
    <div class="modal-card">
        <div class="modal-header">
            <span>Enter Full Name:</span>
            <button class="close-btn" id="closeModal">&times;</button>
        </div>
        <div class="modal-body">
            <input type="text" id="fullNameInput" placeholder="Enter name" class="modal-input" />
            <button class="save-btn" id="saveNameBtn">SAVE</button>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/UpdateProfile.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/UpdateProfile.js" asp-append-version="true"></script>
}