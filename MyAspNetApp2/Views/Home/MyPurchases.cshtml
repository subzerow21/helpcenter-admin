@{
    ViewData["Title"] = "My Purchases";
}

<div class="profile-layout-container">
    <div class="sidebar-wrapper">
        <partial name="_ProfileSideBar" />
    </div>

    <div class="main-content-wrapper">
        <div class="account-details-full-width">

            <div class="purchase-history-link">
                <a href="#">View Purchase History <i class="bi bi-chevron-right"></i></a>
            </div>

            <div class="order-status-navbar">
                <div class="status-item">
                    <i class="bi bi-credit-card"></i>
                    <span>To Pay</span>
                </div>
                <div class="status-item">
                    <i class="bi bi-box-seam"></i>
                    <span>To Ship</span>
                </div>
                <div class="status-item">
                    <i class="bi bi-truck"></i>
                    <span>To Receive</span>
                </div>
                <div class="status-item">
                    <i class="bi bi-star"></i>
                    <span>To Review</span>
                </div>
                <div class="status-item">
                    <i class="bi bi-arrow-counterclockwise"></i>
                    <span>Returns</span>
                </div>
            </div>

            <div class="empty-orders-container">
                <div class="empty-icon-wrapper">
                    <i class="bi bi-archive"></i>
                </div>
                <p>No Orders Yet</p>
            </div>
        </div>

    
    </div>
</div>

<style>
    /* --- CORE LAYOUT & EXPANSION --- */
    .profile-layout-container {
        display: flex;
        width: 100%;
        min-height: 100vh;
        background-color: #fff;
    }

    .sidebar-wrapper {
        width: 280px;
        flex-shrink: 0;
        border-right: 1px solid #e0e0e0;
    }

    /* --- THE SPACE FIX: Pulling content up --- */
    .main-content-wrapper {
        flex: 1;
        background-color: #ffffff;
        padding: 10px 60px 40px 60px; /* Reduced top padding */
        margin-top: 10px; /* Pulls cards close to header */
    }

    .account-details-full-width {
        width: 100%;
    }

    /* --- PURCHASE HISTORY HEADER --- */
    .purchase-history-link {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 15px;
    }

        .purchase-history-link a {
            color: #000;
            text-decoration: none;
            font-weight: 500;
            font-size: 0.95rem;
        }

    /* --- BLACK STATUS BAR --- */
    .order-status-navbar {
        background-color: #000;
        color: #fff;
        border-radius: 15px;
        display: flex;
        justify-content: space-around;
        align-items: center;
        padding: 20px 0;
        margin-bottom: 80px; /* Space before the empty state */
        width: 100%;
    }

    .status-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: opacity 0.2s;
    }

        .status-item:hover {
            opacity: 0.7;
        }

        .status-item i {
            font-size: 1.8rem;
        }

        .status-item span {
            font-size: 0.85rem;
            font-weight: 400;
        }

    /* --- EMPTY STATE --- */
    .empty-orders-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 40px 0;
        color: #000;
    }

    .empty-icon-wrapper i {
        font-size: 5rem;
        color: #000;
        margin-bottom: 10px;
    }

    .empty-orders-container p {
        font-size: 1.2rem;
        font-weight: 700;
        margin: 0;
    }

    .footer-spacer {
        margin-top: 120px;
        width: 100%;
    }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .sidebar-wrapper {
            display: none;
        }

        .main-content-wrapper {
            padding: 20px;
            margin-top: 100px; /* Gap for mobile toggle */
        }

        .order-status-navbar {
            padding: 15px 5px;
        }

        .status-item i {
            font-size: 1.4rem;
        }

        .status-item span {
            font-size: 0.7rem;
        }
    }
</style>