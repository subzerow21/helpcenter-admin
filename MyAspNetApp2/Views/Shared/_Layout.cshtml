<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="NEXT HORIZON - Premium Running Gear. Engineered for Performance. Built for Runners.">
    <meta name="theme-color" content="#000000">
    <title>@ViewData["Title"] - NEXT HORIZON</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        /* --- PROFESSIONAL B&W LOADING OVERLAY --- */
        #loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: #ffffff;
            display: none; /* Controlled by JS */
            justify-content: center;
            align-items: center;
            z-index: 10000; /* Higher than sidebar to prevent flicker */
        }

        .loader-content {
            text-align: center;
        }

        /* Modern Professional Loader Icon */
        .nh-loader-bars {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 6px;
            margin-bottom: 25px;
            height: 40px;
        }

        .nh-loader-bars span {
            width: 5px;
            height: 20px;
            background-color: #000;
            border-radius: 4px;
            animation: nh-wave 1.2s ease-in-out infinite;
        }

        /* Staggered wave effect for a premium feel */
        .nh-loader-bars span:nth-child(2) { animation-delay: 0.1s; }
        .nh-loader-bars span:nth-child(3) { animation-delay: 0.2s; }
        .nh-loader-bars span:nth-child(4) { animation-delay: 0.3s; }
        .nh-loader-bars span:nth-child(5) { animation-delay: 0.4s; }

        .loader-text {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 800;
            color: #000;
            text-transform: uppercase;
            letter-spacing: 6px;
            font-size: 0.75rem;
            opacity: 0.9;
        }

        @@keyframes nh-wave {
            0%, 100% { transform: scaleY(1); opacity: 0.3; }
            50% { transform: scaleY(2); opacity: 1; }
        }

        .hide-global-nav .navbar-toggler,
        .hide-global-nav .mobile-menu-toggle,
        .hide-global-nav #menu-icon {
            display: none !important;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div id="loading-overlay">
        <div class="loader-content">
            <div class="nh-loader-bars">
                <span></span>
                <span></span>
                <span></span>
                <span></span>
                <span></span>
            </div>
            <div class="loader-text">Next Horizon</div>
        </div>
    </div>

    <partial name="_Header" />

    <main class="main-content">
        @RenderBody()
    </main>

    <div id="reviews-modal" class="modal" role="dialog" aria-labelledby="reviews-title" aria-modal="true">
        <div class="modal-content reviews-modal-content">
            <div class="modal-header">
                <h2 id="reviews-title">Customer Reviews</h2>
                <button class="close-btn" onclick="closeReviewsModal()" aria-label="Close reviews">&times;</button>
            </div>
            <div class="reviews-modal-body">
                <div class="reviews-grid" id="all-reviews-grid"></div>
            </div>
        </div>
    </div>

    <div id="login-modal" class="modal" role="dialog" aria-labelledby="login-title" aria-modal="true">
        <div class="modal-content login-modal">
            <button class="modal-close-floating" onclick="closeLoginModal()" aria-label="Close">&times;</button>
            <div class="login-content">
                <h2 id="login-title">Welcome Back</h2>
                <p class="login-subtitle">Sign in to your account</p>
                <form class="login-form" onsubmit="handleLogin(event)">
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" placeholder="Enter your email" autocomplete="username" required>
                    </div>
                    <div class="form-group">
                        <label for="password">Password</label>
                        <input type="password" id="password" placeholder="Enter your password" autocomplete="current-password" required>
                    </div>
                    <button type="submit" class="login-submit">Sign In</button>
                </form>
                <p class="login-footer">Don't have an account? <a href="#" onclick="toggleRegister()">Sign Up</a></p>
            </div>
        </div>
    </div>


    <div id="toast-container" class="toast-container" aria-live="polite"></div>

    <script src="~/js/app.js" asp-append-version="true"></script>

    <script>
        // Use logic to show loader during transitions
        window.addEventListener("beforeunload", function () {
            document.getElementById("loading-overlay").style.display = "flex";
        });

        // Hide loader once the new page has fully loaded
        window.addEventListener("load", function () {
            document.getElementById("loading-overlay").style.display = "none";
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <div class="rv-lightbox" id="rv-lightbox">
        <div class="rv-lightbox-backdrop" onclick="closeReviewSlideshow()"></div>
        <button class="rv-lightbox-close" onclick="closeReviewSlideshow()" aria-label="Close">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
        </button>
        <button class="rv-slide-arrow rv-slide-prev" onclick="slideshowNav(-1)" aria-label="Previous">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
        </button>
        <div class="rv-lightbox-stage">
            <img class="rv-lightbox-img" id="rv-lightbox-img" src="" alt="Review photo">
        </div>
        <button class="rv-slide-arrow rv-slide-next" onclick="slideshowNav(1)" aria-label="Next">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6" /></svg>
        </button>
        <div class="rv-slide-counter" id="rv-slide-counter"></div>
    </div>
</body>
</html>