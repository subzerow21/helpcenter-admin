@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap');
</style>

<button type="button" class="sidebar-mobile-toggle" id="mobile-toggle">
    <i class="bi bi-list"></i>
</button>

<div class="profile-sidebar" id="sidebar">
    <button type="button" class="sidebar-close-btn d-md-none" id="close-sidebar">
        <i class="bi bi-x-lg"></i>
    </button>

    <nav class="sidebar-menu">
        <a asp-controller="Home" asp-action="ProfileView"
           class="sidebar-link @(currentAction == "ProfileView" ? "active" : "")">
            <i class="bi bi-speedometer2"></i> Fitness Overview
        </a>
        <a asp-controller="Home" asp-action="UpdateProfile"
           class="sidebar-link @(currentAction == "UpdateProfile" ? "active" : "")">
            <i class="bi bi-person-gear"></i> Update Profile
        </a>
        <a asp-controller="Home" asp-action="UploadActivity"
           class="sidebar-link @(currentAction == "UploadActivity" ? "active" : "")">
            <i class="bi bi-cloud-arrow-up"></i> Upload Activity
        </a>
        <a asp-controller="Home" asp-action="ShippingAddress"
           class="sidebar-link @(currentAction == "ShippingAddress" ? "active" : "")">
            <i class="bi bi-geo-alt"></i> Shipping Address
        </a>
        <a asp-controller="Home" asp-action="PaymentMethods"
           class="sidebar-link @(currentAction == "PaymentMethods" ? "active" : "")">
            <i class="bi bi-credit-card"></i> Payment Methods
        </a>
        <a asp-controller="Home" asp-action="MyPurchases"
           class="sidebar-link @(currentAction == "MyPurchases" ? "active" : "")">
            <i class="bi bi-bag-check"></i> My Purchases
        </a>
    </nav>
</div>

<style>
    :root {
        --sidebar-width: 280px;
        --sidebar-bg: #e9e9e9;
        --active-bg: #333333;
        --accent-line: #000000;
    }

    /* --- Desktop Sidebar Styles --- */
    .profile-sidebar {
        width: var(--sidebar-width);
        height: 100vh;
        background-color: var(--sidebar-bg) !important;
        position: fixed;
        top: 80px;
        left: 0;
        border-right: 1px solid #d1d1d1;
        z-index: 9998;
        transition: transform 0.3s ease;
        font-family: 'Poppins', sans-serif; /* Set Poppins Font */
        padding: 0; /* REMOVE padding so links can touch edges */
    }

    .sidebar-mobile-toggle, .sidebar-close-btn {
        display: none;
    }

    .sidebar-menu {
        display: flex;
        flex-direction: column;
        padding-top: 20px;
        width: 100%; /* Ensure menu is full width */
    }

    .sidebar-link {
        display: flex;
        align-items: center;
        width: 100%; /* Take up full sidebar space */
        padding: 18px 25px;
        text-decoration: none !important;
        color: #000;
        font-weight: 700; /* High weight for Poppins */
        font-size: 1rem;
        transition: all 0.2s ease;
        box-sizing: border-box;
        border-left: 10px solid transparent; /* Accent placeholder on LEFT */
    }

        /* Active State: Background fills everything, Accent on left */
        .sidebar-link:hover, .sidebar-link.active {
            background-color: var(--active-bg) !important;
            color: #fff !important;
            border-left: 10px solid var(--accent-line) !important; /* Visual accent on left */
            border-right: none;
        }

        .sidebar-link i {
            margin-right: 15px;
            width: 20px;
            text-align: center;
            font-size: 1.2rem;
        }

    /* --- Mobile Styles (768px and below) --- */
    @@media (max-width: 768px) {
        .sidebar-mobile-toggle {
            display: flex;
            align-items: center;
            justify-content: center;
            position: fixed;
            top: 15px;
            left: 15px;
            z-index: 10002;
            background: #000;
            color: #fff;
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 4px;
            cursor: pointer;
        }

        .sidebar-close-btn {
            display: block;
            position: absolute;
            top: 20px;
            right: 20px;
            background: none;
            border: none;
            font-size: 24px;
            color: #000;
            cursor: pointer;
            z-index: 10003;
        }

        .profile-sidebar {
            top: 0;
            transform: translateX(-100%);
            z-index: 10001;
            padding-top: 80px;
        }

            .profile-sidebar.open {
                transform: translateX(0);
            }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const toggleBtn = document.getElementById('mobile-toggle');
        const sidebar = document.getElementById('sidebar');
        const closeBtn = document.getElementById('close-sidebar');

        toggleBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            sidebar.classList.toggle('open');
        });

        if(closeBtn) {
            closeBtn.addEventListener('click', function() {
                sidebar.classList.remove('open');
            });
        }

        document.addEventListener('click', function(event) {
            if (sidebar.classList.contains('open')) {
                if (!sidebar.contains(event.target) && !toggleBtn.contains(event.target)) {
                    sidebar.classList.remove('open');
                }
            }
        });
    });
</script>