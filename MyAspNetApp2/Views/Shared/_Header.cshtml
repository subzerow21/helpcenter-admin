<style>
    /* dropdown positioning */
    .user-dropdown-wrap, .notif-wrap {
        position: relative !important;
        display: inline-block !important;
    }

    #user-menu-dropdown, #notif-dropdown {
        display: none;
        position: absolute !important;
        right: 0 !important;
        top: 45px !important;
        width: 240px !important;
        background: #ffffff !important;
        border-radius: 8px !important;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15) !important;
        z-index: 9999 !important;
        border: 1px solid #eee !important;
        overflow: hidden !important;
    }

        /* Toggle visibility */
        #user-menu-dropdown.show, #notif-dropdown.show {
            display: block !important;
        }

    /* Menu Items Styling */
    .menu-header, .notif-header {
        padding: 15px 20px;
        font-weight: 700;
        font-size: 13px;
        color: #888;
        text-transform: uppercase;
        border-bottom: 1px solid #f0f0f0;
    }

    .menu-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 20px;
        text-decoration: none !important;
        color: #333 !important;
        font-size: 14px;
        background: #ffffff !important; /* Force white background by default */
        border: none;
        width: 100%;
        text-align: left;
        cursor: pointer;
        font-family: inherit;
        transition: background 0.15s ease, color 0.15s ease;
    }

        /* Only turns black on hover */
        .menu-item:hover {
            background: #000000 !important;
            color: #ffffff !important;
        }

        /* Keeps it black ONLY if you actually add the class via logic later */
        .menu-item.active {
            background: #000000 !important;
            color: #ffffff !important;
        }

            /* Ensure icons turn white on hover too */
            .menu-item:hover svg, .menu-item.active svg {
                stroke: #ffffff !important;
            }

    /* Notification styling */
    .notif-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .notif-item {
        padding: 12px 20px;
        border-bottom: 1px solid #f9f9f9;
        display: flex;
        gap: 10px;
    }
</style>

<header id="main-header">
    <div class="container">
        <div class="header-content">
            <div class="logo">
                <a href="/"><img src="/logo.png" alt="NEXT HORIZON" class="header-logo-img"></a>
            </div>

            <form class="header-search-form" asp-controller="Home" asp-action="Shop" method="get">
                <div class="header-search-wrap">
                    <svg class="header-search-icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    <input type="search" name="q" placeholder="Search products…" class="header-search-input">
                </div>
            </form>

            <div class="header-actions">
                <a asp-controller="Home" asp-action="MyOrders" class="my-orders-link">My Orders</a>

                <a asp-controller="Home" asp-action="Cart" class="cart-btn" aria-label="Shopping Cart">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="9" cy="21" r="1"></circle>
                        <circle cx="20" cy="21" r="1"></circle>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                    </svg>
                    <span id="cart-count">0</span>
                </a>

                <div class="notif-wrap">
                    <button type="button" class="notif-btn" id="notif-btn" onclick="toggleNotifDropdown(event)">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                        </svg>
                        <span class="notif-dot"></span>
                    </button>
                    <div id="notif-dropdown" class="notif-dropdown">
                        <div class="notif-header">Notifications</div>
                        <ul class="notif-list">
                            <li class="notif-item">Order #1234 confirmed!</li>
                        </ul>
                    </div>
                </div>

                <div class="user-dropdown-wrap">
                    <button type="button" class="login-btn" id="user-menu-btn" onclick="toggleUserDropdown(event)">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                    </button>

                    <div id="user-menu-dropdown" class="user-menu-dropdown">
                        <div class="menu-header">Account Settings</div>
                        <a asp-controller="Home" asp-action="ProfileView" class="menu-item">View Profile</a>
                        
                        <form asp-controller="Home" asp-action="Logout" method="post">
                            <button type="submit" class="menu-item">Logout</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>

<script>
    function toggleUserDropdown(e) {
        if (e) e.stopPropagation();
        closeAllDropdowns();
        document.getElementById('user-menu-dropdown').classList.toggle('show');
    }

    function toggleNotifDropdown(e) {
        if (e) e.stopPropagation();
        closeAllDropdowns();
        document.getElementById('notif-dropdown').classList.toggle('show');
    }

    function closeAllDropdowns() {
        document.getElementById('user-menu-dropdown').classList.remove('show');
        document.getElementById('notif-dropdown').classList.remove('show');
    }

    window.addEventListener('click', function(e) {
        if (!e.target.closest('.user-dropdown-wrap') && !e.target.closest('.notif-wrap')) {
            closeAllDropdowns();
        }
    });
</script>