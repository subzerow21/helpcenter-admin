@{
    ViewData["Title"] = "Upload Activity";
    Layout = "_ProfileLayout";
}

<div class="profile-layout-container">
    <main class="main-content-wrapper">
        <div class="address-container-centered">
            <div class="header-with-action">
                <h2 class="page-title">Upload Activity</h2>
            </div>

            <hr class="section-divider" />

            <div class="address-form-card">
                <div class="form-header">
                    <h3 class="form-section-title">Manual Activity Entry</h3>
                </div>

                <div class="upload-grid">
                    <div class="upload-inputs">
                        <div class="input-field">
                            <label>Activity Title</label>
                            <input type="text" class="custom-input" placeholder="e.g. Morning Sprint" />
                        </div>

                        <div class="input-field">
                            <label>Activity Type</label>
                            <div class="select-wrapper-monochrome">
                                <select class="custom-input select-black">
                                    <option value="run">RUN</option>
                                    <option value="walk">WALK</option>
                                    <option value="cycle">CYCLE</option>
                                </select>
                                <i class="bi bi-chevron-down select-icon-black"></i>
                            </div>
                        </div>

                        <div class="form-grid" style="margin-top: 0;">
                            <div class="input-field">
                                <label>Date</label>
                                <input type="date" class="custom-input" />
                            </div>
                            <div class="input-field">
                                <label>Moving Time</label>
                                <input type="text" class="custom-input" placeholder="00:00:00" />
                            </div>
                        </div>

                        <div class="input-field">
                            <label>Distance (KM)</label>
                            <input type="number" step="0.01" class="custom-input" placeholder="0.00" />
                        </div>
                    </div>

                    <div class="upload-dropzone" onclick="document.getElementById('fileInput').click()">
                        <input type="file" id="fileInput" hidden />
                        <div class="dropzone-content">
                            <div class="empty-icon-wrapper">
                                <i class="bi bi-camera light-icon"></i>
                                <div class="plus-overlay">+</div>
                            </div>
                            <p class="empty-text">Click to upload screenshot</p>
                            <p class="empty-subtext">JPEG or PNG up to 5MB</p>
                        </div>
                    </div>
                </div>

                <div class="form-buttons">
                    <button type="submit" class="btn-pill btn-black">Submit Activity</button>
                </div>
            </div>
        </div>
    </main>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/uploadActivity.css" asp-append-version="true" />
}

