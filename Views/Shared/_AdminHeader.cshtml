<div class="d-flex align-items-center justify-content-between w-100">
    <div class="d-flex align-items-center">
        <button class="btn btn-link text-black d-lg-none p-0 me-3 shadow-none" onclick="toggleSidebar()">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>

        <h5 class="fw-bold m-0 text-uppercase d-none d-sm-block" style="font-size: 13px; letter-spacing: 1.5px; color: #000;">
            @ViewData["Title"]
        </h5>
    </div>

    <div class="d-flex align-items-center">
        <!--div class="d-none d-md-block me-4">
            <input type="text" class="form-control form-control-sm bg-transparent px-3 custom-search"
                   placeholder="SEARCH DATA..."
                   style="width: 220px; border-radius: 0; border: 1px solid #e0e0e0; font-size: 11px; letter-spacing: 1px; height: 35px;">
        </div>-->
        

        <div class="dropdown me-3">
            <button class="btn btn-link text-black p-0 position-relative shadow-none border-0" id="notifDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                </svg>
                <span class="custom-badge">3</span>
            </button>

            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-3 p-0 custom-notif-menu" style="width: 280px; border-radius: 0;">
                <li class="px-3 py-3 border-bottom bg-light">
                    <h6 class="m-0 fw-bold text-uppercase" style="font-size: 11px; letter-spacing: 1px;">Alerts</h6>
                </li>
                <li>
                    <a class="dropdown-item py-3 border-bottom notif-item" href="#">
                        <span class="fw-bold d-block mb-1">NEW SELLER</span>
                        <span class="text-muted d-block small">GearWorks Pro requested access.</span>
                    </a>
                </li>
                <li>
                    <a class="dropdown-item py-3 border-bottom notif-item" href="#">
                        <span class="fw-bold d-block mb-1">SYSTEM</span>
                        <span class="text-muted d-block small">AI Sync latency normal.</span>
                    </a>
                </li>
                <li class="bg-black text-center">
                    <a asp-controller="Admin" asp-action="Notifications" class="dropdown-item py-2 text-white text-uppercase fw-bold border-0 view-all-btn" style="font-size: 10px;">View All</a>
                </li>
            </ul>
        </div>

        <div class="d-flex align-items-center border-start ps-3" style="border-color: #eee !important;">
            <div class="text-end me-2 d-none d-md-block">
                <p class="fw-bold m-0" style="font-size: 10px; color: #000; text-uppercase; letter-spacing: 0.5px;">Admin J. Chen</p>
                <small class="text-muted text-uppercase" style="font-size: 9px;">Super Admin</small>
            </div>
            <div class="bg-black text-white rounded-0 d-flex align-items-center justify-content-center fw-bold"
                 style="width: 36px; height: 36px; font-size: 11px;">
                JC
            </div>
        </div>
    </div>
</div>