@model NextHorizon.Models.Admin_Models.SuperAdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Portal - Dashboard";
    Layout = "_AdminLayout";
}

<div class="row g-3 mb-5">
    <div class="col-md-3">
        <div class="stat-card d-flex align-items-center justify-content-between p-3 border border-success">
            <div>
                <p class="stat-label mb-1">Platform Revenue (Net)</p>
                <div class="d-flex align-items-center">
                    <h2 class="stat-value mb-0">₱17.2K</h2>
                    <span class="ms-2 tiny text-muted">5% Commission</span>
                </div>
            </div>
            <div class="stat-icon-wrapper text-success">
                <i class="bi bi-piggy-bank fs-3"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card d-flex align-items-center justify-content-between p-3 border border-primary">
            <div>
                <p class="stat-label mb-1">Pending Payouts</p>
                <h2 class="stat-value mb-0">12</h2>
                <span class="text-primary tiny fw-bold">Withdrawal Requests</span>
            </div>
            <div class="stat-icon-wrapper text-primary">
                <i class="bi bi-cash-stack fs-3"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card d-flex align-items-center justify-content-between p-3 border-warning shadow-sm">
            <div>
                <p class="stat-label mb-1 text-warning">Unverified Sellers</p>
                <h2 class="stat-value mb-0 text-dark">05</h2>
                <span class="tiny fw-bold text-muted">Awaiting Approval</span>
            </div>
            <div class="stat-icon-wrapper text-warning">
                <i class="bi bi-person-badge fs-3"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card d-flex align-items-center justify-content-between p-3 border-danger shadow-sm">
            <div>
                <p class="stat-label mb-1 text-danger">Help Center</p>
                <h2 class="stat-value mb-0 text-danger">08</h2>
                <span class="tiny fw-bold text-muted">Pending Tickets</span>
            </div>
            <div class="stat-icon-wrapper text-danger">
                <i class="bi bi-chat-dots fs-3"></i>
            </div>
        </div>
    </div>
</div>

<div class="row mb-5 g-4">
    <div class="col-md-8">
        <div class="bg-white border rounded-4 shadow-sm mb-4">
            <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-light rounded-top-4">
                <h6 class="m-0 fw-bold small text-uppercase"><i class="bi bi-shield-check me-2"></i>Admin Approval Hub</h6>
                <a href="/Admin/Approvals" class="text-decoration-none tiny fw-bold text-dark text-uppercase">See All <i class="bi bi-arrow-right"></i></a>
            </div>
            <div class="p-0">
                <table class="table table-sm align-middle mb-0" style="font-size: 0.85rem;">
                    <thead class="bg-white">
                        <tr class="text-muted">
                            <th class="ps-4">Request Type</th>
                            <th>Entity/Seller</th>
                            <th>Amount/Details</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="ps-4"><span class="badge bg-soft-warning text-warning">New Seller</span></td>
                            <td class="fw-bold">TrailMasters Store</td>
                            <td>Business Permit Inc.</td>
                            <td><span class="badge bg-soft-secondary text-secondary">Pending</span></td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-dark py-0" style="font-size: 10px;">Review App</button>
                            </td>
                        </tr>
                        <tr>
                            <td class="ps-4"><span class="badge bg-soft-primary text-primary">Withdrawal</span></td>
                            <td class="fw-bold">Apex Athletics</td>
                            <td>₱12,400.00</td>
                            <td><span class="badge bg-soft-primary text-primary">Processing</span></td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-dark py-0" style="font-size: 10px;">Approve Payout</button>
                            </td>
                        </tr>
                        <tr>
                            <td class="ps-4"><span class="badge bg-soft-success text-success">Voucher App</span></td>
                            <td class="fw-bold">RunFree Promo</td>
                            <td>15% Off (Platform Wide)</td>
                            <td><span class="badge bg-soft-success text-success">Verification</span></td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-dark py-0" style="font-size: 10px;">Verify Voucher</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="leaderboard-container shadow-sm border rounded-4 overflow-hidden">
            <div class="leaderboard-header bg-dark p-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 fw-bold small text-uppercase text-white">Live Global Leaderboard</h6>
                <a href="/Admin/Leaderboard" class="text-decoration-none tiny fw-bold text-white-50 text-uppercase">See All <i class="bi bi-arrow-right"></i></a>
            </div>
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Rank</th>
                        <th>User</th>
                        <th>Distance</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var runner in Model.ConsumerLeaderboard.Take(5))
                    {
                        <tr>
                            <td class="ps-4">#@runner.Rank</td>
                            <td class="fw-bold">@runner.UserName</td>
                            <td>@runner.StravaKM KM</td>
                            <td><span class="badge rounded-pill bg-soft-success text-success border border-success" style="font-size: 9px;">VERIFIED</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="col-md-4">
        <div class="side-card bg-white p-4 rounded-4 border shadow-sm mb-4">
            <h6 class="fw-bold small text-uppercase mb-3">Help Center: Pending Inbox</h6>
            <div class="d-flex flex-column gap-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-light p-2 rounded text-danger"><i class="bi bi-envelope-exclamation"></i></div>
                    <div class="flex-grow-1">
                        <p class="mb-0 small fw-bold">Payout Not Received</p>
                        <p class="tiny text-muted mb-0">From: Seller_ID_99</p>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-light p-2 rounded text-dark"><i class="bi bi-envelope"></i></div>
                    <div class="flex-grow-1">
                        <p class="mb-0 small fw-bold">Account Verification</p>
                        <p class="tiny text-muted mb-0">From: TrailStore</p>
                    </div>
                </div>
            </div>
            <a asp-controller="Admin" asp-action="HelpCenter" class="btn btn-outline-dark btn-sm w-100 rounded-pill mt-3 tiny fw-bold">Go to Help Desk</a>
        </div>

        <div class="side-card bg-white p-4 rounded-4 border shadow-sm">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold small text-uppercase m-0 text-muted">Platform Audit Log</h6>
                <a href="/Admin/AuditLog" class="text-decoration-none tiny fw-bold text-dark">View All</a>
            </div>
            <ul class="list-unstyled tiny">
                <li class="mb-2 border-bottom pb-1">
                    <i class="bi bi-check-circle-fill text-success me-1"></i> <strong>16:40</strong> - Approved Payout for 'Apex'.
                </li>
                <li class="mb-2 border-bottom pb-1">
                    <i class="bi bi-clock me-1"></i> <strong>16:15</strong> - Admin 'Gemini' updated Payout Terms.
                </li>
                <li class="mb-2">
                    <i class="bi bi-person-plus-fill text-primary me-1"></i> <strong>15:50</strong> - New Seller 'TrailMasters' Application.
                </li>
            </ul>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/admin_css/dashboard.css" asp-append-version="true" />
}