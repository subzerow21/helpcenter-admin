            }

            .faq-scroll::-webkit-scrollbar-thumb {
                background: #e8e8e8;
            }

        .faq-item {
            border-bottom: 1px solid #f5f5f5;
            padding: 12px 16px;
        }

            .faq-item:last-child {
                border-bottom: none;
            }

            .faq-item.editing {
                background: #fafffe;
                border-left: 2px solid #1a1a1a;
            }

        .faq-item-hd {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 8px;
            margin-bottom: 4px;
        }
        /* FIX 1: capitalize FAQ question */
        .faq-q {
            font-size: 12.5px;
            font-weight: 600;
            color: #1a1a1a;
            flex: 1;
            line-height: 1.4;
            text-transform: capitalize;
        }

        .faq-actions {
            display: flex;
            gap: 3px;
            flex-shrink: 0;
        }

        .faq-act {
            background: none;
            border: none;
            cursor: pointer;
