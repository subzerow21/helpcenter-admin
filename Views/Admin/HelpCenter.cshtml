@model NextHorizon.Models.Admin_Models.HelpCenterV2ViewModel
@{
    ViewData["Title"] = "Help Center";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var sessionsJson = System.Text.Json.JsonSerializer.Serialize(Model.Sessions.Select(s => new
    {
        id = s.Id,
        no = s.SessionNo,
        name = s.CustomerName,
        email = s.CustomerEmail,
        role = s.Role,
        av = s.Initials,
        bg = s.AvatarColor,
        waitSec = s.WaitSeconds,
        pos = s.QueuePosition,
        status = s.Status,
        cat = s.Category,
        agent = s.AssignedTo ?? "Unassigned"
    }));

    var agentsJson = System.Text.Json.JsonSerializer.Serialize(Model.Agents.Select(a => new
    {
        name = a.Name,
        initials = a.Initials,
        status = a.Status,
        sessions = a.ActiveSessions,
        max = a.MaxSessions
    }));

    var faqsJson = System.Text.Json.JsonSerializer.Serialize(Model.Faqs.Select(f => new
    {
        id = f.Id,
        q = f.Question,
        a = f.Answer,
        cat = f.Category,
        userType = f.UserType
    }));

    var categoriesJson = System.Text.Json.JsonSerializer.Serialize(Model.Categories);
}

@section Styles {
    <style>
        .admin-content {
            padding: 20px !important;
        }

        /* ── Stats ── */
        .q-stats {
            display: grid;
            grid-template-columns: repeat(5,1fr);
            gap: 12px;
            margin-bottom: 14px;
        }

        .qs {
            background: #fff;
            border: 1px solid #e8e8e8;
            padding: 12px 16px;
        }

        .qs-lbl {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: #aaa;
            margin-bottom: 5px;
        }

        .qs-val {
            font-size: 20px;
            font-weight: 700;
            color: #1a1a1a;
            letter-spacing: -0.5px;
            line-height: 1;
        }

        .qs-sub {
            font-size: 10px;
            color: #aaa;
            margin-top: 4px;
        }

            .qs-sub.warn {
                color: #854F0B;
                display: flex;
                align-items: center;
                gap: 3px;
            }

        .up {
            color: #27500A;
            font-weight: 600;
        }

        .dn {
            color: #A32D2D;
            font-weight: 600;
        }

        /* ── Shell ── */
        .hc-shell {
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 14px;
            height: calc(100vh - 62px - 52px - 80px - 14px);
            min-height: 580px;
        }

        .hc-left {
            display: flex;
            flex-direction: column;
