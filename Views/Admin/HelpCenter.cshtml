@model NextHorizon.Models.Admin_Models.HelpCenterViewModel
@{
    ViewData["Title"] = "Help Center";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var ticketsJson = System.Text.Json.JsonSerializer.Serialize(Model.Tickets.Select(t => new
    {
        id = t.Id,
        no = t.TicketNo,
        subj = t.Subject,
        name = t.CustomerName,
        email = t.CustomerEmail,
        av = t.Initials,
        avBg = t.AvatarColor,
        status = t.Status,
        cat = t.Category,
        date = t.DateLabel,
        role = t.Role,
        msgs = t.Messages.Select(m => new
        {
            from = m.Sender,
            av = m.Initials,
            avBg = m.AvatarColor,
            text = m.Body,
            time = m.TimeLabel,
            resolved = m.IsResolved
        })
    }));
}

@section Styles {
    <style>
        * {
            font-family: 'Poppins', sans-serif;
        }

        .hc-stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 14px;
            margin-bottom: 22px;
        }

        .hc-stat {
            background: #fff;
            border: 1px solid #e8e8e8;
            padding: 18px 20px;
        }

        .hc-stat-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: #aaa;
            margin-bottom: 8px;
        }

        .hc-stat-val {
            font-size: 28px;
            font-weight: 700;
            color: #1a1a1a;
            letter-spacing: -0.5px;
            line-height: 1;
        }

        .hc-stat-sub {
            font-size: 11px;
            color: #aaa;
            margin-top: 6px;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .up {
            color: #27500A;
            font-weight: 600;
        }

        .down {
            color: #A32D2D;
            font-weight: 600;
        }

        .hc-grid {
            display: grid;
            grid-template-columns: 1fr 390px;
            gap: 14px;
            height: calc(100vh - 62px - 52px - 136px - 14px);
            min-height: 520px;
        }

        .hc-panel {
            background: #fff;
            border: 1px solid #e8e8e8;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .hc-panel-hd {
            padding: 15px 20px;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }

        .hc-panel-title {
            font-size: 11.5px;
            font-weight: 700;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            color: #1a1a1a;
        }

        .hc-panel-sub {
            font-size: 11px;
            color: #aaa;
            font-weight: 400;
            margin-top: 2px;
        }

        .btn-new {
            background: #1a1a1a;
            color: #fff;
            border: none;
            padding: 7px 16px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
            letter-spacing: 0.3px;
            transition: background .15s;
        }

            .btn-new:hover {
                background: #333;
            }

        .hc-tabs {
            display: flex;
            border-bottom: 2px solid #f0f0f0;
            padding: 0 20px;
            flex-shrink: 0;
        }

        .hc-tab {
            padding: 11px 0;
            margin-right: 20px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            color: #bbb;
            cursor: pointer;
            border: none;
            border-bottom: 2px solid transparent;
            margin-bottom: -2px;
            background: none;
            font-family: 'Poppins', sans-serif;
            transition: color .2s, border-color .2s;
        }

            .hc-tab:hover {
                color: #555;
            }

            .hc-tab.active {
                color: #1a1a1a;
                border-bottom-color: #1a1a1a;
            }

        .hc-filters {
            padding: 10px 20px;
            border-bottom: 1px solid #f5f5f5;
            display: flex;
            align-items: center;
            gap: 6px;
            flex-shrink: 0;
            flex-wrap: wrap;
        }

        .hc-filter {
            background: #f5f5f5;
            border: 1px solid #e8e8e8;
            color: #666;
            font-size: 11px;
            font-weight: 600;
            padding: 5px 12px;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
            letter-spacing: 0.3px;
            transition: all .15s;
        }

            .hc-filter:hover:not(.active) {
                background: #ebebeb;
            }

            .hc-filter.active {
                background: #1a1a1a;
                color: #fff;
                border-color: #1a1a1a;
            }

        .hc-search {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 8px;
            background: #f8f8f8;
            border: 1px solid #e8e8e8;
            padding: 6px 12px;
            max-width: 210px;
            flex: 1;
        }

            .hc-search svg {
                width: 13px;
                height: 13px;
                stroke: #bbb;
                fill: none;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
                flex-shrink: 0;
            }

            .hc-search input {
                background: none;
                border: none;
                outline: none;
                font-size: 12px;
                font-family: 'Poppins', sans-serif;
                color: #1a1a1a;
                width: 100%;
            }

                .hc-search input::placeholder {
                    color: #ccc;
                }

        .ticket-scroll {
            overflow-y: auto;
            flex: 1;
        }

            .ticket-scroll::-webkit-scrollbar {
                width: 3px;
            }

            .ticket-scroll::-webkit-scrollbar-thumb {
                background: #e8e8e8;
            }

        .ticket-tbl {
            width: 100%;
            border-collapse: collapse;
        }

            .ticket-tbl th {
                font-size: 10px;
                font-weight: 700;
                letter-spacing: 1px;
                text-transform: uppercase;
                color: #aaa;
                padding: 10px 20px;
                text-align: left;
                border-bottom: 1px solid #f0f0f0;
                background: #fafafa;
                position: sticky;
                top: 0;
                z-index: 1;
            }

            .ticket-tbl td {
                padding: 13px 20px;
                border-bottom: 1px solid #f5f5f5;
                vertical-align: middle;
            }

            .ticket-tbl tbody tr {
                cursor: pointer;
                transition: background .1s;
            }

                .ticket-tbl tbody tr:hover td {
                    background: #fafafa;
                }

                .ticket-tbl tbody tr.selected td {
                    background: #f5f5f5 !important;
                }

                .ticket-tbl tbody tr:last-child td {
                    border-bottom: none;
                }

        .t-user {
            display: flex;
            align-items: center;
            gap: 9px;
        }

        .t-av {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            flex-shrink: 0;
        }

        .t-name {
            font-size: 12.5px;
            font-weight: 600;
            color: #1a1a1a;
        }

        .t-email {
            font-size: 11px;
            color: #aaa;
            font-weight: 300;
        }

        .t-subj {
            font-size: 12.5px;
            color: #333;
            font-weight: 500;
            max-width: 200px;
        }

        .t-ref {
            font-size: 11px;
            color: #bbb;
            font-weight: 300;
            margin-top: 2px;
        }

        .t-date {
            font-size: 11.5px;
            color: #aaa;
            font-weight: 300;
            white-space: nowrap;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            padding: 3px 9px;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .badge-open {
            background: #EAF3DE;
            color: #27500A;
        }

        .badge-pending {
            background: #FAEEDA;
            color: #633806;
        }

        .badge-closed {
            background: #f0f0f0;
            color: #666;
        }

        .badge-urgent {
            background: #FCEBEB;
            color: #791F1F;
        }

        .btn-view {
            background: #1a1a1a;
            color: #fff;
            border: none;
            padding: 5px 12px;
            font-size: 10.5px;
            font-weight: 600;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
            letter-spacing: 0.3px;
            transition: background .15s;
            white-space: nowrap;
        }

            .btn-view:hover {
                background: #333;
            }

            .btn-view.outline {
                background: #fff;
                color: #1a1a1a;
                border: 1px solid #e0e0e0;
            }

                .btn-view.outline:hover {
                    background: #f5f5f5;
                }

        .detail-wrap {
            display: flex;
            flex-direction: column;
            height: 100%;
            overflow: hidden;
        }

        .detail-hd {
            padding: 14px 20px;
            border-bottom: 1px solid #f0f0f0;
            flex-shrink: 0;
        }

        .detail-no {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: #aaa;
            margin-bottom: 5px;
        }

        .detail-subj {
            font-size: 13px;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 6px;
            line-height: 1.3;
        }

        .detail-meta {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .detail-meta-txt {
            font-size: 11px;
            color: #aaa;
        }

        .detail-user {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 20px;
            border-bottom: 1px solid #f5f5f5;
            flex-shrink: 0;
        }

        .detail-user-av {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 11px;
            font-weight: 700;
            flex-shrink: 0;
        }

        .detail-uname {
            font-size: 12.5px;
            font-weight: 600;
            color: #1a1a1a;
        }

        .detail-uemail {
            font-size: 11px;
            color: #aaa;
        }

        .chat-msgs {
            flex: 1;
            overflow-y: auto;
            padding: 16px 20px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            min-height: 0;
        }

            .chat-msgs::-webkit-scrollbar {
                width: 3px;
            }

            .chat-msgs::-webkit-scrollbar-thumb {
                background: #e8e8e8;
            }

        .cm {
            display: flex;
            gap: 8px;
            align-items: flex-end;
        }

            .cm.cm-admin {
                flex-direction: row-reverse;
            }

        .cm-av {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 9px;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        .cm-admin .cm-av {
            color: #555;
        }

        .cm-body {
            max-width: 80%;
        }

        .cm-bub {
            padding: 9px 13px;
            font-size: 12.5px;
            line-height: 1.55;
            background: #f5f5f5;
            color: #1a1a1a;
            border: 1px solid #eee;
            border-radius: 3px 14px 14px 14px;
        }

        .cm-admin .cm-bub {
            background: #1a1a1a;
            color: #fff;
            border-color: #1a1a1a;
            border-radius: 14px 3px 14px 14px;
        }

        .cm-bub.resolved {
            background: #EAF3DE;
            color: #27500A;
            border-color: #C0DD97;
        }

        .cm-time {
            font-size: 10px;
            color: #ccc;
            margin-top: 4px;
        }

        .cm-admin .cm-time {
            text-align: right;
        }

        .empty-state {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #ccc;
            gap: 10px;
            padding: 2rem;
            text-align: center;
        }

            .empty-state svg {
                width: 40px;
                height: 40px;
                stroke: #ddd;
                fill: none;
                stroke-width: 1.5;
            }

            .empty-state p {
                font-size: 12.5px;
                color: #bbb;
            }

        .chat-input-sec {
            padding: 12px 20px;
            border-top: 1px solid #f0f0f0;
            flex-shrink: 0;
        }

        .ci-row {
            display: flex;
            gap: 8px;
            background: #f8f8f8;
            border: 1.5px solid #e8e8e8;
            padding: 8px 8px 8px 14px;
            transition: border-color .2s;
        }

            .ci-row:focus-within {
                border-color: #1a1a1a;
            }

        .ci-field {
            flex: 1;
            background: none;
            border: none;
            outline: none;
            font-size: 12.5px;
            font-family: 'Poppins', sans-serif;
            color: #1a1a1a;
            padding: 4px 0;
        }

            .ci-field::placeholder {
                color: #ccc;
            }

        .ci-send {
            width: 36px;
            height: 36px;
            background: #1a1a1a;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: background .15s;
        }

            .ci-send:hover {
                background: #333;
            }

            .ci-send svg {
                width: 14px;
                height: 14px;
                fill: none;
                stroke: #fff;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
            }

        .action-btns {
            display: flex;
            gap: 8px;
            margin-top: 8px;
        }

        .action-btn {
            flex: 1;
            background: #fff;
            border: 1px solid #e0e0e0;
            color: #555;
            font-size: 11px;
            font-weight: 600;
            padding: 7px 0;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
            letter-spacing: 0.3px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
            transition: all .15s;
        }

            .action-btn:hover {
                background: #f5f5f5;
            }

            .action-btn svg {
                width: 13px;
                height: 13px;
                fill: none;
                stroke: currentColor;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
            }

            .action-btn.resolve {
                background: #1a1a1a;
                color: #fff;
                border-color: #1a1a1a;
            }

                .action-btn.resolve:hover {
                    background: #333;
                }
    </style>
}

<!-- STATS -->
<div class="hc-stats">
    <div class="hc-stat">
        <div class="hc-stat-label">Total Tickets</div>
        <div class="hc-stat-val">@Model.Stats.TotalTickets.ToString("N0")</div>
        <div class="hc-stat-sub"><span class="up">+12%</span> vs last month</div>
    </div>
    <div class="hc-stat">
        <div class="hc-stat-label">Open</div>
        <div class="hc-stat-val" id="statOpen">@Model.Stats.OpenTickets</div>
        <div class="hc-stat-sub"><span class="down">+8</span> since yesterday</div>
    </div>
    <div class="hc-stat">
        <div class="hc-stat-label">Avg. Response</div>
        <div class="hc-stat-val">@Model.Stats.AvgResponse</div>
        <div class="hc-stat-sub"><span class="up">&#8722;18min</span> faster</div>
    </div>
    <div class="hc-stat">
        <div class="hc-stat-label">Resolved Today</div>
        <div class="hc-stat-val" id="statResolved">@Model.Stats.ResolvedToday</div>
        <div class="hc-stat-sub"><span class="up">+5</span> vs yesterday</div>
    </div>
</div>

<!-- MAIN GRID -->
<div class="hc-grid">

    <!-- LEFT: TICKET LIST -->
    <div class="hc-panel">
        <div class="hc-panel-hd">
            <div>
                <div class="hc-panel-title">Support Tickets</div>
                <div class="hc-panel-sub">
                    @Model.Stats.OpenTickets open &middot;
                    @Model.Stats.PendingTickets pending &middot;
                    @Model.Stats.UrgentTickets urgent
                </div>
            </div>
      
        </div>

        <div class="hc-tabs">
            <button class="hc-tab active" data-filter="all" onclick="setTab(this)">All</button>
            <button class="hc-tab" data-filter="open" onclick="setTab(this)">Open</button>
            <button class="hc-tab" data-filter="pending" onclick="setTab(this)">Pending</button>
            <button class="hc-tab" data-filter="urgent" onclick="setTab(this)">Urgent</button>
            <button class="hc-tab" data-filter="closed" onclick="setTab(this)">Closed</button>
        </div>

        <div class="hc-filters">
            <button class="hc-filter active" data-cat="all" onclick="setCat(this)">All Types</button>
            <button class="hc-filter" data-cat="orders" onclick="setCat(this)">Orders</button>
            <button class="hc-filter" data-cat="returns" onclick="setCat(this)">Returns</button>
            <button class="hc-filter" data-cat="payments" onclick="setCat(this)">Payments</button>
            <div class="hc-search">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.35-4.35" /></svg>
                <input type="text" id="searchInput" placeholder="Search tickets..." oninput="applyFilters()" />
            </div>
        </div>

        <div class="ticket-scroll">
            <table class="ticket-tbl">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Subject</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="ticketBody"></tbody>
            </table>
        </div>
    </div>

    <!-- RIGHT: TICKET DETAIL -->
    <div class="hc-panel">
        <div class="hc-panel-hd">
            <div class="hc-panel-title">Ticket Detail</div>
            <span class="badge" id="detailStatusBadge"></span>
        </div>

        <div class="detail-wrap">
            <div class="detail-hd">
                <div class="detail-no" id="detailNo">Select a ticket to view</div>
                <div class="detail-subj" id="detailSubj"></div>
                <div class="detail-meta">
                    <span class="badge" id="detailBadge"></span>
                    <span class="detail-meta-txt" id="detailMetaTxt"></span>
                </div>
            </div>

            <div class="detail-user" id="detailUser" style="display:none;">
                <div class="detail-user-av" id="detailAv"></div>
                <div>
                    <div class="detail-uname" id="detailName"></div>
                    <div class="detail-uemail" id="detailEmail"></div>
                </div>
            </div>

            <div class="chat-msgs" id="chatMsgs">
                <div class="empty-state">
                    <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
                    <p>Select a ticket from the list<br>to view the conversation.</p>
                </div>
            </div>

            <div class="chat-input-sec" id="chatInputSec" style="display:none;">
                <div class="ci-row">
                    <input class="ci-field" id="replyInput"
                           placeholder="Type a reply to the customer..."
                           onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendReply();}" />
                    <button class="ci-send" onclick="sendReply()" title="Send">
                        <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13" /><polygon points="22 2 15 22 11 13 2 9 22 2" /></svg>
                    </button>
                </div>
                <div class="action-btns">
                    <button class="action-btn">
                        <svg viewBox="0 0 24 24"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48" /></svg>
                        Attach
                    </button>
                    <button class="action-btn">
                        <svg viewBox="0 0 24 24"><polyline points="15 3 21 3 21 9" /><polyline points="9 21 3 21 3 15" /><line x1="21" y1="3" x2="14" y2="10" /><line x1="3" y1="21" x2="10" y2="14" /></svg>
                        Transfer
                    </button>
                    <button class="action-btn resolve" id="resolveBtn" onclick="resolveTicket()">
                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                        Resolve
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var TICKETS   = @Html.Raw(ticketsJson);
        var activeId  = null;
        var statusTab = 'all';
        var catFilter = 'all';

        function badgeClass(s) { return 'badge badge-' + s; }
        function badgeLabel(s) { return s.charAt(0).toUpperCase() + s.slice(1); }

        function renderTable() {
            var q = (document.getElementById('searchInput').value || '').toLowerCase();
            var rows = TICKETS.filter(function (t) {
                return (statusTab === 'all' || t.status === statusTab)
                    && (catFilter === 'all' || t.cat === catFilter)
                    && (!q || t.name.toLowerCase().includes(q) || t.subj.toLowerCase().includes(q) || t.no.toLowerCase().includes(q));
            });

            var tbody = document.getElementById('ticketBody');
            tbody.innerHTML = '';
            rows.forEach(function (t) {
                var isClosed = t.status === 'closed';
                var tr = document.createElement('tr');
                if (t.id === activeId) tr.classList.add('selected');
                tr.onclick = function () { selectTicket(t.id); };
                tr.innerHTML =
                    '<td><div class="t-user">'
                    + '<div class="t-av" style="background:' + t.avBg + '">' + t.av + '</div>'
                    + '<div><div class="t-name">' + t.name + '</div><div class="t-email">' + t.role + '</div></div></div></td>'
                    + '<td><div class="t-subj">' + t.subj + '</div><div class="t-ref">' + t.no + '</div></td>'
                    + '<td><span class="' + badgeClass(t.status) + '">' + badgeLabel(t.status) + '</span></td>'
                    + '<td class="t-date">' + t.date + '</td>'
                    + '<td><button class="btn-view' + (isClosed ? ' outline' : '') + '">'
                    + (isClosed ? 'Reopen' : 'View') + '</button></td>';
                tbody.appendChild(tr);
            });
        }

        function selectTicket(id) {
            activeId = id;
            var t = TICKETS.find(function (x) { return x.id === id; });
            if (!t) return;

            renderTable();

            document.getElementById('detailNo').textContent   = 'Ticket #' + t.no;
            document.getElementById('detailSubj').textContent = t.subj;

            var db = document.getElementById('detailBadge');
            db.className = badgeClass(t.status); db.textContent = badgeLabel(t.status);

            var dsb = document.getElementById('detailStatusBadge');
            dsb.className = badgeClass(t.status); dsb.textContent = badgeLabel(t.status);

            document.getElementById('detailMetaTxt').textContent =
                t.cat.charAt(0).toUpperCase() + t.cat.slice(1) + ' · ' + t.date + ', 2025';

            var userRow = document.getElementById('detailUser');
            userRow.style.display = 'flex';

            var av = document.getElementById('detailAv');
            av.textContent = t.av; av.style.background = t.avBg;

            document.getElementById('detailName').textContent  = t.name;
            document.getElementById('detailEmail').textContent = t.role;

            renderMsgs(t);

            document.getElementById('chatInputSec').style.display = 'block';
            document.getElementById('replyInput').value = '';

            var rb = document.getElementById('resolveBtn');
            if (t.status === 'closed') {
                rb.innerHTML = '<svg viewBox="0 0 24 24" style="width:13px;height:13px;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg> Reopen';
                rb.onclick = reopenTicket;
            } else {
                rb.innerHTML = '<svg viewBox="0 0 24 24" style="width:13px;height:13px;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round"><polyline points="20 6 9 17 4 12"/></svg> Resolve';
                rb.onclick = resolveTicket;
            }
        }

        function renderMsgs(t) {
            var area = document.getElementById('chatMsgs');
            area.innerHTML = '';
            t.msgs.forEach(function (m) {
                var isAdmin = m.from === 'admin';
                var d = document.createElement('div');
                d.className = 'cm' + (isAdmin ? ' cm-admin' : '');
                d.innerHTML =
                    '<div class="cm-av" style="background:' + m.avBg + ';' + (isAdmin ? 'color:#555;' : '') + '">' + m.av + '</div>'
                    + '<div class="cm-body"><div class="cm-bub' + (m.resolved ? ' resolved' : '') + '">' + m.text + '</div>'
                    + '<div class="cm-time">' + m.time + '</div></div>';
                area.appendChild(d);
            });
            area.scrollTop = area.scrollHeight;
        }

        function sendReply() {
            var input = document.getElementById('replyInput');
            var text  = input.value.trim();
            if (!text || activeId === null) return;

            var t = TICKETS.find(function (x) { return x.id === activeId; });
            if (!t) return;

            var ts = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            t.msgs.push({ from: 'admin', av: 'JC', avBg: '#e8e8e8', text: text, time: 'Today, ' + ts, resolved: false });
            renderMsgs(t);
            input.value = '';
            input.disabled = true;

            fetch('/Admin/HelpCenterReply', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ticketId: activeId, message: text })
            })
            .catch(function () { return { success: true }; })
            .finally(function () { input.disabled = false; input.focus(); });
        }

        function resolveTicket() {
            if (activeId === null) return;
            fetch('/Admin/HelpCenterResolve', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ticketId: activeId })
            })
            .catch(function () { return {}; })
            .then(function () {
                var t = TICKETS.find(function (x) { return x.id === activeId; });
                t.status = 'closed';
                var now = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                t.msgs.push({ from: 'admin', av: 'JC', avBg: '#e8e8e8',
                    text: 'This ticket has been marked as <strong>resolved</strong>. Thank you for contacting Next Horizon!',
                    time: 'Today, ' + now, resolved: true });
                renderMsgs(t);
                selectTicket(activeId);
                renderTable();
            });
        }

        function reopenTicket() {
            if (activeId === null) return;
            fetch('/Admin/HelpCenterReopen', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ticketId: activeId })
            })
            .catch(function () { return {}; })
            .then(function () {
                var t = TICKETS.find(function (x) { return x.id === activeId; });
                t.status = 'open';
                var now = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                t.msgs.push({ from: 'admin', av: 'JC', avBg: '#e8e8e8',
                    text: 'This ticket has been reopened. Our team will follow up shortly.',
                    time: 'Today, ' + now, resolved: false });
                renderMsgs(t);
                selectTicket(activeId);
                renderTable();
            });
        }

        function setTab(el) {
            document.querySelectorAll('.hc-tab').forEach(function (t) { t.classList.remove('active'); });
            el.classList.add('active');
            statusTab = el.getAttribute('data-filter');
            applyFilters();
        }

        function setCat(el) {
            document.querySelectorAll('.hc-filter').forEach(function (b) { b.classList.remove('active'); });
            el.classList.add('active');
            catFilter = el.getAttribute('data-cat');
            applyFilters();
        }

        function applyFilters() { renderTable(); }

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                var s = document.getElementById('searchInput');
                if (s && s.value) { s.value = ''; applyFilters(); }
            }
        });

        renderTable();
    </script>
}
