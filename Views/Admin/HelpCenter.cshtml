@model NextHorizon.Models.Admin_Models.HelpCenterV2ViewModel
@{
    ViewData["Title"] = "Help Center";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var sessionsJson = System.Text.Json.JsonSerializer.Serialize(Model.Sessions.Select(s => new
    {
        id = s.Id,
        no = s.SessionNo,
        name = s.CustomerName,
        email = s.CustomerEmail,
        role = s.Role,
        av = s.Initials,
        bg = s.AvatarColor,
        waitSec = s.WaitSeconds,
        pos = s.QueuePosition,
        status = s.Status,
        cat = s.Category,
        agent = s.AssignedTo ?? "Unassigned"
    }));

    var agentsJson = System.Text.Json.JsonSerializer.Serialize(Model.Agents.Select(a => new
    {
        name = a.Name,
        initials = a.Initials,
        status = a.Status,
        sessions = a.ActiveSessions,
        max = a.MaxSessions
    }));

    var faqsJson = System.Text.Json.JsonSerializer.Serialize(Model.Faqs.Select(f => new
    {
        id = f.Id,
        q = f.Question,
        a = f.Answer,
        cat = f.Category
    }));
}

@section Styles {
    <style>
        .admin-content {
            padding: 20px !important;
        }

        /* ── STATS ── */
        .q-stats {
            display: grid;
            grid-template-columns: repeat(5,1fr);
            gap: 12px;
            margin-bottom: 14px;
        }

        .qs {
            background: #fff;
            border: 1px solid #e8e8e8;
            padding: 12px 16px;
        }

        .qs-lbl {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: #aaa;
            margin-bottom: 5px;
        }

        .qs-val {
            font-size: 20px;
            font-weight: 700;
            color: #1a1a1a;
            letter-spacing: -0.5px;
            line-height: 1;
        }

        .qs-sub {
            font-size: 10px;
            color: #aaa;
            margin-top: 4px;
        }

            .qs-sub.warn {
                color: #854F0B;
                display: flex;
                align-items: center;
                gap: 3px;
            }

        .up {
            color: #27500A;
            font-weight: 600;
        }

        .dn {
            color: #A32D2D;
            font-weight: 600;
        }

        /* ── SHELL ── */
        .hc-shell {
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 14px;
            height: calc(100vh - 62px - 52px - 80px - 14px);
            min-height: 580px;
        }

        .hc-left {
            display: flex;
            flex-direction: column;
            gap: 14px;
            overflow: hidden;
        }

        .hc-right {
            display: flex;
            flex-direction: column;
            gap: 14px;
            overflow: hidden;
        }

        /* ── PANEL ── */
        .panel {
            background: #fff;
            border: 1px solid #e8e8e8;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .ph {
            padding: 12px 18px;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }

        .ph-title {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            color: #1a1a1a;
        }

        .ph-sub {
            font-size: 11px;
            color: #aaa;
            font-weight: 400;
            margin-top: 1px;
        }

        /* ── BUTTONS ── */
        .pbtn {
            background: #1a1a1a;
            color: #fff;
            border: none;
            padding: 6px 13px;
            font-size: 10.5px;
            font-weight: 600;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
            letter-spacing: 0.3px;
            transition: background .15s;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

            .pbtn:hover {
                background: #333;
            }

            .pbtn.out {
                background: #fff;
                color: #1a1a1a;
                border: 1px solid #e0e0e0;
            }

                .pbtn.out:hover {
                    background: #f5f5f5;
                }

            .pbtn.danger {
                background: #FCEBEB;
                color: #791F1F;
                border: 1px solid #f0c0c0;
            }

                .pbtn.danger:hover {
                    background: #fad4d4;
                }

            .pbtn svg {
                width: 12px;
                height: 12px;
                fill: none;
                stroke: currentColor;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
            }

        /* ── QUEUE ── */
        .q-scroll {
            overflow-y: auto;
            flex: 1;
        }

            .q-scroll::-webkit-scrollbar {
                width: 3px;
            }

            .q-scroll::-webkit-scrollbar-thumb {
                background: #e8e8e8;
            }

        .qtbl {
            width: 100%;
            border-collapse: collapse;
        }

            .qtbl th {
                font-size: 9.5px;
                font-weight: 700;
                letter-spacing: 1px;
                text-transform: uppercase;
                color: #aaa;
                padding: 9px 16px;
                text-align: left;
                border-bottom: 1px solid #f0f0f0;
                background: #fafafa;
                position: sticky;
                top: 0;
                z-index: 1;
            }

            .qtbl td {
                padding: 10px 16px;
                border-bottom: 1px solid #f5f5f5;
                vertical-align: middle;
            }

            .qtbl tbody tr {
                cursor: pointer;
                transition: background .1s;
            }

                .qtbl tbody tr:hover td {
                    background: #fafafa;
                }

                .qtbl tbody tr.sel td {
                    background: #f5f5f5 !important;
                }

                .qtbl tbody tr:last-child td {
                    border-bottom: none;
                }

        .q-cust {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .q-av {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        .q-name {
            font-size: 12px;
            font-weight: 600;
            color: #1a1a1a;
        }

        .q-role {
            font-size: 10.5px;
            color: #aaa;
            font-weight: 300;
        }

        .q-wait {
            font-size: 12px;
            font-weight: 600;
            color: #1a1a1a;
            font-variant-numeric: tabular-nums;
        }

            .q-wait.over5 {
                color: #791F1F;
            }

        .sla-bar {
            width: 44px;
            height: 5px;
            background: #f0f0f0;
            border-radius: 2px;
            overflow: hidden;
            display: inline-block;
        }

        .sla-fill {
            height: 5px;
            border-radius: 2px;
        }

        .sl-ok {
            background: #4ade80;
        }

        .sl-warn {
            background: #f59e0b;
        }

        .sl-red {
            background: #e24b4a;
        }

        /* ── BADGES ── */
        .badge {
            display: inline-flex;
            align-items: center;
            padding: 2px 8px;
            font-size: 9.5px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .b-waiting {
            background: #EAF3DE;
            color: #27500A;
        }

        .b-active {
            background: #e8f0fe;
            color: #0c447c;
        }

        .b-idle {
            background: #FAEEDA;
            color: #633806;
        }

        .b-done {
            background: #f0f0f0;
            color: #666;
        }

        .b-online {
            background: #EAF3DE;
            color: #27500A;
        }

        .b-busy {
            background: #e8f0fe;
            color: #0c447c;
        }

        .b-away {
            background: #FAEEDA;
            color: #633806;
        }

        .b-offline {
            background: #f0f0f0;
            color: #666;
        }

        .b-full {
            background: #FCEBEB;
            color: #791F1F;
        }

        .b-resolved {
            background: #EAF3DE;
            color: #27500A;
        }

        /* ── WAIT WARNING ── */
        .wait-warn {
            background: #FCEBEB;
            border-left: 3px solid #e24b4a;
            padding: 8px 14px;
            display: none;
            align-items: center;
            font-size: 11.5px;
            flex-shrink: 0;
        }

            .wait-warn.show {
                display: flex;
            }

        .ww-left {
            display: flex;
            align-items: center;
            gap: 6px;
            color: #791F1F;
            font-weight: 500;
        }

            .ww-left svg {
                width: 13px;
                height: 13px;
                stroke: #791F1F;
                fill: none;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
                flex-shrink: 0;
            }

        /* ── AGENT STATUS — 3 COLUMNS ── */
        .agent-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 0;
            flex: 1;
            overflow: hidden;
        }

        .agent-col {
            border-right: 1px solid #f0f0f0;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

            .agent-col:last-child {
                border-right: none;
            }

        .agent-col-hd {
            padding: 8px 12px;
            background: #fafafa;
            border-bottom: 1px solid #f0f0f0;
            font-size: 9.5px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: #aaa;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .slot-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #e8e8e8;
        }

            .slot-dot.filled {
                background: #1a1a1a;
            }

        .agent-col-body {
            flex: 1;
            overflow-y: auto;
        }

            .agent-col-body::-webkit-scrollbar {
                width: 3px;
            }

            .agent-col-body::-webkit-scrollbar-thumb {
                background: #e8e8e8;
            }

        .agent-slot {
            padding: 9px 12px;
            border-bottom: 1px solid #f5f5f5;
            display: flex;
            align-items: center;
            gap: 7px;
        }

            .agent-slot:last-child {
                border-bottom: none;
            }

        .ag-av {
            width: 28px;
            height: 28px;
            background: #1a1a1a;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 9.5px;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
            position: relative;
        }

        .ag-dot {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            border: 2px solid #fff;
        }

        .d-on {
            background: #4ade80;
        }

        .d-busy {
            background: #378ADD;
        }

        .d-away {
            background: #f59e0b;
        }

        .d-off {
            background: #ccc;
        }

        .ag-info {
            flex: 1;
            min-width: 0;
        }

        .ag-name {
            font-size: 11px;
            font-weight: 600;
            color: #1a1a1a;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .ag-chat {
            font-size: 10px;
            color: #aaa;
            margin-top: 1px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .empty-slot {
            padding: 9px 12px;
            font-size: 11px;
            color: #ddd;
            font-style: italic;
            border-bottom: 1px solid #f5f5f5;
        }

            .empty-slot:last-child {
                border-bottom: none;
            }

        /* ── FAQ FORM ── */
        .faq-form {
            background: #fff;
            border: 1px solid #e8e8e8;
            flex-shrink: 0;
        }

        .faq-form-body {
            padding: 12px 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .faq-inp {
            width: 100%;
            background: #f8f8f8;
            border: 1.5px solid #e8e8e8;
            padding: 8px 12px;
            font-size: 12.5px;
            font-family: 'Poppins', sans-serif;
            color: #1a1a1a;
            outline: none;
            transition: border-color .2s;
        }

            .faq-inp:focus {
                border-color: #1a1a1a;
            }

            .faq-inp::placeholder {
                color: #ccc;
            }

        textarea.faq-inp {
            resize: none;
            height: 58px;
            line-height: 1.5;
        }

        .faq-cats {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }

        .cat-chip {
            background: #f5f5f5;
            border: 1px solid #e8e8e8;
            color: #666;
            font-size: 11px;
            font-weight: 600;
            padding: 4px 11px;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
            transition: all .15s;
        }

            .cat-chip.on {
                background: #1a1a1a;
                color: #fff;
                border-color: #1a1a1a;
            }

        .faq-form-foot {
            padding: 9px 16px;
            border-top: 1px solid #f0f0f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .char-count {
            font-size: 10.5px;
            color: #aaa;
        }

        /* ── FAQ LIST ── */
        .faq-list-panel {
            background: #fff;
            border: 1px solid #e8e8e8;
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            min-height: 0;
        }

        .faq-search {
            padding: 9px 16px;
            border-bottom: 1px solid #f5f5f5;
            display: flex;
            align-items: center;
            gap: 8px;
            background: #fafafa;
            flex-shrink: 0;
        }

            .faq-search svg {
                width: 12px;
                height: 12px;
                stroke: #bbb;
                fill: none;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
                flex-shrink: 0;
            }

            .faq-search input {
                background: none;
                border: none;
                outline: none;
                font-size: 12px;
                font-family: 'Poppins', sans-serif;
                color: #1a1a1a;
                flex: 1;
            }

                .faq-search input::placeholder {
                    color: #ccc;
                }

        .faq-filter {
            display: flex;
            gap: 5px;
            padding: 8px 16px;
            border-bottom: 1px solid #f5f5f5;
            flex-shrink: 0;
            flex-wrap: wrap;
        }

        .ff {
            background: #f5f5f5;
            border: 1px solid #e8e8e8;
            color: #666;
            font-size: 10.5px;
            font-weight: 600;
            padding: 4px 10px;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
            transition: all .15s;
        }

            .ff.on {
                background: #1a1a1a;
                color: #fff;
                border-color: #1a1a1a;
            }

        .faq-scroll {
            overflow-y: auto;
            flex: 1;
        }

            .faq-scroll::-webkit-scrollbar {
                width: 3px;
            }

            .faq-scroll::-webkit-scrollbar-thumb {
                background: #e8e8e8;
            }

        .faq-item {
            border-bottom: 1px solid #f5f5f5;
            padding: 12px 16px;
            transition: background .1s;
        }

            .faq-item:last-child {
                border-bottom: none;
            }

            .faq-item.editing {
                background: #fafffe;
                border-left: 2px solid #1a1a1a;
            }

        .faq-item-hd {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 8px;
            margin-bottom: 5px;
        }

        .faq-q {
            font-size: 12.5px;
            font-weight: 600;
            color: #1a1a1a;
            flex: 1;
            line-height: 1.4;
        }

        .faq-actions {
            display: flex;
            gap: 3px;
            flex-shrink: 0;
        }

        .faq-act {
            background: none;
            border: none;
            cursor: pointer;
            padding: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 3px;
            transition: background .15s;
        }

            .faq-act:hover {
                background: #f5f5f5;
            }

            .faq-act svg {
                width: 13px;
                height: 13px;
                fill: none;
                stroke: #888;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
            }

            .faq-act.del svg {
                stroke: #e24b4a;
            }

        .faq-a {
            font-size: 12px;
            color: #555;
            line-height: 1.55;
            font-weight: 300;
        }

        .faq-cat-badge {
            display: inline-flex;
            align-items: center;
            padding: 2px 7px;
            font-size: 9.5px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            margin-top: 6px;
        }

        .fc-orders {
            background: #e8f0fe;
            color: #0c447c;
        }

        .fc-returns {
            background: #FAEEDA;
            color: #633806;
        }

        .fc-payments {
            background: #EAF3DE;
            color: #27500A;
        }

        .fc-shipping {
            background: #EEEDFE;
            color: #3C3489;
        }

        .fc-general {
            background: #f0f0f0;
            color: #666;
        }

        .edit-inp {
            width: 100%;
            background: #f8f8f8;
            border: 1px solid #e8e8e8;
            padding: 6px 10px;
            font-size: 12px;
            font-family: 'Poppins', sans-serif;
            color: #1a1a1a;
            outline: none;
            margin-bottom: 6px;
        }

            .edit-inp:focus {
                border-color: #1a1a1a;
            }

        textarea.edit-inp {
            resize: none;
            height: 50px;
            line-height: 1.5;
        }

        .edit-foot {
            display: flex;
            gap: 6px;
            margin-top: 6px;
        }

        .faq-empty {
            padding: 24px;
            text-align: center;
            color: #ccc;
            font-size: 12px;
        }

        /* TOAST */
        .nh-toast {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #1a1a1a;
            color: #fff;
            padding: 10px 18px;
            font-size: 12px;
            font-weight: 500;
            font-family: 'Poppins', sans-serif;
            z-index: 9999;
            opacity: 0;
            transition: opacity .3s;
            pointer-events: none;
        }

            .nh-toast.show {
                opacity: 1;
            }
    </style>
}

<!-- STATS -->
<div class="q-stats">
    <div class="qs">
        <div class="qs-lbl">In Queue</div>
        <div class="qs-val" id="qsInQueue">@Model.Stats.InQueue</div>
        <div class="qs-sub"><span class="dn">+2</span> vs 30min ago</div>
    </div>
    <div class="qs">
        <div class="qs-lbl">Active Sessions</div>
        <div class="qs-val">@Model.Stats.ActiveSessions</div>
        <div class="qs-sub"><span class="up">@Model.Stats.AgentsOnline agents</span> online</div>
    </div>
    <div class="qs">
        <div class="qs-lbl">Avg. Wait Time</div>
        <div class="qs-val">@Model.Stats.AvgWaitTime</div>
        <div class="qs-sub warn">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#854F0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
            Target: 2:00
        </div>
    </div>
    <div class="qs">
        <div class="qs-lbl">Resolved Today</div>
        <div class="qs-val">@Model.Stats.ResolvedToday</div>
        <div class="qs-sub"><span class="up">+5</span> vs yesterday</div>
    </div>
    <div class="qs">
        <div class="qs-lbl">Total FAQs</div>
        <div class="qs-val" id="statFaqCount">@Model.Faqs.Count</div>
        <div class="qs-sub">across 5 categories</div>
    </div>
</div>

<!-- MAIN SHELL -->
<div class="hc-shell">

    <!-- LEFT -->
    <div class="hc-left">

        <!-- QUEUE TABLE -->
        <div class="panel" style="flex:1;min-height:0;">
            <div class="ph">
                <div>
                    <div class="ph-title">Live Queue</div>
                    <div class="ph-sub" id="qMeta">@Model.Stats.InQueue waiting</div>
                </div>
                <button class="pbtn out" onclick="autoAssign()">Auto-Assign</button>
            </div>

            <div class="wait-warn" id="waitWarn">
                <div class="ww-left">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                    <span id="warnTxt">Customers waiting over 5 minutes &mdash; assign an agent immediately</span>
                </div>
            </div>

            <div class="q-scroll">
                <table class="qtbl">
                    <thead>
                        <tr>
                            <th>Customer</th>
                            <th>Wait Time</th>
                            <th>SLA</th>
                            <th>Status</th>
                            <th>Assigned</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="qBody"></tbody>
                </table>
            </div>
        </div>

        <!-- AGENT STATUS — 3 COLUMNS -->
        <div class="panel" style="flex-shrink:0;height:240px;">
            <div class="ph">
                <div>
                    <div class="ph-title">Agent Status</div>
                    <div class="ph-sub" id="agentMeta">@Model.Stats.AgentsOnline online &middot; max 3 chats each</div>
                </div>
                <div style="font-size:10px;color:#aaa;">Total capacity: <strong style="color:#1a1a1a;">9 sessions</strong></div>
            </div>
            <div class="agent-grid" id="agentGrid"></div>
        </div>

    </div>

    <!-- RIGHT: FAQ MANAGER -->
    <div class="hc-right">

        <!-- ADD FORM -->
        <div class="faq-form">
            <div class="ph">
                <div>
                    <div class="ph-title">FAQ Manager</div>
                    <div class="ph-sub">Add, edit, or delete FAQs in real time</div>
                </div>
            </div>
            <div class="faq-form-body">
                <input class="faq-inp" id="faqQ" type="text" placeholder="Question — e.g. How do I track my order?" maxlength="300" />
                <textarea class="faq-inp" id="faqA" placeholder="Answer — type the full response here..." maxlength="500"></textarea>
                <div class="faq-cats">
                    <div class="cat-chip on" onclick="selCat(this,'orders')">Orders</div>
                    <div class="cat-chip" onclick="selCat(this,'returns')">Returns</div>
                    <div class="cat-chip" onclick="selCat(this,'payments')">Payments</div>
                    <div class="cat-chip" onclick="selCat(this,'shipping')">Shipping</div>
                    <div class="cat-chip" onclick="selCat(this,'general')">General</div>
                </div>
            </div>
            <div class="faq-form-foot">
                <span class="char-count" id="charCount">0 / 500 chars</span>
                <button class="pbtn" onclick="addFaq()">
                    <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                    Add FAQ
                </button>
            </div>
        </div>

        <!-- FAQ LIST -->
        <div class="faq-list-panel">
            <div class="ph">
                <div class="ph-title">Published FAQs</div>
                <span id="faqListCount" style="font-size:11px;color:#aaa;font-weight:500;">@Model.Faqs.Count FAQs</span>
            </div>
            <div class="faq-search">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.35-4.35" /></svg>
                <input type="text" placeholder="Search FAQs..." oninput="filterFaqs(this.value)" />
            </div>
            <div class="faq-filter">
                <button class="ff on" onclick="setFaqFilter(this,'all')">All</button>
                <button class="ff" onclick="setFaqFilter(this,'orders')">Orders</button>
                <button class="ff" onclick="setFaqFilter(this,'returns')">Returns</button>
                <button class="ff" onclick="setFaqFilter(this,'payments')">Payments</button>
                <button class="ff" onclick="setFaqFilter(this,'shipping')">Shipping</button>
                <button class="ff" onclick="setFaqFilter(this,'general')">General</button>
            </div>
            <div class="faq-scroll" id="faqList"></div>
        </div>

    </div>
</div>

<div class="nh-toast" id="nhToast"></div>

@section Scripts {
    <script>
        var SESSIONS  = @Html.Raw(sessionsJson);
        var AGENTS    = @Html.Raw(agentsJson);
        var FAQS      = @Html.Raw(faqsJson);

        var selCategory = 'orders';
        var faqFilter   = 'all';
        var faqSearch   = '';
        var nextId      = @(Model.Faqs.Count > 0 ? Model.Faqs.Max(f => f.Id) + 1 : 1);
        var qTimer      = null;

        /* ── HELPERS ── */
        function fmt(s){ return String(Math.floor(s/60)).padStart(2,'0')+':'+String(s%60).padStart(2,'0'); }
        function cap(s){ return s.charAt(0).toUpperCase()+s.slice(1); }
        function escH(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
        function slaClass(s){ return s<120?'sl-ok':s<300?'sl-warn':'sl-red'; }
        function slaPct(s){ return Math.min(100,Math.round(s/360*100)); }

        function showToast(msg){
            var t=document.getElementById('nhToast');
            t.textContent=msg; t.classList.add('show');
            setTimeout(function(){ t.classList.remove('show'); }, 2400);
        }

        /* ── QUEUE ── */
        function renderQueue(){
            var body=document.getElementById('qBody');
            body.innerHTML='';
            var over5=0;
            SESSIONS.forEach(function(s){
                if(s.waitSec>=300) over5++;
                var tr=document.createElement('tr');
                tr.onclick=function(){};
                var wc=s.waitSec>=300?'q-wait over5':'q-wait';
                var sb=s.status==='active'?'b-active':s.status==='idle'?'b-idle':'b-waiting';
                var sl=s.status==='active'?'Active':s.status==='idle'?'Idle':'Waiting';
                var pct=slaPct(s.waitSec);
                var sc=slaClass(s.waitSec);
                var btnLabel=s.agent==='Unassigned'?'Assign':'Reassign';
                tr.innerHTML=
                    '<td><div class="q-cust"><div class="q-av" style="background:'+s.bg+'">'+s.av+'</div>'
                    +'<div><div class="q-name">'+s.name+'</div><div class="q-role">'+s.role+'</div></div></div></td>'
                    +'<td><div class="'+wc+'">'+fmt(s.waitSec)+'</div></td>'
                    +'<td><div style="display:flex;align-items:center;gap:5px;"><div class="sla-bar"><div class="sla-fill '+sc+'" style="width:'+pct+'%"></div></div><span style="font-size:10px;color:#aaa;">'+fmt(s.waitSec)+'</span></div></td>'
                    +'<td><span class="badge '+sb+'">'+sl+'</span></td>'
                    +'<td style="font-size:11.5px;font-weight:'+(s.agent==='Unassigned'?'400;color:#aaa':'500;color:#1a1a1a')+';">'+s.agent+'</td>'
                    +'<td><button class="pbtn '+(s.agent==='Unassigned'?'':'out')+'" style="font-size:10px;padding:4px 9px;" onclick="event.stopPropagation();assignSession('+s.id+')">'+btnLabel+'</button></td>';
                body.appendChild(tr);
            });
            var w=document.getElementById('waitWarn');
            w.classList.toggle('show',over5>0);
            if(over5>0) document.getElementById('warnTxt').textContent=over5+' customer(s) waiting over 5 minutes — assign an agent immediately';
            var longest=SESSIONS.length?Math.max.apply(null,SESSIONS.map(function(s){return s.waitSec;})):0;
            document.getElementById('qMeta').textContent=SESSIONS.length+' waiting · longest: '+fmt(longest);
            document.getElementById('qsInQueue').textContent=SESSIONS.length;
        }

        /* ── AGENT 3-COLUMN ── */
        function renderAgents(){
            var grid=document.getElementById('agentGrid');
            grid.innerHTML='';
            for(var slot=0;slot<3;slot++){
                var col=document.createElement('div');
                col.className='agent-col';
                var hd=document.createElement('div');
                hd.className='agent-col-hd';
                hd.innerHTML='<div class="slot-dot filled"></div>Chat Slot '+(slot+1);
                col.appendChild(hd);
                var body=document.createElement('div');
                body.className='agent-col-body';
                AGENTS.forEach(function(a){
                    var hasChat=slot<a.sessions;
                    var chatSess=null;
                    if(hasChat){
                        var busy=SESSIONS.filter(function(s){return s.agent===a.name&&s.status==='active';});
                        if(busy[slot]) chatSess=busy[slot];
                    }
                    var dotCls=a.status==='online'?'d-on':a.status==='busy'?'d-busy':a.status==='away'?'d-away':'d-off';
                    var statusCls='b-'+a.status;
                    if(a.status==='offline'||a.status==='away'){
                        var d=document.createElement('div');
                        d.className='agent-slot';
                        d.innerHTML='<div class="ag-av" style="background:#ccc;"><span>'+a.initials+'</span><div class="ag-dot '+dotCls+'"></div></div>'
                            +'<div class="ag-info"><div class="ag-name">'+a.name+'</div><div class="ag-chat">'+cap(a.status)+'</div></div>'
                            +'<span class="badge '+statusCls+'" style="font-size:9px;padding:1px 6px;">'+a.status+'</span>';
                        body.appendChild(d);
                    } else if(hasChat){
                        var isFull=a.sessions>=a.max&&slot===a.max-1;
                        var d=document.createElement('div');
                        d.className='agent-slot';
                        var chatTxt=chatSess?chatSess.name+' · '+fmt(chatSess.waitSec):'Slot '+(slot+1)+' occupied';
                        d.innerHTML='<div class="ag-av"><span>'+a.initials+'</span><div class="ag-dot '+dotCls+'"></div></div>'
                            +'<div class="ag-info"><div class="ag-name">'+a.name+'</div><div class="ag-chat">'+chatTxt+'</div></div>'
                            +'<span class="badge '+(isFull?'b-full':statusCls)+'" style="font-size:9px;padding:1px 6px;">'+(isFull?'Full':a.status)+'</span>';
                        body.appendChild(d);
                    } else {
                        var d=document.createElement('div');
                        d.className='empty-slot';
                        d.textContent='Available slot';
                        body.appendChild(d);
                    }
                });
                col.appendChild(body);
                grid.appendChild(col);
            }
        }

        /* ── ASSIGN ── */
        function assignSession(id){
            var s=SESSIONS.find(function(x){return x.id===id;});
            var avail=AGENTS.find(function(a){return (a.status==='online'||a.status==='busy')&&a.sessions<a.max;});
            if(!avail){showToast('No available agents. All agents are at capacity.');return;}
            s.agent=avail.name; s.status='active'; avail.sessions++;
            fetch('/Admin/QueueAssign',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({sessionId:id,agentName:avail.name})}).catch(function(){});
            renderQueue(); renderAgents();
            showToast(s.name+' assigned to '+avail.name);
        }

        function autoAssign(){
            var count=0;
            SESSIONS.filter(function(s){return s.status==='waiting';}).forEach(function(s){
                var avail=AGENTS.find(function(a){return (a.status==='online'||a.status==='busy')&&a.sessions<a.max;});
                if(avail){s.agent=avail.name;s.status='active';avail.sessions++;count++;}
            });
            fetch('/Admin/QueueAutoAssign',{method:'POST'}).catch(function(){});
            renderQueue(); renderAgents();
            showToast(count>0?count+' session(s) auto-assigned.':'No available agents right now.');
        }

        /* ── FAQ ── */
        function selCat(el,cat){
            document.querySelectorAll('.cat-chip').forEach(function(c){c.classList.remove('on');});
            el.classList.add('on'); selCategory=cat;
        }
        function setFaqFilter(el,cat){
            document.querySelectorAll('.ff').forEach(function(f){f.classList.remove('on');});
            el.classList.add('on'); faqFilter=cat; renderFaqs();
        }
        function filterFaqs(v){ faqSearch=v.toLowerCase(); renderFaqs(); }

        document.getElementById('faqA').addEventListener('input',function(){
            document.getElementById('charCount').textContent=this.value.length+' / 500 chars';
        });

        function addFaq(){
            var q=document.getElementById('faqQ').value.trim();
            var a=document.getElementById('faqA').value.trim();
            if(!q||!a){showToast('Please fill in both question and answer.');return;}
            if(a.length>500){showToast('Answer exceeds 500 characters.');return;}

            fetch('/Admin/FaqAdd',{
                method:'POST',headers:{'Content-Type':'application/json'},
                body:JSON.stringify({question:q,answer:a,category:selCategory})
            })
            .then(function(r){return r.json();})
            .catch(function(){return{success:true,id:nextId};})
            .then(function(data){
                FAQS.push({id:data.id||nextId++,q:q,a:a,cat:selCategory});
                document.getElementById('faqQ').value='';
                document.getElementById('faqA').value='';
                document.getElementById('charCount').textContent='0 / 500 chars';
                updateFaqCounts();
                renderFaqs();
                showToast('FAQ added successfully!');
            });
        }

        function deleteFaq(id){
            fetch('/Admin/FaqDelete',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:id})}).catch(function(){});
            FAQS=FAQS.filter(function(f){return f.id!==id;});
            updateFaqCounts();
            renderFaqs();
            showToast('FAQ deleted.');
        }

        function editFaq(id){
            var f=FAQS.find(function(x){return x.id===id;});
            if(!f)return;
            var item=document.getElementById('faq-'+id);
            item.classList.add('editing');
            item.innerHTML=
                '<input class="edit-inp" id="eq-'+id+'" type="text" value="'+escH(f.q)+'"/>'
                +'<textarea class="edit-inp" id="ea-'+id+'">'+escH(f.a)+'</textarea>'
                +'<div class="edit-foot">'
                    +'<button class="pbtn" style="font-size:10px;padding:5px 12px;" onclick="saveEdit('+id+')">Save</button>'
                    +'<button class="pbtn out" style="font-size:10px;padding:5px 12px;" onclick="renderFaqs()">Cancel</button>'
                +'</div>';
        }

        function saveEdit(id){
            var q=document.getElementById('eq-'+id).value.trim();
            var a=document.getElementById('ea-'+id).value.trim();
            if(!q||!a){showToast('Both fields are required.');return;}
            var f=FAQS.find(function(x){return x.id===id;});
            f.q=q; f.a=a;
            fetch('/Admin/FaqUpdate',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:id,question:q,answer:a,category:f.cat})}).catch(function(){});
            renderFaqs();
            showToast('FAQ updated successfully!');
        }

        function updateFaqCounts(){
            document.getElementById('statFaqCount').textContent=FAQS.length;
            document.getElementById('faqListCount').textContent=FAQS.length+' FAQs';
        }

        function renderFaqs(){
            var list=document.getElementById('faqList');
            list.innerHTML='';
            var filtered=FAQS.filter(function(f){
                return (faqFilter==='all'||f.cat===faqFilter)
                    && (!faqSearch||f.q.toLowerCase().includes(faqSearch)||f.a.toLowerCase().includes(faqSearch));
            });
            if(filtered.length===0){
                list.innerHTML='<div class="faq-empty">No FAQs found.</div>';
                return;
            }
            filtered.forEach(function(f){
                var d=document.createElement('div');
                d.className='faq-item';
                d.id='faq-'+f.id;
                d.innerHTML=
                    '<div class="faq-item-hd">'
                        +'<div class="faq-q">'+escH(f.q)+'</div>'
                        +'<div class="faq-actions">'
                            +'<button class="faq-act" onclick="editFaq('+f.id+')" title="Edit"><svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>'
                            +'<button class="faq-act del" onclick="deleteFaq('+f.id+')" title="Delete"><svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg></button>'
                        +'</div>'
                    +'</div>'
                    +'<div class="faq-a">'+escH(f.a)+'</div>'
                    +'<span class="faq-cat-badge fc-'+f.cat+'">'+cap(f.cat)+'</span>';
                list.appendChild(d);
            });
        }

        /* ── LIVE WAIT TIMER ── */
        qTimer=setInterval(function(){
            SESSIONS.forEach(function(s){ s.waitSec++; });
            renderQueue();
        },1000);

        renderQueue();
        renderAgents();
        renderFaqs();
    </script>
}
