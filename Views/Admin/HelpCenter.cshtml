            border: 1px solid #e8e8e8;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .ph {
            padding: 12px 18px;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }

        .ph-title {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            color: #1a1a1a;
        }

        .ph-sub {
            font-size: 11px;
            color: #aaa;
            font-weight: 400;
            margin-top: 1px;
        }

        .pbtn {
            background: #1a1a1a;
            color: #fff;
            border: none;
            padding: 6px 13px;
            font-size: 10.5px;
            font-weight: 600;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
            letter-spacing: 0.3px;
            transition: background .15s;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

            .pbtn:hover {
                background: #333;
            }

            .pbtn.out {
                background: #fff;
                color: #1a1a1a;
                border: 1px solid #e0e0e0;
            }

