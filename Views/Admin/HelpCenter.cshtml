        }

        .faq-meta {
            display: flex;
            align-items: center;
            gap: 6px;
            flex-wrap: wrap;
        }
        /* FIX 1: capitalize badges */
        .faq-cat-badge {
            display: inline-flex;
            align-items: center;
            padding: 2px 7px;
            font-size: 9.5px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: capitalize;
        }

        .ut-consumer {
            background: #e8f0fe;
            color: #0c447c;
        }

        .ut-seller {
            background: #EAF3DE;
            color: #27500A;
        }

        .edit-inp {
            width: 100%;
            background: #f8f8f8;
            border: 1px solid #e8e8e8;
            padding: 6px 10px;
