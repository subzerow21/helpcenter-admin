            min-width: 0;
        }
        /* FIX 1: capitalize */
        .ag-name {
            font-size: 11px;
            font-weight: 600;
            color: #1a1a1a;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            text-transform: capitalize;
        }

        .ag-chat {
            font-size: 10px;
            color: #aaa;
            margin-top: 1px;
            white-space: nowrap;
            overflow: hidden;
