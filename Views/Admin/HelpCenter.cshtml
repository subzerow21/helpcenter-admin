            color: #666;
            line-height: 1.55;
            font-weight: 400;
        }

        .nh-modal-body {
            padding: 12px 20px 16px;
        }

        .nh-modal-warn {
            background: #FAEEDA;
            border: 1px solid #f5d08a;
            padding: 8px 12px;
            font-size: 11.5px;
            color: #633806;
            font-weight: 500;
            margin-top: 10px;
            display: flex;
            align-items: center;
            gap: 7px;
        }

            .nh-modal-warn svg {
                width: 13px;
                height: 13px;
                fill: none;
                stroke: #854F0B;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
                flex-shrink: 0;
            }

        .nh-modal-foot {
            padding: 12px 20px;
            border-top: 1px solid #f0f0f0;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 8px;
        }

        .nh-modal-cancel {
            background: #fff;
            color: #1a1a1a;
            border: 1px solid #e0e0e0;
            padding: 7px 16px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            font-family: 'Poppins',sans-serif;
            transition: background .15s;
        }

            .nh-modal-cancel:hover {
                background: #f5f5f5;
            }

        .nh-modal-confirm {
            background: #e24b4a;
            color: #fff;
            border: none;
            padding: 7px 16px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            font-family: 'Poppins',sans-serif;
            transition: background .15s;
        }

            .nh-modal-confirm:hover {
                background: #c73938;
            }

        .nh-toast {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #1a1a1a;
            color: #fff;
            padding: 10px 18px;
            font-size: 12px;
            font-weight: 500;
            font-family: 'Poppins',sans-serif;
            z-index: 9999;
            opacity: 0;
            transition: opacity .3s;
            pointer-events: none;
        }

            .nh-toast.show {
                opacity: 1;
            }
    </style>
}

