@Html.AntiForgeryToken()
<div class="nh-toast" id="nhToast"></div>

@section Scripts {
    <script>
        var SESSIONS   = @Html.Raw(sessionsJson);
        var AGENTS     = @Html.Raw(agentsJson);
        var FAQS       = @Html.Raw(faqsJson);
        var CATEGORIES = @Html.Raw(categoriesJson);

        var selCat          = CATEGORIES.length ? CATEGORIES[0] : '';
        var faqFilterActive = 'all';
        var utFilterActive  = 'all';
        var faqSearch       = '';
        var nextId          = @(Model.Faqs.Count > 0 ? Model.Faqs.Max(f => f.Id) + 1 : 1);

        var __af     = document.querySelector('input[name="__RequestVerificationToken"]');
        var AF_TOKEN = __af ? __af.value : '';

        // ── helpers ──────────────────────────────────────────────────────────
        function postJson(url, data) {
            return fetch(url, {
                method:  'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': AF_TOKEN },
                body:    JSON.stringify(data)
            }).then(function(r) { return r.json(); });
        }
        function fmt(s)  { return String(Math.floor(s/60)).padStart(2,'0')+':'+String(s%60).padStart(2,'0'); }
        function titleCase(str) { return String(str||'').replace(/\b\w/g,function(c){ return c.toUpperCase(); }); }
        function escH(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
        function getUserType() { return document.querySelector('input[name="userType"]:checked').value; }
        function showToast(msg) {
            var t = document.getElementById('nhToast');
            t.textContent = msg; t.classList.add('show');
            setTimeout(function(){ t.classList.remove('show'); }, 2400);
        }

        // ════════════════════════════════════════════════════════════════════
        // PORTAL-BASED DROPDOWN
        // ────────────────────────────────────────────────────────────────────
        // A single shared <div id="dd-portal"> is positioned via JS using
        // getBoundingClientRect so it's never clipped by overflow:hidden parents.
        //
        // FIX 1 — dropdown closes instantly:
        //   The _ddJustOpened flag prevents the document click listener from
        //   firing in the SAME event cycle as the button click that opened it.
        //
        // FIX 2 — dropdown cut off at bottom:
        //   After rendering we measure available space and flip the dropdown
        //   upward if there isn't enough room below the button.
        // ════════════════════════════════════════════════════════════════════
        var _ddPortal     = null;
        var _ddSessionId  = null;
        var _ddJustOpened = false;   // FIX 1

        function initPortal() {
            _ddPortal = document.getElementById('dd-portal');
        }

        function closeDropdown() {
            if (_ddPortal) { _ddPortal.classList.remove('open'); _ddPortal.innerHTML = ''; }
            _ddSessionId = null;
        }

        // Outside-click handler — skips the tick that opened the dropdown
        document.addEventListener('click', function(e) {
            if (_ddJustOpened) { _ddJustOpened = false; return; }   // FIX 1
            if (_ddPortal && !_ddPortal.contains(e.target)) closeDropdown();
        });

        // Close on any scroll so the portal doesn't float away from its button
        document.addEventListener('scroll', function() { closeDropdown(); }, true);

        function openAssignDropdown(sessionId, btnEl) {
            // Toggle closed if same button clicked again
            if (_ddSessionId === sessionId && _ddPortal && _ddPortal.classList.contains('open')) {
                closeDropdown(); return;
            }

            _ddJustOpened = true;   // FIX 1 — block the immediately-following document click
            _ddSessionId  = sessionId;

            // FIX 2 — Position portal using viewport coords of the button
            var rect       = btnEl.getBoundingClientRect();
            var ddWidth    = 220;
            var spaceBelow = window.innerHeight - rect.bottom - 8;
            var spaceAbove = rect.top - 8;

            _ddPortal.style.width = ddWidth + 'px';
            var left = rect.right - ddWidth;
            if (left < 8) left = 8;
            _ddPortal.style.left = left + 'px';

            // Default: open downward
            _ddPortal.style.bottom = '';
            _ddPortal.style.top    = (rect.bottom + 4) + 'px';

            _ddPortal.innerHTML = '<div class="assign-dd-hd">Select Agent</div>'
                + '<div class="assign-agent-opt" style="justify-content:center;color:#aaa;font-size:11px;pointer-events:none;">Loading&hellip;</div>';
            _ddPortal.classList.add('open');

            fetch('/Admin/GetAvailableAgents')
                .then(function(r) { return r.json(); })
                .then(function(agents) {
                    if (_ddSessionId !== sessionId) return; // stale response
                    if (!agents || !agents.length) {
                        _ddPortal.innerHTML = '<div class="assign-dd-hd">Select Agent</div>'
                            + '<div class="assign-dd-empty">No agents available right now</div>';
                        return;
                    }
                    var html = '<div class="assign-dd-hd">Select Agent</div>';
                    agents.forEach(function(a) {
                        var dotCls   = a.status === 'available' ? 'on' : a.status === 'busy' ? 'busy' : 'away';
                        var initials = (a.name||'').split(' ').filter(Boolean).slice(0,2)
                                        .map(function(w){ return w[0].toUpperCase(); }).join('');
                        var safeName = escH(a.name).replace(/'/g,"&#39;");
                        html += '<div class="assign-agent-opt" onclick="confirmAssign('+sessionId+',\''+safeName+'\')">'
                              + '<div class="aao-av">'+initials+'<div class="aao-dot '+dotCls+'"></div></div>'
                              + '<div class="aao-info">'
                              +   '<div class="aao-name">'+escH(titleCase(a.name))+'</div>'
                              +   '<div class="aao-slots">'+a.activeSessions+' / '+a.maxSessions+' slots used</div>'
                              + '</div></div>';
                    });
                    _ddPortal.innerHTML = html;

                    // FIX 2b — flip upward if not enough space below after content renders
                    var portalH   = _ddPortal.offsetHeight;
                    var needsFlip = (rect.bottom + 4 + portalH > window.innerHeight - 8) && (spaceAbove >= portalH);
                    if (needsFlip) {
                        _ddPortal.style.top    = '';
                        _ddPortal.style.bottom = (window.innerHeight - rect.top + 4) + 'px';
                    } else {
                        _ddPortal.style.bottom = '';
                        _ddPortal.style.top    = (rect.bottom + 4) + 'px';
                    }
                })
                .catch(function() {
                    _ddPortal.innerHTML = '<div class="assign-dd-hd">Select Agent</div>'
                        + '<div class="assign-dd-empty">Could not load agents</div>';
                });
        }

        function confirmAssign(sessionId, agentName) {
            closeDropdown();
            var s = SESSIONS.find(function(x){ return x.id === sessionId; });
            if (!s) return;

            postJson('/Admin/QueueAssign', { sessionId: sessionId, agentName: agentName })
                .then(function(data) {
                    if (data.success) {
                        // Remove from local queue — now Active in DB
                        SESSIONS = SESSIONS.filter(function(x){ return x.id !== sessionId; });
                        // Optimistically bump agent slot count
                        var ag = AGENTS.find(function(a){ return a.name === agentName; });
                        if (ag) ag.sessions = Math.min(ag.sessions + 1, ag.max);
                        renderQueue();
                        renderAgents();
                        showToast(titleCase(s.name) + ' assigned to ' + titleCase(agentName) + '.');
                    } else {
                        showToast(data.message || 'Assignment failed.');
                    }
                })
                .catch(function() { showToast('Could not reach server.'); });
        }

        // ════════════════════════════════════════════════════════════════════
        // QUEUE
        // ════════════════════════════════════════════════════════════════════
        function renderQueue() {
            var body = document.getElementById('qBody');
            body.innerHTML = '';
            var over5 = 0;

            SESSIONS.forEach(function(s, i) {
                if (s.waitSec >= 300) over5++;
                var tr  = document.createElement('tr');
                var wc  = s.waitSec >= 300 ? 'q-wait over5' : 'q-wait';
                var pc  = i === 0 ? 'p1' : i === 1 ? 'p2' : i === 2 ? 'p3' : '';

                var hasAvail = AGENTS.some(function(a) {
                    return (a.status === 'online' || a.status === 'busy') && a.sessions < a.max;
                });

                var actionCell = hasAvail
                    ? '<button class="pbtn" style="font-size:10px;padding:4px 10px;" '
                    +   'onclick="event.stopPropagation();openAssignDropdown('+s.id+',this)">'
                    +   '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;margin-right:3px;vertical-align:-1px;">'
                    +     '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>'
                    +   '</svg>Assign &#9660;</button>'
                    : '<span style="font-size:11px;color:#aaa;">No agents</span>';

                tr.innerHTML =
                    '<td><div class="q-pos-badge '+pc+'">'+(i+1)+'</div></td>'
                    + '<td><div class="q-cust">'
                    +   '<div class="q-av" style="background:'+s.bg+'">'+s.av+'</div>'
                    +   '<div><div class="q-name">'+escH(titleCase(s.name))+'</div>'
                    +       '<div class="q-role">'+escH(titleCase(s.role))+'</div></div>'
                    + '</div></td>'
                    + '<td><div class="'+wc+'">'+fmt(s.waitSec)+'</div></td>'
                    + '<td><span style="font-size:11px;color:#666;font-weight:500;">'+escH(titleCase(s.cat))+'</span></td>'
                    + '<td><span class="badge b-waiting">Waiting</span></td>'
                    + '<td>'+actionCell+'</td>';
                body.appendChild(tr);
            });

            var w = document.getElementById('waitWarn');
            w.classList.toggle('show', over5 > 0);
            if (over5 > 0) document.getElementById('warnTxt').textContent = over5 + ' customer(s) waiting over 5 minutes';
            var longest = SESSIONS.length ? Math.max.apply(null, SESSIONS.map(function(s){ return s.waitSec; })) : 0;
            document.getElementById('qMeta').textContent     = SESSIONS.length + ' in queue · longest: ' + fmt(longest);
            document.getElementById('qsInQueue').textContent = SESSIONS.length;
        }

        // ════════════════════════════════════════════════════════════════════
        // AGENT STATUS — 3-column grid showing real slot data
        //
        // Each column = Chat Slot 1 / 2 / 3.
        // If a.slots contains an entry for that slot number → show client + ConvID.
        // If not → show "Available" (slot is free / was resolved).
        // Resolved slots have EndTime set in DB so they are excluded from
        // activeAgentRows in the controller — the JS just shows Available.
        // ════════════════════════════════════════════════════════════════════
        function renderAgents() {
            var grid = document.getElementById('agentGrid');
            grid.innerHTML = '';

            for (var slotNum = 1; slotNum <= 3; slotNum++) {
                var col     = document.createElement('div'); col.className = 'agent-col';
                var hd      = document.createElement('div'); hd.className  = 'agent-col-hd';

                // Dot is filled (dark) if at least one agent has this slot occupied
                var anyFilled = AGENTS.some(function(a) {
                    return (a.slots||[]).some(function(sl){ return sl.slotNum === slotNum; });
                });
                hd.innerHTML = '<div class="slot-dot'+(anyFilled?' filled':'')+'"></div>Chat Slot ' + slotNum;
                col.appendChild(hd);

                var colBody = document.createElement('div'); colBody.className = 'agent-col-body';

                AGENTS.forEach(function(a) {
                    var slots    = a.slots || [];
                    var slotData = slots.find(function(sl){ return sl.slotNum === slotNum; });

                    var dotCls    = a.status === 'online' ? 'd-on' : a.status === 'busy' ? 'd-busy' : a.status === 'away' ? 'd-away' : 'd-off';
                    var statusCls = 'b-' + a.status;
                    var avBg      = (a.status === 'offline') ? '#ccc' : '#1a1a1a';
                    var d         = document.createElement('div');

                    if (a.status === 'offline') {
                        // Offline agents: show only once (slot 1), greyed out
                        if (slotNum !== 1) return;
                        d.className = 'agent-slot';
                        d.innerHTML =
                            '<div class="ag-av" style="background:#ccc;">'
                            + '<span>'+a.initials+'</span>'
                            + '<div class="ag-dot d-off"></div></div>'
                            + '<div class="ag-info">'
                            +   '<div class="ag-name">'+escH(titleCase(a.name))+'</div>'
                            +   '<div class="ag-chat">Offline</div>'
                            + '</div>'
                            + '<span class="badge b-offline" style="font-size:9px;padding:1px 6px;">offline</span>';

                    } else if (slotData && slotData.convId && slotData.convId > 0) {
                        // ── OCCUPIED SLOT — show client + ConversationID ──
                        d.className = 'agent-slot';
                        d.innerHTML =
                            '<div class="ag-av" style="background:'+avBg+';">'
                            + '<span>'+a.initials+'</span>'
                            + '<div class="ag-dot '+dotCls+'"></div></div>'
                            + '<div class="ag-info">'
                            +   '<div class="ag-name">'+escH(titleCase(a.name))+'</div>'
                            +   '<div class="ag-chat">'
                            +     escH(slotData.client||'Customer')
                            +     ' &middot; <span class="ag-conv">Conv #'+slotData.convId+'</span>'
                            +   '</div>'
                            + '</div>'
                            + '<span class="badge b-occupied" style="font-size:9px;padding:1px 6px;">active</span>';

                    } else {
                        // ── AVAILABLE SLOT (free or previously resolved) ──
                        d.className = 'empty-slot';
                        d.innerHTML =
                            '<div class="ag-av" style="background:'+avBg+';width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9.5px;font-weight:700;color:#fff;flex-shrink:0;position:relative;">'
                            + '<span>'+a.initials+'</span>'
                            + '<div class="ag-dot '+dotCls+'" style="position:absolute;bottom:0;right:0;width:8px;height:8px;border-radius:50%;border:2px solid #fff;"></div>'
                            + '</div>'
                            + '<div style="flex:1;min-width:0;">'
                            +   '<div style="font-size:11px;font-weight:600;color:#1a1a1a;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">'+escH(titleCase(a.name))+'</div>'
                            +   '<div style="font-size:10px;color:#ccc;font-style:italic;margin-top:1px;">Available</div>'
                            + '</div>'
                            + '<span class="badge '+statusCls+'" style="font-size:9px;padding:1px 6px;">'+a.status+'</span>';
                    }
                    colBody.appendChild(d);
                });

                col.appendChild(colBody);
                grid.appendChild(col);
            }
        }

        // ════════════════════════════════════════════════════════════════════
        // FAQ CATEGORIES
        // ════════════════════════════════════════════════════════════════════
        function renderCatChips() {
            var wrap = document.getElementById('catChips');
            wrap.innerHTML = '';
            CATEGORIES.forEach(function(c) {
                var d = document.createElement('div');
                d.className = 'cat-chip'+(c === selCat ? ' on' : '');
                d.onclick   = function(){ selCat = c; renderCatChips(); };
                d.innerHTML = escH(titleCase(c))
                    + '<svg class="cat-del" viewBox="0 0 24 24" onclick="event.stopPropagation();deleteCategory(\''+escH(c).replace(/'/g,"&#39;")+'\')">'
                    + '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
                wrap.appendChild(d);
            });
            renderFaqFilterBar();
        }

        function addCategory() {
            var inp = document.getElementById('newCatInp');
            var v   = inp.value.trim();
            if (!v) { showToast('Enter a category name.'); return; }
            var vTitle = titleCase(v);
            if (CATEGORIES.find(function(c){ return c.toLowerCase() === vTitle.toLowerCase(); })) {
                showToast('Category already exists.'); return;
            }
            postJson('/Admin/FaqCategoryAdd', { name: vTitle })
                .then(function(data) {
                    if (data.success) {
                        CATEGORIES.push(vTitle); selCat = vTitle; inp.value = '';
                        renderCatChips();
                        showToast('"'+vTitle+'" category added!');
                    } else { showToast(data.message || 'Failed to add category.'); }
                })
                .catch(function() { showToast('Could not reach server.'); });
        }

        function deleteCategory(cat) {
            var count = FAQS.filter(function(f){ return f.cat === cat; }).length;
            var msg   = count > 0
                ? count + ' FAQ(s) under "'+titleCase(cat)+'" will also be set to Resolved.'
                : '"'+titleCase(cat)+'" will be removed (no FAQs attached).';
            showModal('Deactivate Category "'+titleCase(cat)+'"?', msg, function() {
                postJson('/Admin/FaqCategoryDelete', { name: cat })
                    .then(function(data) {
                        if (data.success) {
                            FAQS       = FAQS.filter(function(f){ return f.cat !== cat; });
                            CATEGORIES = CATEGORIES.filter(function(c){ return c !== cat; });
                            if (selCat === cat) selCat = CATEGORIES[0] || '';
                            updateFaqCounts(); renderCatChips(); renderFaqs();
                            showToast(data.message || 'Category deactivated.');
                        } else { showToast(data.message || 'Delete failed.'); }
                    })
                    .catch(function() { showToast('Could not reach server.'); });
            });
        }

        function renderFaqFilterBar() {
            var bar = document.getElementById('faqFilterBar');
            bar.innerHTML = '';
            var allBtn = document.createElement('button');
            allBtn.className   = 'ff'+(faqFilterActive === 'all' ? ' on' : '');
            allBtn.textContent = 'All';
            allBtn.onclick = function(){ faqFilterActive = 'all'; renderFaqFilterBar(); renderFaqs(); };
            bar.appendChild(allBtn);
            CATEGORIES.forEach(function(c) {
                var b = document.createElement('button');
                b.className   = 'ff'+(faqFilterActive === c ? ' on' : '');
                b.textContent = titleCase(c);
                b.onclick     = function(){ faqFilterActive = c; renderFaqFilterBar(); renderFaqs(); };
                bar.appendChild(b);
            });
        }

        function setUtFilter(el, val) {
            utFilterActive = val;
            document.querySelectorAll('#utFilterBar .ff').forEach(function(b){ b.classList.remove('on'); });
            el.classList.add('on');
            renderFaqs();
        }

        // ════════════════════════════════════════════════════════════════════
        // FAQ CRUD
        // ════════════════════════════════════════════════════════════════════
        function addFaq() {
            var qRaw = document.getElementById('faqQ').value.trim();
            var a    = document.getElementById('faqA').value.trim();
            var ut   = getUserType();
            var q    = titleCase(qRaw);
            if (!q || !a) { showToast('Please fill in both question and answer.'); return; }
            if (!selCat)  { showToast('Please select a category first.'); return; }
            postJson('/Admin/FaqAdd', { question: q, answer: a, category: selCat, userType: ut })
                .then(function(data) {
                    if (data.success) {
                        FAQS.push({ id: data.id || nextId++, q: q, a: a, cat: selCat, userType: ut });
                        document.getElementById('faqQ').value = '';
                        document.getElementById('faqA').value = '';
                        updateFaqCounts(); renderFaqs();
                        showToast('FAQ added!');
                    } else { showToast(data.message || 'Failed to add FAQ.'); }
                })
                .catch(function() { showToast('Could not reach server.'); });
        }

        function deleteFaq(id) {
            var f = FAQS.find(function(x){ return x.id === id; });
            if (!f) return;
            showModal('Deactivate FAQ?', '"'+escH(f.q)+'" will be set to Resolved.', function() {
                postJson('/Admin/FaqDelete', { id: id })
                    .then(function(data) {
                        if (data.success) {
                            FAQS = FAQS.filter(function(x){ return x.id !== id; });
                            updateFaqCounts(); renderFaqs();
                            showToast('FAQ set to Resolved.');
                        } else { showToast(data.message || 'Delete failed.'); }
                    })
                    .catch(function() { showToast('Could not reach server.'); });
            });
        }

        function editFaq(id) {
            var f = FAQS.find(function(x){ return x.id === id; });
            if (!f) return;
            var item = document.getElementById('faq-'+id);
            item.classList.add('editing');
            var catOpts = CATEGORIES.map(function(c) {
                return '<option value="'+escH(c)+'"'+(c===f.cat?' selected':'')+'>'+escH(titleCase(c))+'</option>';
            }).join('');
            item.innerHTML =
                '<div style="margin-bottom:6px;"><div class="field-lbl" style="margin-bottom:4px;">Category</div>'
                + '<select class="edit-inp" id="ec-'+id+'">'+catOpts+'</select></div>'
                + '<div style="margin-bottom:6px;"><div class="field-lbl" style="margin-bottom:4px;">Question</div>'
                + '<input class="edit-inp" id="eq-'+id+'" type="text" value="'+escH(f.q)+'" /></div>'
                + '<div style="margin-bottom:6px;"><div class="field-lbl" style="margin-bottom:4px;">Answer</div>'
                + '<textarea class="edit-inp" id="ea-'+id+'">'+escH(f.a)+'</textarea></div>'
                + '<div style="margin-bottom:6px;"><div class="field-lbl" style="margin-bottom:6px;">Visible to</div>'
                + '<div style="display:flex;gap:16px;">'
                +   '<label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;">'
                +     '<input type="radio" name="eut-'+id+'" value="Consumer"'+(f.userType==='Consumer'?' checked':'')+' style="accent-color:#1a1a1a;"/> Consumer</label>'
                +   '<label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;">'
                +     '<input type="radio" name="eut-'+id+'" value="Seller"'+(f.userType==='Seller'?' checked':'')+' style="accent-color:#1a1a1a;"/> Seller</label>'
                + '</div></div>'
                + '<div class="edit-foot">'
                +   '<button class="pbtn" style="font-size:10px;padding:5px 12px;" onclick="saveEdit('+id+')">Save</button>'
                +   '<button class="pbtn out" style="font-size:10px;padding:5px 12px;" onclick="renderFaqs()">Cancel</button>'
                + '</div>';
        }

        function saveEdit(id) {
            var qRaw = document.getElementById('eq-'+id).value.trim();
            var a    = document.getElementById('ea-'+id).value.trim();
            var c    = document.getElementById('ec-'+id).value;
            var ut   = document.querySelector('input[name="eut-'+id+'"]:checked').value;
            var q    = titleCase(qRaw);
            if (!q || !a) { showToast('Both fields are required.'); return; }
            postJson('/Admin/FaqUpdate', { id: id, question: q, answer: a, category: c, userType: ut })
                .then(function(data) {
                    if (data.success) {
                        var f = FAQS.find(function(x){ return x.id === id; });
                        if (f) { f.q = q; f.a = a; f.cat = c; f.userType = ut; }
                        renderFaqs();
                        showToast('FAQ updated!');
                    } else { showToast(data.message || 'Update failed.'); }
                })
                .catch(function() { showToast('Could not reach server.'); });
        }

        function filterFaqs(v) { faqSearch = v.toLowerCase(); renderFaqs(); }

        function updateFaqCounts() {
            document.getElementById('statFaqCount').textContent = FAQS.length;
            document.getElementById('faqListCount').textContent = FAQS.length + ' FAQs';
        }

        function renderFaqs() {
            var list = document.getElementById('faqList');
            list.innerHTML = '';
            var filtered = FAQS.filter(function(f) {
                return (faqFilterActive === 'all' || f.cat === faqFilterActive)
                    && (utFilterActive  === 'all' || f.userType === utFilterActive)
                    && (!faqSearch || f.q.toLowerCase().includes(faqSearch) || f.a.toLowerCase().includes(faqSearch));
            });
            if (!filtered.length) { list.innerHTML = '<div class="faq-empty">No FAQs found.</div>'; return; }
            filtered.forEach(function(f) {
                var d = document.createElement('div');
                d.className = 'faq-item'; d.id = 'faq-'+f.id;
                d.innerHTML =
                    '<div class="faq-item-hd">'
                    +   '<div class="faq-q">'+escH(titleCase(f.q))+'</div>'
                    +   '<div class="faq-actions">'
                    +     '<button class="faq-act" onclick="editFaq('+f.id+')" title="Edit">'
                    +       '<svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>'
                    +       '<path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>'
                    +     '<button class="faq-act del" onclick="deleteFaq('+f.id+')" title="Deactivate">'
                    +       '<svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/>'
                    +       '<path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>'
                    +       '<path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg></button>'
                    +   '</div>'
                    + '</div>'
                    + '<div class="faq-a">'+escH(f.a)+'</div>'
                    + '<div class="faq-meta">'
                    +   '<span class="faq-cat-badge" style="background:#f0f0f0;color:#555;">'+escH(titleCase(f.cat))+'</span>'
                    +   '<span class="faq-cat-badge '+(f.userType==='Seller'?'ut-seller':'ut-consumer')+'">'+escH(f.userType||'Consumer')+'</span>'
                    + '</div>';
                list.appendChild(d);
            });
        }

        // ── MODAL ──────────────────────────────────────────────────────────
        var _modalCallback = null;
        function showModal(title, msg, onConfirm) {
            document.getElementById('nhModalTitle').textContent = title;
            document.getElementById('nhModalMsg').textContent   = msg;
            _modalCallback = onConfirm;
            document.getElementById('nhModalBg').classList.add('show');
        }
        function closeModal() {
            document.getElementById('nhModalBg').classList.remove('show');
            _modalCallback = null;
        }

        // ── INIT ──────────────────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', function() {
            initPortal();
            document.getElementById('nhModalConfirm').onclick = function() {
                var cb = _modalCallback; closeModal(); if (cb) cb();
            };
            document.getElementById('nhModalBg').addEventListener('click', function(e) {
                if (e.target === this) closeModal();
            });
            var afEl = document.querySelector('input[name="__RequestVerificationToken"]');
            if (afEl) AF_TOKEN = afEl.value;
        });

        // Run initPortal immediately too in case DOMContentLoaded already fired
        initPortal();

        // ── TICK — increment wait timers every second ─────────────────────
        setInterval(function(){ SESSIONS.forEach(function(s){ s.waitSec++; }); renderQueue(); }, 1000);

        renderQueue();
        renderAgents();
        renderCatChips();
        renderFaqs();

       
        function refreshAgents() {
            fetch('/Admin/GetAgentStatus')
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    AGENTS = data;
                    renderAgents();
                })
                .catch(function() { /* silent — keep last known state */ });
        }

        setInterval(refreshAgents, 10000);  // change to 5000 for 5s refresh
    </script>
    </script>
}
