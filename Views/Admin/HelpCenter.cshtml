            display: flex;
            flex-direction: column;
            gap: 10px;
            max-height: 130px;
            overflow-y: auto;
            flex: 1;
            min-height: 0;
        }

            .form-body::-webkit-scrollbar {
                width: 3px;
            }

            .form-body::-webkit-scrollbar-thumb {
                background: #e8e8e8;
            }

        .form-visible-to {
            padding-bottom: 12px;
            border-top: 1px solid #f0f0f0;
            flex-shrink: 0;
        }

        .field-lbl {
            font-size: 9.5px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: #aaa;
            margin-bottom: 4px;
        }

        .cat-add-row {
            display: flex;
            align-items: center;
            gap: 7px;
            margin-bottom: 8px;
        }
        /* FIX 1: capitalize category input */
        .cat-text-inp {
            flex: 1;
            background: #f8f8f8;
            border: 1.5px solid #e8e8e8;
            padding: 7px 11px;
            font-size: 12px;
            font-family: 'Poppins', sans-serif;
            color: #1a1a1a;
            outline: none;
            transition: border-color .2s;
            text-transform: capitalize;
        }

            .cat-text-inp:focus {
                border-color: #1a1a1a;
            }

            .cat-text-inp::placeholder {
                color: #ccc;
                text-transform: none;
            }

        .cat-add-btn {
            background: #1a1a1a;
            color: #fff;
            border: none;
            padding: 7px 12px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
            white-space: nowrap;
            transition: background .15s;
        }

            .cat-add-btn:hover {
                background: #333;
            }

        .cat-chips {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
        }
        /* FIX 1: capitalize chips */
        .cat-chip {
            background: #f5f5f5;
            border: 1px solid #e8e8e8;
            color: #666;
            font-size: 11px;
            font-weight: 600;
            padding: 4px 10px;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
            transition: all .15s;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            text-transform: capitalize;
        }

            .cat-chip.on {
                background: #1a1a1a;
                color: #fff;
                border-color: #1a1a1a;
            }

        .cat-del {
            width: 11px;
            height: 11px;
            cursor: pointer;
            fill: none;
            stroke: currentColor;
            stroke-width: 2.5;
            stroke-linecap: round;
            display: none;
        }

        .cat-chip:hover .cat-del {
