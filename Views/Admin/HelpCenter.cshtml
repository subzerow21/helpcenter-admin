@model NextHorizon.Models.Admin_Models.HelpCenterV2ViewModel
@{
    ViewData["Title"] = "Help Center";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var sessionsJson = System.Text.Json.JsonSerializer.Serialize(Model.Sessions.Select(s => new
    {
        id = s.Id,
        no = s.SessionNo,
        name = s.CustomerName,
        email = s.CustomerEmail,
        role = s.Role,
        av = s.Initials,
        bg = s.AvatarColor,
        waitSec = s.WaitSeconds,
        pos = s.QueuePosition,
        status = s.Status,
        cat = s.Category,
        agent = s.AssignedTo ?? "Unassigned"
    }));

    var agentsJson = System.Text.Json.JsonSerializer.Serialize(Model.Agents.Select(a => new
    {
        name = a.Name,
        initials = a.Initials,
        status = a.Status,
        sessions = a.ActiveSessions,
        max = a.MaxSessions,
        slots = a.Slots.Select(sl => new
        {
            convId = sl.ConversationId,
            client = sl.ClientName,
            cat = sl.Category,
            slotNum = sl.SlotNumber
        })
    }));

    var faqsJson = System.Text.Json.JsonSerializer.Serialize(Model.Faqs.Select(f => new
    {
        id = f.Id,
        q = f.Question,
        a = f.Answer,
        cat = f.Category,
        userType = f.UserType
    }));

    var categoriesJson = System.Text.Json.JsonSerializer.Serialize(Model.Categories);
}

@section Styles {
    <style>
        * {
            box-sizing: border-box;
        }

        .admin-content {
            padding: 20px !important;
            overflow-y: auto !important;
            height: calc(100vh - 62px) !important;
        }

        /* ── STATS ── */
        .q-stats {
            display: grid;
            grid-template-columns: repeat(5,1fr);
            gap: 12px;
            margin-bottom: 14px;
        }

        .qs {
            background: #fff;
            border: 1px solid #e8e8e8;
            padding: 12px 16px;
        }

        .qs-lbl {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: #aaa;
            margin-bottom: 5px;
        }

        .qs-val {
            font-size: 20px;
            font-weight: 700;
            color: #1a1a1a;
            letter-spacing: -0.5px;
            line-height: 1;
        }

        .qs-sub {
            font-size: 10px;
            color: #aaa;
            margin-top: 4px;
        }

            .qs-sub.warn {
                color: #854F0B;
                display: flex;
                align-items: center;
                gap: 3px;
            }

        .up {
            color: #27500A;
            font-weight: 600;
        }

        .dn {
            color: #A32D2D;
            font-weight: 600;
        }

        /* ── LAYOUT ── */
        .hc-shell {
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 14px;
            min-height: 580px;
        }

        .hc-left {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .hc-right {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .panel {
            background: #fff;
            border: 1px solid #e8e8e8;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .ph {
            padding: 12px 18px;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }

        .ph-title {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            color: #1a1a1a;
        }

        .ph-sub {
            font-size: 11px;
            color: #aaa;
            font-weight: 400;
            margin-top: 1px;
        }

        .pbtn {
            background: #1a1a1a;
            color: #fff;
            border: none;
            padding: 6px 13px;
            font-size: 10.5px;
            font-weight: 600;
            cursor: pointer;
            font-family: 'Poppins',sans-serif;
            letter-spacing: 0.3px;
            transition: background .15s;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

            .pbtn:hover {
                background: #333;
            }

            .pbtn.out {
                background: #fff;
                color: #1a1a1a;
                border: 1px solid #e0e0e0;
            }

                .pbtn.out:hover {
                    background: #f5f5f5;
                }

            .pbtn svg {
                width: 12px;
                height: 12px;
                fill: none;
                stroke: currentColor;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
            }

        /* ── QUEUE ── */
        .q-scroll {
            overflow-y: auto;
            flex: 1;
        }

            .q-scroll::-webkit-scrollbar {
                width: 3px;
            }

            .q-scroll::-webkit-scrollbar-thumb {
                background: #e8e8e8;
            }

        .qtbl {
            width: 100%;
            border-collapse: collapse;
        }

            .qtbl th {
                font-size: 9.5px;
                font-weight: 700;
                letter-spacing: 1px;
                text-transform: uppercase;
                color: #aaa;
                padding: 9px 16px;
                text-align: left;
                border-bottom: 1px solid #f0f0f0;
                background: #fafafa;
                position: sticky;
                top: 0;
                z-index: 1;
            }

            .qtbl td {
                padding: 11px 16px;
                border-bottom: 1px solid #f5f5f5;
                vertical-align: middle;
            }

            .qtbl tbody tr:last-child td {
                border-bottom: none;
            }

        .q-cust {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .q-av {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        .q-name {
            font-size: 12px;
            font-weight: 600;
            color: #1a1a1a;
        }

        .q-role {
            font-size: 10.5px;
            color: #aaa;
            font-weight: 300;
        }

        .q-wait {
            font-size: 12px;
            font-weight: 600;
            color: #1a1a1a;
            font-variant-numeric: tabular-nums;
        }

            .q-wait.over5 {
                color: #791F1F;
            }

        .q-pos-badge {
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: #f0f0f0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            font-weight: 700;
            color: #888;
        }

            .q-pos-badge.p1 {
                background: #1a1a1a;
                color: #fff;
            }

            .q-pos-badge.p2 {
                background: #444;
                color: #fff;
            }

            .q-pos-badge.p3 {
                background: #888;
                color: #fff;
            }

        .badge {
            display: inline-flex;
            align-items: center;
            padding: 2px 8px;
            font-size: 9.5px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .b-waiting {
            background: #EAF3DE;
            color: #27500A;
        }

        .b-active {
            background: #e8f0fe;
            color: #0c447c;
        }

        .b-idle {
            background: #FAEEDA;
            color: #633806;
        }

        .b-done {
            background: #f0f0f0;
            color: #666;
        }

        .b-online {
            background: #EAF3DE;
            color: #27500A;
        }

        .b-busy {
            background: #e8f0fe;
            color: #0c447c;
        }

        .b-away {
            background: #FAEEDA;
            color: #633806;
        }

        .b-offline {
            background: #f0f0f0;
            color: #666;
        }

        .b-full {
            background: #FCEBEB;
            color: #791F1F;
        }

        .b-occupied {
            background: #e8f0fe;
            color: #0c447c;
        }

        .wait-warn {
            background: #FCEBEB;
            border-left: 3px solid #e24b4a;
            padding: 8px 14px;
            display: none;
            align-items: center;
            font-size: 11.5px;
            flex-shrink: 0;
        }

            .wait-warn.show {
                display: flex;
            }

        .ww-left {
            display: flex;
            align-items: center;
            gap: 6px;
            color: #791F1F;
            font-weight: 500;
        }

            .ww-left svg {
                width: 13px;
                height: 13px;
                stroke: #791F1F;
                fill: none;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
                flex-shrink: 0;
            }

        /* ── ASSIGN DROPDOWN PORTAL ── */
        /*
             * The portal is a single <div id="dd-portal"> placed at the very end of
             * the page, outside all scroll containers. JS positions it using
             * getBoundingClientRect() so it never gets clipped by overflow:hidden.
             */
        #dd-portal {
            position: fixed;
            z-index: 9000;
            display: none;
            background: #fff;
            border: 1px solid #e0e0e0;
            box-shadow: 0 4px 20px rgba(0,0,0,.14);
            min-width: 220px;
            max-height: 320px;
            overflow-y: auto;
        }

            #dd-portal.open {
                display: block;
            }

            #dd-portal::-webkit-scrollbar {
                width: 3px;
            }

            #dd-portal::-webkit-scrollbar-thumb {
                background: #e8e8e8;
            }

        .assign-dd-hd {
            padding: 8px 12px 6px;
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: #aaa;
            border-bottom: 1px solid #f0f0f0;
        }

        .assign-agent-opt {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 9px 12px;
            cursor: pointer;
            transition: background .12s;
            border-bottom: 1px solid #f8f8f8;
        }

            .assign-agent-opt:last-child {
                border-bottom: none;
            }

            .assign-agent-opt:hover {
                background: #f5f5f5;
            }

        .aao-av {
            width: 26px;
            height: 26px;
            background: #1a1a1a;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 9px;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
            position: relative;
        }

        .aao-dot {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            border: 1.5px solid #fff;
        }

            .aao-dot.on {
                background: #4ade80;
            }

            .aao-dot.busy {
                background: #378ADD;
            }

            .aao-dot.away {
                background: #f59e0b;
            }

        .aao-info {
            flex: 1;
            min-width: 0;
        }

        .aao-name {
            font-size: 12px;
            font-weight: 600;
            color: #1a1a1a;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .aao-slots {
            font-size: 10px;
            color: #aaa;
            margin-top: 1px;
        }

        .assign-dd-empty {
            padding: 14px;
            font-size: 11px;
            color: #bbb;
            text-align: center;
        }

        /* ── AGENT 3-COL ── */
        .agent-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 0;
            flex: 1;
            overflow: hidden;
        }

        .agent-col {
            border-right: 1px solid #f0f0f0;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

            .agent-col:last-child {
                border-right: none;
            }

        .agent-col-hd {
            padding: 8px 12px;
            background: #fafafa;
            border-bottom: 1px solid #f0f0f0;
            font-size: 9.5px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: #aaa;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .slot-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #e8e8e8;
        }

            .slot-dot.filled {
                background: #1a1a1a;
            }

        .agent-col-body {
            flex: 1;
            overflow-y: auto;
        }

        .agent-slot {
            padding: 9px 12px;
            border-bottom: 1px solid #f5f5f5;
            display: flex;
            align-items: center;
            gap: 7px;
        }

            .agent-slot:last-child {
                border-bottom: none;
            }

        .ag-av {
            width: 28px;
            height: 28px;
            background: #1a1a1a;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 9.5px;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
            position: relative;
        }

        .ag-dot {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            border: 2px solid #fff;
        }

        .d-on {
            background: #4ade80;
        }

        .d-busy {
            background: #378ADD;
        }

        .d-away {
            background: #f59e0b;
        }

        .d-off {
            background: #ccc;
        }

        .ag-info {
            flex: 1;
            min-width: 0;
        }

        .ag-name {
            font-size: 11px;
            font-weight: 600;
            color: #1a1a1a;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .ag-chat {
            font-size: 10px;
            color: #aaa;
            margin-top: 1px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .ag-conv {
            font-size: 10px;
            color: #1a1a1a;
            font-weight: 700;
        }

        .empty-slot {
            padding: 9px 12px;
            font-size: 11px;
            color: #ccc;
            font-style: italic;
            border-bottom: 1px solid #f5f5f5;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .empty-slot:last-child {
                border-bottom: none;
            }

        .empty-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #e0e0e0;
            flex-shrink: 0;
        }

        /* ── FAQ FORM ── */
        .faq-form {
            background: #fff;
            border: 1px solid #e8e8e8;
            flex-shrink: 0;
        }

        .form-body {
            padding: 12px 16px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .field-lbl {
            font-size: 9.5px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: #aaa;
            margin-bottom: 4px;
        }

        .cat-add-row {
            display: flex;
            align-items: center;
            gap: 7px;
            margin-bottom: 8px;
        }

        .cat-text-inp {
            flex: 1;
            background: #f8f8f8;
            border: 1.5px solid #e8e8e8;
            padding: 7px 11px;
            font-size: 12px;
            font-family: 'Poppins',sans-serif;
            color: #1a1a1a;
            outline: none;
            transition: border-color .2s;
        }

            .cat-text-inp:focus {
                border-color: #1a1a1a;
            }

            .cat-text-inp::placeholder {
                color: #ccc;
            }

        .cat-add-btn {
            background: #1a1a1a;
            color: #fff;
            border: none;
            padding: 7px 12px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            font-family: 'Poppins',sans-serif;
            white-space: nowrap;
            transition: background .15s;
        }

            .cat-add-btn:hover {
                background: #333;
            }

        .cat-chips {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
        }

        .cat-chip {
            background: #f5f5f5;
            border: 1px solid #e8e8e8;
            color: #666;
            font-size: 11px;
            font-weight: 600;
            padding: 4px 10px;
            cursor: pointer;
            font-family: 'Poppins',sans-serif;
            transition: all .15s;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

            .cat-chip.on {
                background: #1a1a1a;
                color: #fff;
                border-color: #1a1a1a;
            }

        .cat-del {
            width: 11px;
            height: 11px;
            cursor: pointer;
            fill: none;
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            display: none;
        }

        .cat-chip:hover .cat-del {
            display: inline;
        }

        .cat-chip.on .cat-del {
            display: inline;
        }

        .faq-inp {
            width: 100%;
            background: #f8f8f8;
            border: 1.5px solid #e8e8e8;
            padding: 8px 12px;
            font-size: 12.5px;
            font-family: 'Poppins',sans-serif;
            color: #1a1a1a;
            outline: none;
            transition: border-color .2s;
        }

            .faq-inp:focus {
                border-color: #1a1a1a;
            }

            .faq-inp::placeholder {
                color: #ccc;
            }

        textarea.faq-inp {
            resize: none;
            height: 70px;
            line-height: 1.5;
        }

        .radio-row {
            display: flex;
            align-items: center;
            gap: 18px;
        }

        .radio-opt {
            display: flex;
            align-items: center;
            gap: 7px;
            cursor: pointer;
        }

            .radio-opt input[type=radio] {
                width: 14px;
                height: 14px;
                accent-color: #1a1a1a;
                cursor: pointer;
            }

            .radio-opt span {
                font-size: 12.5px;
                font-weight: 500;
                color: #1a1a1a;
            }

        .form-foot {
            padding: 9px 16px;
            border-top: 1px solid #f0f0f0;
            display: flex;
            align-items: center;
            justify-content: flex-end;
        }

        /* ── FAQ LIST ── */
        .faq-list-panel {
            background: #fff;
            border: 1px solid #e8e8e8;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            height: 500px;
        }

        .faq-search {
            padding: 9px 16px;
            border-bottom: 1px solid #f5f5f5;
            display: flex;
            align-items: center;
            gap: 8px;
            background: #fafafa;
            flex-shrink: 0;
        }

            .faq-search svg {
                width: 12px;
                height: 12px;
                stroke: #bbb;
                fill: none;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
                flex-shrink: 0;
            }

            .faq-search input {
                background: none;
                border: none;
                outline: none;
                font-size: 12px;
                font-family: 'Poppins',sans-serif;
                color: #1a1a1a;
                flex: 1;
            }

                .faq-search input::placeholder {
                    color: #ccc;
                }

        .faq-filter {
            display: flex;
            gap: 5px;
            padding: 8px 16px;
            border-bottom: 1px solid #f5f5f5;
            flex-shrink: 0;
            flex-wrap: wrap;
        }

        .ff {
            background: #f5f5f5;
            border: 1px solid #e8e8e8;
            color: #666;
            font-size: 10.5px;
            font-weight: 600;
            padding: 4px 10px;
            cursor: pointer;
            font-family: 'Poppins',sans-serif;
            transition: all .15s;
        }

            .ff.on {
                background: #1a1a1a;
                color: #fff;
                border-color: #1a1a1a;
            }

        .faq-scroll {
            overflow-y: auto;
            flex: 1;
        }

            .faq-scroll::-webkit-scrollbar {
                width: 3px;
            }

            .faq-scroll::-webkit-scrollbar-thumb {
                background: #e8e8e8;
            }

        .faq-item {
            border-bottom: 1px solid #f5f5f5;
            padding: 12px 16px;
        }

            .faq-item:last-child {
                border-bottom: none;
            }

            .faq-item.editing {
                background: #fafffe;
                border-left: 2px solid #1a1a1a;
            }

        .faq-item-hd {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 8px;
            margin-bottom: 4px;
        }

        .faq-q {
            font-size: 12.5px;
            font-weight: 600;
            color: #1a1a1a;
            flex: 1;
            line-height: 1.4;
        }

        .faq-actions {
            display: flex;
            gap: 3px;
            flex-shrink: 0;
        }

        .faq-act {
            background: none;
            border: none;
            cursor: pointer;
            padding: 4px;
            display: flex;
            align-items: center;
            border-radius: 3px;
            transition: background .15s;
        }

            .faq-act:hover {
                background: #f5f5f5;
            }

            .faq-act svg {
                width: 13px;
                height: 13px;
                fill: none;
                stroke: #888;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
            }

            .faq-act.del svg {
                stroke: #e24b4a;
            }

        .faq-a {
            font-size: 12px;
            color: #555;
            line-height: 1.5;
            font-weight: 300;
            margin-bottom: 6px;
        }

        .faq-meta {
            display: flex;
            align-items: center;
            gap: 6px;
            flex-wrap: wrap;
        }

        .faq-cat-badge {
            display: inline-flex;
            align-items: center;
            padding: 2px 7px;
            font-size: 9.5px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .ut-consumer {
            background: #e8f0fe;
            color: #0c447c;
        }

        .ut-seller {
            background: #EAF3DE;
            color: #27500A;
        }

        .edit-inp {
            width: 100%;
            background: #f8f8f8;
            border: 1px solid #e8e8e8;
            padding: 6px 10px;
            font-size: 12px;
            font-family: 'Poppins',sans-serif;
            color: #1a1a1a;
            outline: none;
            margin-bottom: 6px;
        }

            .edit-inp:focus {
                border-color: #1a1a1a;
            }

        textarea.edit-inp {
            resize: none;
            height: 52px;
            line-height: 1.5;
        }

        .edit-foot {
            display: flex;
            gap: 6px;
            margin-top: 6px;
        }

        .faq-empty {
            padding: 24px;
            text-align: center;
            color: #ccc;
            font-size: 12px;
        }

        /* ── MODAL ── */
        .nh-modal-bg {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.45);
            z-index: 10000;
            display: none;
            align-items: center;
            justify-content: center;
        }

            .nh-modal-bg.show {
                display: flex;
            }

        .nh-modal {
            background: #fff;
            border: 1px solid #e0e0e0;
            padding: 0;
            width: 380px;
            max-width: 95vw;
        }

        .nh-modal-hd {
            padding: 16px 20px 0;
            display: flex;
            align-items: flex-start;
            gap: 12px;
        }

        .nh-modal-icon {
            width: 36px;
            height: 36px;
            background: #FCEBEB;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .nh-modal-icon svg {
                width: 16px;
                height: 16px;
                fill: none;
                stroke: #791F1F;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
