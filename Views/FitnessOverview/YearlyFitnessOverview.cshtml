@{
    ViewData["Title"] = "Yearly Fitness Overview";
}



<div class="centered-layout-container">
    <div class="fitness-content-wrapper">
        <div class="fitness-container">
            <div class="back-navigation">
                <a asp-controller="AccountProfile" asp-action="ProfileView"><i class="bi bi-chevron-left"></i> Back</a>
            </div>

            <div class="fitness-header">
                <h1>FITNESS OVERVIEW <span>(This Year)</span></h1>
            </div>

            <div class="period-navbar">
                <a asp-controller="FitnessOverview" asp-action="DailyFitnessOverview" class="period-btn">DAILY</a>
                <a asp-controller="FitnessOverview" asp-action="WeeklyFitnessOverview" class="period-btn">Weekly</a>
                <a asp-controller="FitnessOverview" asp-action="MonthlyFitnessOverview" class="period-btn">MONTHLY</a>
                <a asp-controller="FitnessOverview" asp-action="YearlyFitnessOverview" class="period-btn active">YEARLY</a>
            </div>

            <div class="fitness-charts-grid">
                <div class="chart-card">
                    <div class="chart-header">
                        <small>Daily Average Distance</small>
                        <h3>500 KM</h3>
                    </div>
                    <div class="chart-body">
                        <div class="chart-y-axis">
                            <span>6.5</span><span>4.5</span><span>2.5</span><span>0</span>
                        </div>
                        <div class="chart-placeholder">
                            <div class="mock-grid"></div>
                            <div class="bar-container yearly-bars">
                                <div class="bar" style="height: 50%; left: 4%;"></div>
                                <div class="bar" style="height: 65%; left: 12%;"></div>
                                <div class="bar" style="height: 75%; left: 20%;"></div>
                                <div class="bar" style="height: 60%; left: 28%;"></div>
                                <div class="bar" style="height: 45%; left: 36%;"></div>
                            </div>
                        </div>
                        <div class="chart-labels">
                            <span>J</span><span>F</span><span>M</span><span>A</span><span>M</span><span>J</span><span>J</span><span>A</span><span>S</span><span>O</span><span>N</span><span>D</span>
                        </div>
                    </div>
                </div>

                <div class="chart-card">
                    <div class="chart-header">
                        <small>Daily Average Time</small>
                        <h3>35:00:00</h3>
                    </div>
                    <div class="chart-body">
                        <div class="chart-y-axis">
                            <span>12</span><span>8</span><span>4</span><span>0</span>
                        </div>
                        <div class="chart-placeholder">
                            <div class="mock-grid"></div>
                            <div class="bar-container yearly-bars">
                                <div class="bar" style="height: 40%; left: 4%;"></div>
                                <div class="bar" style="height: 55%; left: 12%;"></div>
                                <div class="bar" style="height: 70%; left: 20%;"></div>
                            </div>
                        </div>
                        <div class="chart-labels">
                            <span>J</span><span>F</span><span>M</span><span>A</span><span>M</span><span>J</span><span>J</span><span>A</span><span>S</span><span>O</span><span>N</span><span>D</span>
                        </div>
                    </div>
                </div>

                <div class="chart-card">
                    <div class="chart-header">
                        <small>Daily Average Steps</small>
                        <h3>10,000</h3>
                    </div>
                    <div class="chart-body">
                        <div class="chart-y-axis">
                            <span>6000</span><span>4000</span><span>2000</span><span>0</span>
                        </div>
                        <div class="chart-placeholder">
                            <div class="mock-grid"></div>
                            <div class="bar-container yearly-bars">
                                <div class="bar" style="height: 60%; left: 4%;"></div>
                                <div class="bar" style="height: 80%; left: 12%;"></div>
                                <div class="bar" style="height: 75%; left: 20%;"></div>
                            </div>
                        </div>
                        <div class="chart-labels">
                            <span>J</span><span>F</span><span>M</span><span>A</span><span>M</span><span>J</span><span>J</span><span>A</span><span>S</span><span>O</span><span>N</span><span>D</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Updated for full-width expansion consistent with Weekly view */
    .centered-layout-container {
        display: block;
        width: 100%;
        min-height: 100vh;
        background-color: #fff;
    }

    .fitness-content-wrapper {
        width: 100%;
        max-width: 100%; /* Removes the 1300px constraint */
        margin: 0;
        padding: 20px 60px 40px 60px; /* Aligned with Weekly/Daily */
    }

    .back-navigation a {
        text-decoration: none;
        color: #000;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .fitness-header h1 {
        font-size: 1.8rem;
        font-weight: 800;
        margin: 15px 0;
    }

        .fitness-header h1 span {
            font-weight: 400;
            font-size: 1.2rem;
            color: #444;
        }

    .period-navbar {
        display: flex;
        background-color: #000;
        border-radius: 4px;
        overflow: hidden;
        margin-bottom: 30px;
        width: 100%;
    }

    .period-btn {
        flex: 1;
        background: transparent;
        color: #fff;
        border: none;
        padding: 12px;
        font-weight: 700;
        text-transform: uppercase;
        text-align: center;
        text-decoration: none;
        cursor: pointer;
        border-right: 1px solid #444;
    }

        .period-btn.active {
            background-color: #777;
        }

    .fitness-charts-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        width: 100%;
    }

    .chart-card {
        background-color: #f0f0f0;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }

    .chart-header {
        background-color: #000;
        color: #fff;
        padding: 12px 15px;
    }

        .chart-header h3 {
            margin: 0;
            font-size: 1.2rem;
            font-weight: 700;
        }

    .chart-body {
        padding: 15px;
        position: relative;
    }

    .chart-y-axis {
        position: absolute;
        right: 8px;
        top: 15px;
        height: 180px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        font-size: 0.65rem;
        color: #666;
    }

    .chart-placeholder {
        height: 180px;
        width: calc(100% - 45px);
        position: relative;
        border: 1px solid #000;
        background: #e8e8e8;
    }

    .mock-grid {
        height: 100%;
        width: 100%;
        background-image: linear-gradient(#ccc 1px, transparent 1px), linear-gradient(90deg, #ccc 1px, transparent 1px);
        background-size: 25% 25%;
    }

    .bar-container {
        position: absolute;
        bottom: 0;
        width: 100%;
        height: 100%;
    }

    .bar {
        position: absolute;
        bottom: 0;
        background-color: #000;
    }

    .yearly-bars .bar {
        width: 12px; /* Fixed width for yearly visibility */
    }

    .chart-labels {
        display: flex;
        justify-content: space-between;
        padding-right: 45px;
        margin-top: 5px;
        font-size: 0.65rem;
        color: #666;
    }

    @@media (max-width: 1200px) {
        .fitness-charts-grid {
            grid-template-columns: 1fr;
        }

        .fitness-content-wrapper {
            padding: 20px 20px;
        }
    }
</style>