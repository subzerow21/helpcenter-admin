<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="NEXT HORIZON - Premium Running Gear. Engineered for Performance. Built for Runners.">
    <meta name="theme-color" content="#000000">
    <title>@ViewData["Title"] - NEXT HORIZON</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/header.css" asp-append-version="true">


    <!-- {Page Loader Style} -->
    <link rel="stylesheet" href="~/css/pageLoader.css" asp-append-version="true">

    @await RenderSectionAsync("Styles", required: false)

    <style>
        /* 1. LOCK THE VIEWPORT */
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
            overflow: hidden;
        }

        /* The body acts as the main flex container */
        .fixed-layout-body {
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        /* 2. HEADER */
        #main-header {
            flex-shrink: 0;
            z-index: 1100;
            background: #fff;
            border-bottom: 1px solid #e0e0e0;
        }

        /* 3. APP CONTAINER (Sidebar + Main) */
        .app-container {
            display: flex;
            flex: 1; /* Fills remaining height */
            overflow: hidden; /* Contains children */
            position: relative;
        }

        /* 4. SIDEBAR (Desktop) */
        .profile-sidebar {
            width: 280px;
            height: 100%;
            overflow-y: auto;
            background: #ffffff;
            border-right: 1px solid #d1d1d1;
            flex-shrink: 0;
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* 5. MAIN CONTENT */
        .main-content {
            flex: 1;
            overflow-y: auto;
            padding: 40px;
            background-color: #f8f9fa;
            -webkit-overflow-scrolling: touch;
        }

        /* 6. MENU BUTTON (Left of Logo) */
        .sidebar-trigger-btn {
            display: none; /* Hidden on Desktop */
            background: none;
            border: none;
            cursor: pointer;
            padding: 8px;
            color: #1a1a1a;
            margin-right: 10px;
            align-items: center;
            justify-content: center;
        }

        /* 7. MOBILE RESPONSIVENESS */
        @@media (max-width: 991px) {
            .sidebar-trigger-btn {
                display: flex; /* Show on Mobile */
            }

            .profile-sidebar {
                position: fixed;
                top: 0;
                left: 0;
                bottom: 0;
                z-index: 9999;
                transform: translateX(-100%);
                box-shadow: 10px 0 30px rgba(0,0,0,0.1);
            }

                .profile-sidebar.open {
                    transform: translateX(0);
                }

            .main-content {
                padding: 20px;
            }
            /* Ensure header items align properly on small screens */
            .header-top {
                display: flex;
                align-items: center;
            }
        }

    </style>
</head>

<body class="fixed-layout-body">

    <!-- Page Loader -->
    <div id="loading-overlay">
        <div class="loader-content">
            <div class="nh-loader-bars">
                <span></span>
                <span></span>
                <span></span>
                <span></span>
                <span></span>
            </div>
            <div class="loader-text">Next Horizon</div>
        </div>
    </div>


    <partial name="_ProfileHeader" />

    <div class="app-container">
        <partial name="_ProfileSideBar" />

        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <div id="sidebar-backdrop"
         style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:9998;"
         onclick="closeMobileSidebar()">
    </div>

    <script src="~/js/app.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)


    <!-- Page Loader -->
    <script src="~/js/pageLoader.js" asp-append-version="true"></script>

  
</body>
</html>