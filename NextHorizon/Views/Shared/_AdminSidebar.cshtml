<div class="py-4 d-flex flex-column h-100">
    <div class="px-4 mb-4">
        <a href="@Url.Action("Dashboard", "Admin")" class="d-block text-decoration-none">
            <img src="~/images/new-logo.png" alt="Next Horizon" class="img-fluid" style="max-height: 40px;"
                 onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
            <span class="fw-bold text-dark fs-5" style="display: none;">NEXT HORIZON</span>
        </a>
    </div>

    <ul class="nav flex-column px-2 flex-grow-1">
        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")"
               href="@Url.Action("Dashboard", "Admin")"> <i class="bi bi-grid-1x2-fill me-3"></i>DASHBOARD</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Analytics" ? "active" : "")"
               href="@Url.Action("Analytics", "Admin")"> <i class="bi bi-graph-up-arrow me-3"></i>ANALYTICS</a>
        </li>

        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Users" ? "active" : "")"
               href="@Url.Action("Users", "Admin")"> <i class="bi bi-people-fill me-3"></i>USERS</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Sellers" ? "active" : "")"
               href="@Url.Action("Sellers", "Admin")"> <i class="bi bi-shop me-3"></i> SELLERS</a>
        </li>

        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Logistics" ? "active" : "")"
               href="@Url.Action("Logistics", "Admin")"> <i class="bi bi-truck me-3"></i>LOGISTICS</a>
        </li>
       
        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Tasks" ? "active" : "")"
               href="@Url.Action("Tasks", "Admin")"> <i class="bi bi-trophy-fill me-3"></i>TASKS AND CHALLENGES</a>
        </li>

        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Moderation" ? "active" : "")"
               href="@Url.Action("Moderation", "Admin")"> <i class="bi bi-shield-check me-3"></i>MODERATION</a>
        </li>

        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Settings" ? "active" : "")"
               href="@Url.Action("Settings", "Admin")"> <i class="bi bi-gear-fill me-3"></i>SETTINGS</a>
        </li>
    </ul>

    <div class="px-2 mt-auto border-top pt-3">
        <a class="nav-link logout-link" href="@Url.Action("Logout", "Account")">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                <polyline points="16 17 21 12 16 7"></polyline>
                <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
            LOGOUT
        </a>
    </div>
</div>

