@{
    ViewData["Title"] = "Admin Portal - Settings";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">
    <div class="mb-4">
        <h3 class="fw-bold mb-0 text-poppins">System Settings</h3>
        <p class="text-muted small">Configure global platform rules, branding, and administrative controls.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="sticky-nav-wrapper">
                <div class="card border-0 shadow-sm rounded-4 p-2">
                    <div class="nav flex-column nav-pills gap-2" id="v-pills-tab" role="tablist" aria-orientation="vertical">
                        <button class="nav-link rounded-pill text-start px-3 active" id="tab-account-btn" data-bs-toggle="pill" data-bs-target="#tab-account" type="button" role="tab">
                            <i class="bi bi-person-lock me-2"></i> Account Security
                        </button>
                        <button class="nav-link rounded-pill text-start px-3" id="tab-security-btn" data-bs-toggle="pill" data-bs-target="#tab-security" type="button" role="tab">
                            <i class="bi bi-people me-2"></i> Permissions
                        </button>
                        <button class="nav-link rounded-pill text-start px-3" id="tab-audit-btn" data-bs-toggle="pill" data-bs-target="#tab-audit" type="button" role="tab">
                            <i class="bi bi-journal-text me-2"></i> Audit Logs
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="tab-content" id="v-pills-tabContent">

                <div class="tab-pane fade show active" id="tab-account" role="tabpanel">
                    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                        <h5 class="fw-bold mb-1">Profile Information</h5>
                        <p class="text-muted small mb-4">Update your display name and contact email.</p>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="small fw-bold mb-1">Full Name</label>
                                <input type="text" id="adminFullName" class="form-control rounded-3" value="System Admin">
                            </div>
                            <div class="col-md-6">
                                <label class="small fw-bold mb-1">Email Address</label>
                                <input type="email" id="adminEmail" class="form-control rounded-3" value="admin@nexthorizon.com">
                            </div>
                        </div>
                        <div class="d-flex justify-content-end mt-3">
                            <button class="btn btn-dark rounded-pill px-4" onclick="saveProfileInfo()">Save Profile</button>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h5 class="fw-bold mb-1 text-danger">Security Credentials</h5>
                        <p class="text-muted small mb-4">Update your password to keep your account secure.</p>
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="small fw-bold mb-1">Current Password</label>
                                <input type="password" id="currentPass" class="form-control rounded-3" placeholder="Required to make changes">
                            </div>
                            <div class="col-md-6">
                                <label class="small fw-bold mb-1">New Password</label>
                                <input type="password" id="newPass" class="form-control rounded-3" placeholder="••••••••">
                            </div>
                            <div class="col-md-6">
                                <label class="small fw-bold mb-1">Confirm New Password</label>
                                <input type="password" id="confirmNewPass" class="form-control rounded-3" placeholder="••••••••">
                            </div>
                        </div>
                        <div class="d-flex justify-content-end mt-4">
                            <button class="btn btn-outline-dark rounded-pill px-4" onclick="requestPasswordChange()">Update Password</button>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="tab-security" role="tabpanel">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="d-none d-sm-block">
                                <h5 class="fw-bold mb-0">Administrative Access</h5>
                                <p class="text-muted small mb-0">Manage roles and portal access for staff.</p>
                            </div>

                            <div class="d-flex gap-2 align-items-center flex-nowrap search-container-mobile ms-auto">
                                <div class="input-group input-group-sm search-input-group">
                                    <span class="input-group-text bg-light border-end-0 rounded-start-pill"><i class="bi bi-search text-muted"></i></span>
                                    <input type="text" id="adminSearchInput" class="form-control bg-light border-start-0 rounded-end-pill" placeholder="Search...">
                                </div>
                                <button class="btn btn-sm btn-dark rounded-pill px-3 btn-add-user" onclick="openInviteModal()">
                                    <i class="bi bi-person-plus"></i> <span class="d-none d-md-inline">Add User</span>
                                </button>
                            </div>
                        </div>

                        <ul class="nav nav-tabs border-0 mb-3 gap-2" id="permissionSubTabs" role="tablist">
                            <li class="nav-item">
                                <button class="nav-link active btn btn-sm rounded-pill px-3 border" data-bs-toggle="tab" data-bs-target="#activeAdmins">Active Admins</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link btn btn-sm rounded-pill px-3 border" data-bs-toggle="tab" data-bs-target="#revokedAdmins">Revoked Access</button>
                            </li>
                        </ul>

                        <div class="tab-content">
                            <div class="tab-pane fade show active" id="activeAdmins">
                                <div class="table-responsive rounded-3 border scrollable-card-body">
                                    <table class="table align-middle mb-0">
                                        <thead class="bg-light sticky-top">
                                            <tr class="x-small text-muted text-uppercase">
                                                <th class="ps-3">User</th>
                                                <th>Role</th>
                                                <th>Contact</th>
                                                <th>Date Added</th>
                                                <th class="text-end pe-3">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody class="small" id="adminTableBody">
                                            <tr class="admin-row" id="modRow1">
                                                <td class="ps-3">
                                                    <div class="fw-bold name-cell">Sarah Chen</div>
                                                    <div class="x-small text-muted email-cell">sarah.c@nexthorizon.com</div>
                                                </td>
                                                <td><span class="badge bg-light text-dark border rounded-pill fw-normal">Moderator</span></td>
                                                <td class="x-small text-muted">+1 234 567 890</td>
                                                <td class="x-small text-muted">Oct 24, 2025</td>
                                                <td class="text-end pe-3">
                                                    <button class="btn btn-sm btn-outline-dark border-0"
                                                            onclick="editModerator('Sarah Chen', 'sarah.c@nexthorizon.com', 'Moderator', '+1 234 567 890')">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger border-0"
                                                            onclick="requestRemoveAccess('Sarah Chen', 'modRow1')">
                                                        <i class="bi bi-slash-circle"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="tab-pane fade" id="revokedAdmins">
                                <div class="table-responsive rounded-3 border scrollable-card-body">
                                    <table class="table align-middle mb-0">
                                        <thead class="bg-light sticky-top">
                                            <tr class="x-small text-muted text-uppercase">
                                                <th class="ps-3">User</th>
                                                <th>Revoked Date</th>
                                                <th class="text-end pe-3">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody class="small">
                                            <tr>
                                                <td class="ps-3">
                                                    <div class="fw-bold text-muted">John Doe</div>
                                                    <div class="x-small">j.doe@nexthorizon.com</div>
                                                </td>
                                                <td class="text-muted">Oct 12, 2025</td>
                                                <td class="text-end pe-3">
                                                    <button class="btn btn-sm btn-dark rounded-pill px-3" onclick="reinstateAccess('John Doe')">
                                                        <i class="bi bi-arrow-counterclockwise me-1"></i> Reinstate
                                                    </button>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="tab-audit" role="tabpanel">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h5 class="fw-bold mb-1">System Audit Logs</h5>
                        <p class="text-muted small mb-4">Read-only trail of administrative actions.</p>

                        <div class="table-responsive rounded-3 border scrollable-card-body" style="max-height: 450px; overflow-y: auto;">
                            <table class="table table-hover align-middle small mb-0">
                                <thead class="bg-light sticky-top" style="z-index: 10;">
                                    <tr class="text-muted text-uppercase x-small">
                                        <th>Timestamp</th>
                                        <th>Admin</th>
                                        <th>Action</th>
                                        <th>Target</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody id="auditLogBody">
                                    <tr>
                                        <td>2026-03-07 14:20</td>
                                        <td><strong>SuperAdmin</strong></td>
                                        <td>Initial Setup</td>
                                        <td>System</td>
                                        <td><span class="badge bg-success-subtle text-success rounded-pill">Success</span></td>
                                    </tr>
                                    @for (int i = 0; i < 15; i++)
                                    {
                                        <tr>
                                            <td>2026-03-07 12:00</td>
                                            <td><strong>Admin</strong></td>
                                            <td>Login</td>
                                            <td>Dashboard</td>
                                            <td><span class="badge bg-success-subtle text-success rounded-pill">Success</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="inviteModModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="modModalLabel">User Details</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="small fw-bold mb-1">Full Name</label>
                        <input type="text" id="modName" class="form-control rounded-3" placeholder="Sarah Chen">
                    </div>
                    <div class="col-md-6">
                        <label class="small fw-bold mb-1">Email Address</label>
                        <input type="email" id="modEmail" class="form-control rounded-3" placeholder="sarah@example.com">
                    </div>
                    <div class="col-md-6">
                        <label class="small fw-bold mb-1">Phone Number</label>
                        <input type="tel" id="modPhone" class="form-control rounded-3" placeholder="+1 234...">
                    </div>
                    <div class="mb-3">
                        <label class="small fw-bold mb-1">Assign Role</label>
                        <div class="dropdown">
                            <button class="btn dropdown-toggle-custom shadow-none" type="button" id="roleDropdown" data-bs-toggle="dropdown">
                                <span id="selectedRoleText">Select Role</span>
                                <i class="bi bi-chevron-down small text-muted"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-custom shadow-lg">
                                <li><a class="dropdown-item dropdown-item-custom" onclick="updateRoleUI('Admin', 'admin')">Admin</a></li>
                                <li><a class="dropdown-item dropdown-item-custom" onclick="updateRoleUI('Moderator', 'mod')">Moderator</a></li>
                                <li><a class="dropdown-item dropdown-item-custom" onclick="updateRoleUI('Support Agent', 'support')">Support Agent</a></li>
                            </ul>
                            <input type="hidden" id="accessLevelInput" value="">
                        </div>
                    </div>

                    <div id="supportAssignmentSection" class="mb-3 d-none">
                        <label class="small fw-bold mb-1">Support Assignment <span class="text-danger">*</span></label>
                        <div class="dropdown">
                            <button class="btn dropdown-toggle-custom shadow-none w-100" type="button" id="supportDropdown" data-bs-toggle="dropdown">
                                <span id="selectedSupportText">-- Select Assignment --</span>
                                <i class="bi bi-chevron-down small text-muted"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-custom shadow-lg w-100">
                                <li><a class="dropdown-item dropdown-item-custom" onclick="updateSupportUI('Consumer Support', 'Consumer')">Consumer Support</a></li>
                                <li><a class="dropdown-item dropdown-item-custom" onclick="updateSupportUI('Seller Support', 'Seller')">Seller Support</a></li>
                                <li><a class="dropdown-item dropdown-item-custom" onclick="updateSupportUI('General (Both)', 'Both')">General (Both)</a></li>
                            </ul>
                            <input type="hidden" id="supportType" value="">
                        </div>
                        <div class="x-small text-muted mt-2">Mandatory for Support Agent roles.</div>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="button" id="overrideToggleBtn" class="btn btn-sm btn-outline-dark rounded-pill w-100 mb-2" onclick="toggleCredentialOverride()">
                        <i class="bi bi-shield-lock me-1"></i> Update User's Login Credentials
                    </button>

                    <div id="credentialOverrideSection" class="d-none bg-light p-3 rounded-3 border border-warning-subtle">
                        <p class="x-small text-muted mb-3"><i class="bi bi-exclamation-triangle-fill text-warning me-1"></i> Warning: Overriding credentials will change the user's login access immediately.</p>
                        <div class="mb-2">
                            <label class="x-small fw-bold mb-1">New Username</label>
                            <input type="text" id="overrideUsername" class="form-control form-control-sm rounded-2">
                        </div>
                        <div>
                            <label class="x-small fw-bold mb-1">New Password</label>
                            <input type="password" id="overridePassword" class="form-control form-control-sm rounded-2" placeholder="••••••••">
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0 mt-2">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-dark rounded-pill px-4" onclick="processModerator()">Apply Changes</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmActionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4 text-center">
            <div class="modal-body p-4">
                <i id="confirmIcon" class="bi bi-exclamation-circle text-warning display-4 mb-3"></i>
                <h5 class="fw-bold" id="confirmTitle">Are you sure?</h5>
                <p class="text-muted small mb-0" id="confirmBody">This action will be logged in the system.</p>
            </div>
            <div class="modal-footer border-0 justify-content-center pt-0 pb-4">
                <button type="button" class="btn btn-light rounded-pill px-3" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmBtnExecute" class="btn btn-dark rounded-pill px-4">Confirm</button>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="settingsToast" class="toast align-items-center text-white bg-dark border-0 rounded-4 shadow" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                <i class="bi bi-check-circle-fill me-2 text-success"></i>
                <span id="toastMsg">Action completed successfully.</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto shadow-none" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/admin_css/settings.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/admin_js/settings.js" asp-append-version="true"></script>
}