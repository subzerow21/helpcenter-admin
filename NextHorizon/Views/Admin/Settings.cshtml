@{
    ViewData["Title"] = "Admin Portal - Settings";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">
    <div class="mb-4">
        <h3 class="fw-bold mb-0 text-poppins">System Settings</h3>
        <p class="text-muted small">Configure global platform rules, branding, and administrative controls.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-2">
                <div class="nav flex-column nav-pills gap-2" id="v-pills-tab" role="tablist" aria-orientation="vertical">
                    <button class="nav-link active rounded-pill text-start px-3" data-bs-toggle="pill" data-bs-target="#tab-general" type="button">
                        <i class="bi bi-palette me-2"></i> General & Branding
                    </button>
                    <button class="nav-link rounded-pill text-start px-3" data-bs-toggle="pill" data-bs-target="#tab-account" type="button">
                        <i class="bi bi-person-lock me-2"></i> Account Security
                    </button>
                    <button class="nav-link rounded-pill text-start px-3" data-bs-toggle="pill" data-bs-target="#tab-moderation" type="button">
                        <i class="bi bi-shield-check me-2"></i> Moderation Rules
                    </button>
                    <button class="nav-link rounded-pill text-start px-3" data-bs-toggle="pill" data-bs-target="#tab-security" type="button">
                        <i class="bi bi-people me-2"></i> Permissions
                    </button>
                    <button class="nav-link rounded-pill text-start px-3" data-bs-toggle="pill" data-bs-target="#tab-audit" type="button">
                        <i class="bi bi-journal-text me-2"></i> Audit Logs
                    </button>
                    <button class="nav-link rounded-pill text-start px-3" data-bs-toggle="pill" data-bs-target="#tab-danger" type="button">
                        <i class="bi bi-exclamation-triangle me-2"></i> Danger Zone
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="tab-content" id="v-pills-tabContent">

                <div class="tab-pane fade show active" id="tab-general">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h5 class="fw-bold mb-4">Platform Branding</h5>
                        <div class="d-flex align-items-center gap-4 mb-4 p-3 border rounded-4 bg-light">
                            <div id="logoPreviewContainer" class="bg-white rounded-3 border d-flex align-items-center justify-content-center" style="width: 100px; height: 100px; overflow: hidden;">
                                <img id="logoPreview" src="/images/default-logo.png" alt="Logo" style="max-width: 100%; height: auto;">
                            </div>
                            <div class="flex-grow-1">
                                <label class="fw-bold small d-block mb-2">Platform Logo</label>
                                <input type="file" id="logoUpload" class="form-control form-control-sm mb-2 w-auto" accept="image/*" onchange="previewImage(this)">
                                <p class="text-muted x-small mb-0">Recommended: Square PNG or SVG (Max 2MB).</p>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="small fw-bold mb-1">Platform Name</label>
                                <input type="text" id="platformName" class="form-control rounded-3" value="Next Horizon">
                            </div>
                            <div class="col-md-6">
                                <label class="small fw-bold mb-1">Measurement Unit</label>
                                <select class="form-select rounded-3">
                                    <option value="km">Metric (Kilometers)</option>
                                    <option value="mi">Imperial (Miles)</option>
                                </select>
                            </div>
                        </div>
                        <hr class="my-4">
                        <div class="d-flex justify-content-end">
                            <button class="btn btn-dark rounded-pill px-4" onclick="saveGeneralSettings()">Save Changes</button>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="tab-account">
                    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                        <h5 class="fw-bold mb-1">Profile Information</h5>
                        <p class="text-muted small mb-4">Update your display name and contact email.</p>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="small fw-bold mb-1">Full Name</label>
                                <input type="text" id="adminFullName" class="form-control rounded-3" value="System Admin">
                            </div>
                            <div class="col-md-6">
                                <label class="small fw-bold mb-1">Email Address</label>
                                <input type="email" id="adminEmail" class="form-control rounded-3" value="admin@nexthorizon.com">
                            </div>
                        </div>
                        <div class="d-flex justify-content-end mt-3">
                            <button class="btn btn-dark rounded-pill px-4" onclick="saveProfileInfo()">Save Profile</button>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h5 class="fw-bold mb-1 text-danger">Security Credentials</h5>
                        <p class="text-muted small mb-4">Update your password to keep your account secure.</p>
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="small fw-bold mb-1">Current Password</label>
                                <input type="password" id="currentPass" class="form-control rounded-3" placeholder="Required to make changes">
                            </div>
                            <div class="col-md-6">
                                <label class="small fw-bold mb-1">New Password</label>
                                <input type="password" id="newPass" class="form-control rounded-3" placeholder="••••••••">
                            </div>
                            <div class="col-md-6">
                                <label class="small fw-bold mb-1">Confirm New Password</label>
                                <input type="password" id="confirmNewPass" class="form-control rounded-3" placeholder="••••••••">
                            </div>
                        </div>
                        <div class="d-flex justify-content-end mt-4">
                            <button class="btn btn-outline-dark rounded-pill px-4" onclick="requestPasswordChange()">Update Password</button>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="tab-moderation">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h5 class="fw-bold mb-1">Auto-Flagging Thresholds</h5>
                        <p class="text-muted small mb-4">Activities exceeding these limits go to queue.</p>
                        <div class="mb-3">
                            <label class="small fw-bold mb-1">Running Speed Limit (km/h)</label>
                            <div class="input-group" style="max-width: 200px;">
                                <input type="number" id="speedLimitInput" class="form-control rounded-start-3" value="25">
                                <span class="input-group-text rounded-end-3 bg-white border-start-0 text-muted">km/h</span>
                            </div>
                        </div>
                        <div class="form-check form-switch mt-4">
                            <input class="form-check-input shadow-none" type="checkbox" id="autoDQ" checked onchange="toggleAutoFlag()">
                            <label class="form-check-label fw-bold small" for="autoDQ">Enable AI Fraud Detection</label>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="tab-security">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="fw-bold mb-0">Administrative Access</h5>
                            <button class="btn btn-sm btn-dark rounded-pill px-3" onclick="openInviteModal()">
                                <i class="bi bi-person-plus me-1"></i> Add Moderator
                            </button>
                        </div>
                        <div class="table-responsive rounded-3 border">
                            <table class="table align-middle mb-0">
                                <thead class="bg-light">
                                    <tr class="x-small text-muted text-uppercase">
                                        <th class="ps-3">User</th>
                                        <th>Role</th>
                                        <th>Status</th>
                                        <th class="text-end pe-3">Action</th>
                                    </tr>
                                </thead>
                                <tbody class="small">
                                    <tr id="modRow1">
                                        <td class="ps-3">
                                            <div class="fw-bold">Sarah Chen</div>
                                            <div class="x-small text-muted">sarah.c@nexthorizon.com</div>
                                        </td>
                                        <td><span class="badge bg-light text-dark border rounded-pill fw-normal">Moderator</span></td>
                                        <td><span class="text-muted">● Offline</span></td>
                                        <td class="text-end pe-3">
                                            <button class="btn btn-sm btn-outline-dark border-0" onclick="editModerator('Sarah Chen', 'sarah.c@nexthorizon.com', 'Moderator')">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-dark border-0" onclick="requestRemoveAccess('Sarah Chen', 'modRow1')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="tab-audit">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h5 class="fw-bold mb-1">System Audit Logs</h5>
                        <p class="text-muted small mb-4">Read-only trail of administrative actions.</p>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle small">
                                <thead class="bg-light">
                                    <tr class="text-muted text-uppercase x-small">
                                        <th>Timestamp</th>
                                        <th>Admin</th>
                                        <th>Action</th>
                                        <th>Target</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody id="auditLogBody">
                                    <tr>
                                        <td>2026-03-07 14:20</td>
                                        <td><strong>SuperAdmin</strong></td>
                                        <td>Initial Setup</td>
                                        <td>System</td>
                                        <td><span class="badge bg-success-subtle text-success rounded-pill">Success</span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="tab-danger">
                    <div class="card border border-danger border-opacity-25 shadow-sm rounded-4 p-4">
                        <h5 class="fw-bold mb-1 text-danger">Danger Zone</h5>
                        <p class="text-muted small mb-4">Sensitive operations that impact security and integrity.</p>

                        <div class="p-3 bg-light rounded-4 mb-3 border">
                            <h6 class="fw-bold mb-1">Session Management</h6>
                            <p class="text-muted x-small mb-3">Force logouts in case of a suspected security breach.</p>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-dark rounded-pill" onclick="requestExpireAdminSessions()">Expire Admin Sessions</button>
                                <button class="btn btn-sm btn-dark rounded-pill" onclick="requestSignOutAllUsers()">Sign Out All Users</button>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center p-3 bg-light rounded-4 mb-3 border">
                            <div>
                                <h6 class="mb-0 fw-bold">Maintenance Mode</h6>
                                <small class="text-muted">Disable user access temporarily.</small>
                            </div>
                            <div class="form-switch">
                                <input class="form-check-input shadow-none" type="checkbox" id="maintenanceToggle" onchange="handleMaintenanceToggle()">
                            </div>
                        </div>
                        <button class="btn btn-outline-danger rounded-pill px-4" onclick="requestPurgeData()">Purge Flagged Data</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="inviteModModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="modModalLabel">Add New Moderator</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="small fw-bold mb-1">Name</label>
                    <input type="text" id="modName" class="form-control rounded-3" placeholder="Full Name">
                </div>

                <div class="mb-3">
                    <label class="small fw-bold mb-1">Email Address</label>
                    <input type="email" id="modEmail" class="form-control rounded-3" placeholder="email@example.com">
                </div>
                <div class="mb-3">
                    <label class="small fw-bold mb-1">Assign Role</label>
                    <select id="modRole" class="form-select rounded-3">
                        <option value="Moderator">Moderator</option>
                        <option value="Admin">Admin</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="small fw-bold mb-1">Password</label>
                    <input type="password" id="modPassword" class="form-control rounded-3" placeholder="Password">
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-dark rounded-pill px-4" onclick="processModerator()">Apply Changes</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmActionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4 text-center">
            <div class="modal-body p-4">
                <i class="bi bi-exclamation-circle text-warning display-4 mb-3"></i>
                <h5 class="fw-bold" id="confirmTitle">Are you sure?</h5>
                <p class="text-muted small mb-0" id="confirmBody">This action will be logged in the system.</p>
            </div>
            <div class="modal-footer border-0 justify-content-center pt-0 pb-4">
                <button type="button" class="btn btn-light rounded-pill px-3" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmBtnExecute" class="btn btn-dark rounded-pill px-4">Confirm</button>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="settingsToast" class="toast align-items-center text-white bg-dark border-0 rounded-4 shadow" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                <i class="bi bi-check-circle-fill me-2 text-success"></i>
                <span id="toastMsg">Action completed successfully.</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto shadow-none" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/admin_css/settings.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/admin_js/settings.js" asp-append-version="true"></script>
}