@{
    ViewData["Title"] = "Admin Portal - Sellers Overview";
    Layout = "_AdminLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin_css/sellers.css" asp-append-version="true" />
}

<div class="container-fluid py-4 bg-light">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-4 gap-3">
        <div>
            <div class="d-flex border-bottom overflow-auto text-nowrap custom-tabs">
                <button id="tab-active" onclick="switchSellerTab('active')"
                        class="btn btn-sm fw-bold bg-dark text-white rounded-0 px-3 py-2 active-tab me-1">
                    Active Sellers
                </button>
                <button id="tab-performance" onclick="switchSellerTab('performance')"
                        class="btn btn-sm text-muted rounded-0 px-3 py-2 me-1">
                    Performance Metrics
                </button>
                <button id="tab-archived" onclick="switchSellerTab('archived')"
                        class="btn btn-sm text-muted rounded-0 px-3 py-2">
                    Archived
                </button>
            </div>
        </div>

        <div class="d-flex align-items-center gap-2">
            <div class="search-container shadow-sm">
                <input type="text" id="sellerSearchInput" class="form-control rounded-pill border-0 px-3 py-2" placeholder="Search Shop or Seller">
                <i class="bi bi-search"></i>
            </div>
        </div>
    </div>

    <div id="view-active" class="consumer-grid-wrapper bg-white shadow-sm overflow-hidden rounded-4">
        <div class="table-responsive">
            <table class="table mb-0 align-middle text-center" style="min-width: 1000px;">
                <thead>
                    <tr>
                        <th class="border-start">Shop Name</th>
                        <th class="border-start">Owner</th>
                        <th class="border-start">Contact</th>
                        <th class="border-start">Date Joined</th>
                        <th class="border-start">Total Products</th>
                        <th class="border-start">Total Sales</th>
                        <th class="border-start">Status</th>
                        <th class="border-start">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 1; i <= 5; i++)
                    {
                        <tr>
                            <td class="border-start fw-bold">ShopExpress_@(i)</td>
                            <td class="border-start text-secondary">SellerName@(i)</td>
                            <td class="border-start text-secondary">seller@(i)@@market.com</td>
                            <td class="border-start text-secondary">Date @(i)</td>
                            <td class="border-start">@(i * 12) Items</td>
                            <td class="border-start fw-bold text-dark">₱@(i * 1500).00</td>
                            <td class="border-start"><span class="badge bg-success opacity-75">Verified</span></td>
                            <td class="border-start">
                                <div class="action-icons">
                                    <i class="bi bi-eye me-2 text-info" onclick="openViewModal('ShopExpress_@(i)', 'SellerName@(i)', '₱@(i * 1500)', '@(i * 12)')"></i>
                                    <i class="bi bi-pencil me-2 text-primary" onclick="openEditModal('ShopExpress_@(i)', 'seller@(i)@@market.com')"></i>
                                    <i class="bi bi-archive text-danger" onclick="openConfirmModal('delete', 'ShopExpress_@(i)')"></i>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div id="view-performance" class="d-none">
        <div class="row g-3">
            @for (int i = 1; i <= 3; i++)
            {
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm rounded-4 p-3">
                        <div class="d-flex justify-content-between">
                            <h6 class="fw-bold">Top Seller @i</h6>
                            <span class="text-success small">+12% <i class="bi bi-graph-up"></i></span>
                        </div>
                        <hr>
                        <div class="text-center py-2">
                            <p class="text-muted mb-1 small">Monthly Revenue</p>
                            <h3 class="fw-bold">₱45,200</h3>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="consumer-grid-wrapper bg-white shadow-sm mt-4 rounded-4 overflow-hidden">
            <div class="p-3 fw-bold border-bottom">Rankings by Rating</div>
            <div class="table-responsive">
                <table class="table mb-0 align-middle text-center">
                    <thead>
                        <tr>
                            <th>Rank</th>
                            <th>Shop</th>
                            <th>Rating</th>
                            <th>Fulfilled Orders</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>1</td><td>Premium Hub</td><td>⭐ 4.9</td><td>1,200</td></tr>
                        <tr><td>2</td><td>Tech Gadgets</td><td>⭐ 4.8</td><td>950</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="view-archived" class="consumer-grid-wrapper bg-white shadow-sm d-none overflow-hidden rounded-4">
        <div class="table-responsive">
            <table class="table mb-0 align-middle text-center" style="min-width: 900px;">
                <thead class="bg-light">
                    <tr>
                        <th class="border-start">Shop Name</th>
                        <th class="border-start">Owner</th>
                        <th class="border-start">Reason</th>
                        <th class="border-start">Archived Date</th>
                        <th class="border-start">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="border-start">OldShop_01</td>
                        <td class="border-start">John Doe</td>
                        <td class="border-start text-muted italic small">Inactive > 90 days</td>
                        <td class="border-start text-danger">Mar 01, 2026</td>
                        <td class="border-start">
                            <button class="btn btn-sm btn-outline-dark rounded-pill py-0 px-3" onclick="openConfirmModal('restore', 'OldShop_01')">Restore</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>


<div class="modal fade" id="viewSellerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="fw-bold mb-0">Shop Profile</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4 pb-4">
                <div class="text-center mb-4">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 80px; height: 80px;">
                        <i class="bi bi-shop fs-1 text-dark"></i>
                    </div>
                    <h5 class="fw-bold" id="viewShopName">Shop Name</h5>
                    <span class="badge bg-success opacity-75">Verified Seller</span>
                </div>
                <div class="row g-3">
                    <div class="col-6"><label class="small text-muted">Owner</label><p class="fw-bold" id="viewOwner">-</p></div>
                    <div class="col-6"><label class="small text-muted">Total Sales</label><p class="fw-bold" id="viewSales">-</p></div>
                    <div class="col-6"><label class="small text-muted">Products</label><p class="fw-bold" id="viewProducts">-</p></div>
                    <div class="col-6"><label class="small text-muted">Joined Date</label><p class="fw-bold">Jan 12, 2026</p></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editSellerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="fw-bold">Edit Seller Info</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4">
                <form id="editSellerForm">
                    <div class="mb-3">
                        <label class="small fw-bold text-secondary">Shop Name</label>
                        <input type="text" class="form-control rounded-3" id="editShopName">
                    </div>

                    <div class="mb-3">
                        <label class="small fw-bold text-secondary">Owner Name</label>
                        <input type="email" class="form-control rounded-3" id="editOwnerName">
                    </div>

                    <div class="mb-3">
                        <label class="small fw-bold text-secondary">Owner Email</label>
                        <input type="email" class="form-control rounded-3" id="editEmail">
                    </div>
                    <div class="mb-3">
                        <label class="small fw-bold text-secondary">Status</label>
                        <select class="form-select rounded-3">
                            <option>Verified</option>
                            <option>Pending</option>
                            <option>Suspended</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pb-4 px-4">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-dark rounded-pill px-4" onclick="confirmAction('update')">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmSellerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4 text-center">
            <div class="modal-body p-4">
                <div id="sellerConfirmIcon" class="mb-3"></div>
                <h5 class="fw-bold" id="sellerConfirmTitle">Confirm Action</h5>
                <p class="small text-secondary" id="sellerConfirmMessage"></p>
                <div class="d-flex gap-2 justify-content-center mt-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">No</button>
                    <button type="button" id="sellerConfirmBtn" class="btn rounded-pill px-4 text-white">Proceed</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1060;">
    <div id="sellerToast" class="toast border-0 shadow rounded-4" role="alert">
        <div class="d-flex align-items-center bg-dark text-white rounded-4 p-2">
            <div class="toast-body d-flex align-items-center gap-2">
                <i id="sellerToastIcon" class="bi bi-check-circle-fill text-success fs-5"></i>
                <span id="sellerToastMessage">Done!</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin_js/sellers.js" asp-append-version="true"></script>
}