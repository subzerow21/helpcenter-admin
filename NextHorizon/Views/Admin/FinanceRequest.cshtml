@model NextHorizon.Models.Admin_Models.FinanceRequestsViewModel

@{
    ViewData["Title"] = "Admin Portal - Requests & Finance";
    Layout = "_AdminLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin_css/financeRequest.css" asp-append-version="true" />
}

<div class="container-fluid py-4 bg-light">
    <div class="mb-4">
        <h3 class="fw-bold mb-0 text-poppins">Requests & Finance</h3>
        <p class="text-muted small">Manage seller payout disbursements, product approvals, and global marketplace promotions.</p>
    </div>

    @* --- Tabs Navigation --- *@
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-2">
            <ul class="nav nav-pills nav-fill" id="financeTabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active rounded-pill fw-bold" id="payouts-tab" data-bs-toggle="tab" data-bs-target="#payouts" type="button">
                        <i class="bi bi-cash-stack me-2"></i>Payouts (@Model.PendingPayouts.Count)
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link rounded-pill fw-bold" id="products-tab" data-bs-toggle="tab" data-bs-target="#products" type="button">
                        <i class="bi bi-box-seam me-2"></i>Products (@Model.TotalPendingProductsCount)
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link rounded-pill fw-bold" id="discounts-tab" data-bs-toggle="tab" data-bs-target="#discounts" type="button">
                        <i class="bi bi-percent me-2"></i>Discounts (@Model.TotalPendingDiscountsCount)
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link rounded-pill fw-bold" id="admin-discounts-tab" data-bs-toggle="tab" data-bs-target="#admin-discounts" type="button">
                        <i class="bi bi-megaphone me-2"></i>Global Promo
                    </button>
                </li>
            </ul>
        </div>
    </div>

    <div class="tab-content" id="financeTabsContent">
        @* --- Payout Requests Tab --- *@
        <div class="tab-pane fade show active" id="payouts" role="tabpanel">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr class="x-small text-muted text-uppercase">
                                <th class="ps-4">ID</th>
                                <th>Seller / Shop</th>
                                <th>Amount</th>
                                <th>Bank Method</th>
                                <th>Requested Date</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.PendingPayouts != null && Model.PendingPayouts.Any())
                            {
                                @foreach (var p in Model.PendingPayouts)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold">#@p.WithdrawalId</td>
                                        <td>
                                            <span class="d-block fw-bold small">@p.ShopName</span>
                                            <span class="text-muted tiny">@p.SellerEmail</span>
                                        </td>
                                        <td><span class="fw-bold text-success">₱@p.Amount.ToString("N2")</span></td>
                                        <td><span class="badge bg-light text-dark border">@p.BankName</span></td>
                                        <td class="small">@p.RequestedAt.ToString("MMM dd, yyyy")</td>
                                        <td class="text-center">
                                            <div class="d-flex justify-content-center gap-1">
                                                <button class="btn btn-sm btn-success rounded-pill px-3 fw-bold"
                                                        onclick="openPayoutModal(@p.WithdrawalId, @p.Amount, 'approve', '@(p.SellerNote?.Replace("'", "\\'"))')">
                                                    Approve
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-bold"
                                                        onclick="openPayoutModal(@p.WithdrawalId, @p.Amount, 'reject')">
                                                    Reject
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="6" class="text-center py-4 text-muted">No pending payout requests.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* --- Product Approvals Tab --- *@
        <div class="tab-pane fade" id="products" role="tabpanel">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr class="x-small text-muted text-uppercase">
                                <th class="ps-4">Product Details</th>
                                <th>Category</th>
                                <th>Price</th>
                                <th>Submitted By</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.PendingProducts != null && Model.PendingProducts.Any())
                            {
                                foreach (var prod in Model.PendingProducts)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="fw-bold small">@prod.ProductName</div>
                                            </div>
                                        </td>
                                        <td><span class="badge bg-light text-dark border">@prod.Category</span></td>
                                        <td><span class="fw-bold">₱@prod.Price.ToString("N2")</span></td>
                                        <td>
                                            <span class="small d-block">@prod.SellerName</span>
                                            <span class="tiny text-muted">@prod.SubmittedAt.ToString("MM/dd/yyyy")</span>
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex justify-content-center gap-1">
                                                <button class="btn btn-sm btn-success rounded-pill px-3 fw-bold" onclick="approveProduct(@prod.ProductId)">Approve</button>
                                                <button class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-bold" onclick="declineProduct(@prod.ProductId)">Decline</button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="5" class="text-center py-4 text-muted">No products awaiting approval.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* --- Discount Approvals Tab --- *@
        <div class="tab-pane fade" id="discounts" role="tabpanel">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr class="x-small text-muted text-uppercase">
                                <th class="ps-4">Product</th>
                                <th>Orig. Price</th>
                                <th>Discount</th>
                                <th>New Price</th>
                                <th>Created</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.PendingDiscounts != null && Model.PendingDiscounts.Any())
                            {
                                @foreach (var d in Model.PendingDiscounts)
                                {
                                    var discountedPrice = d.OriginalPrice - (d.OriginalPrice * d.TotalDiscountPercent / 100);
                                    <tr>
                                        <td class="ps-4">
                                            <span class="fw-bold small d-block">@d.ProductName</span>
                                            <span class="text-muted tiny">By @d.ShopName</span>
                                        </td>
                                        <td class="text-muted small">₱@d.OriginalPrice.ToString("N2")</td>
                                        <td><span class="badge bg-danger-subtle text-danger fw-bold">-@d.TotalDiscountPercent%</span></td>
                                        <td class="fw-bold">₱@discountedPrice.ToString("N2")</td>
                                        <td class="small">@d.CreatedAt.ToString("MM/dd/yyyy")</td>
                                        <td class="text-center">
                                            <button class="btn btn-sm btn-dark rounded-pill px-4"
                                                    onclick="openDiscountReviewModal(@d.Id, '@d.ProductName.Replace("'", "\\'")', @d.TotalDiscountPercent, @discountedPrice, '@d.CreatedAt.ToString("MMM dd")', '@(d.ProductImage ?? "")')">
                                                Review
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="6" class="text-center py-4 text-muted">No pending discount requests.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* --- Global Promotions Tab --- *@
        <div class="tab-pane fade" id="admin-discounts" role="tabpanel">
            <div class="row g-4">
                @* LEFT: Launch Form *@
                <div class="col-lg-5">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h6 class="fw-bold mb-3" id="adminPromoFormTitle">Launch Global Promotion</h6>
                        <form id="adminDiscountForm" onsubmit="handleGlobalPromoSubmission(event)">
                            <div class="mb-3">
                                <label class="tiny fw-bold text-muted text-uppercase">Campaign Name</label>
                                <input type="text" class="form-control rounded-3" id="promoTitle" placeholder="e.g. 3.3 Mega Sale" required>
                            </div>
                            <div class="mb-3">
                                <label class="tiny fw-bold text-muted text-uppercase">Description</label>
                                <textarea class="form-control rounded-3" id="promoDesc" rows="3"></textarea>
                            </div>
                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="tiny fw-bold text-muted text-uppercase">Discount %</label>
                                    <input type="number" class="form-control rounded-3" id="promoPercent" required>
                                </div>
                                <div class="col-6">
                                    <label class="tiny fw-bold text-muted text-uppercase">Start Date</label>
                                    <input type="date" class="form-control rounded-3" id="promoStart" required>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-dark w-100 rounded-pill fw-bold">Launch Promotion</button>
                        </form>
                    </div>
                </div>

                @* RIGHT: Scrollable Live Campaigns List *@
                <div class="col-lg-7">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h6 class="fw-bold mb-3">Live Campaigns</h6>
                        <div id="activePromoList" class="d-flex flex-column gap-3 text-center py-5">
                            <i class="bi bi-calendar2-x text-muted fs-1"></i>
                            <p class="text-muted small mt-2">Campaign list loading or empty...</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Modals remain the same as your snippet - Ensure JS functions match ID names *@

@section Scripts {
    <script src="~/js/admin_js/financeRequest.js" asp-append-version="true"></script>
}