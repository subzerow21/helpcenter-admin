@model NextHorizon.Models.Admin_Models.FinanceRequestsViewModel

@{
    ViewData["Title"] = "Admin Portal - Requests & Finance";
    Layout = "_AdminLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin_css/financeRequest.css" asp-append-version="true" />
}

<div class="container-fluid py-4 bg-light">
    <div class="mb-4">
        <h3 class="fw-bold mb-0 text-poppins">Requests & Finance</h3>
        <p class="text-muted small">Manage seller payout disbursements, approvals, and global marketplace promotions.</p>
    </div>

    @* --- Tabs Navigation --- *@
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-2">
            <ul class="nav nav-pills nav-fill" id="financeTabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active rounded-pill fw-bold" id="payouts-tab" data-bs-toggle="tab" data-bs-target="#payouts" type="button">
                        <i class="bi bi-cash-stack me-2"></i>Payout Requests
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link rounded-pill fw-bold" id="discounts-tab" data-bs-toggle="tab" data-bs-target="#discounts" type="button">
                        <i class="bi bi-percent me-2"></i>Discount Approvals
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link rounded-pill fw-bold" id="admin-discounts-tab" data-bs-toggle="tab" data-bs-target="#admin-discounts" type="button">
                        <i class="bi bi-megaphone me-2"></i>Global Promotions
                    </button>
                </li>
            </ul>
        </div>
    </div>

    <div class="tab-content" id="financeTabsContent">
        @* --- Payout Requests Tab --- *@
        <div class="tab-pane fade show active" id="payouts" role="tabpanel">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr class="x-small text-muted text-uppercase">
                                <th class="ps-4">ID</th>
                                <th>Seller / Shop</th>
                                <th>Amount</th>
                                <th>Bank Method</th>
                                <th>Requested Date</th>
                                <th class="text-center">Action</th>
                             </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.PendingPayouts)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">#@p.WithdrawalId</td>
                                    <td>
                                        <span class="d-block fw-bold small">@p.ShopName</span>
                                        <span class="text-muted tiny">@p.SellerEmail</span>
                                    </td>
                                    <td><span class="fw-bold text-success">₱@p.Amount.ToString("N2")</span></td>
                                    <td><span class="badge bg-light text-dark border">@p.BankName</span></td>
                                    <td class="small">@p.RequestedAt.ToString("MMM dd, yyyy")</td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-1">
                                            <button class="btn btn-sm btn-success rounded-pill px-3 fw-bold"
                                                    onclick="openPayoutModal(@p.WithdrawalId, @p.Amount, 'approve')">
                                                Approve
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-bold"
                                                    onclick="openPayoutModal(@p.WithdrawalId, @p.Amount, 'reject')">
                                                Reject
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* --- Discount Approvals Tab --- *@
        <div class="tab-pane fade" id="discounts" role="tabpanel">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr class="x-small text-muted text-uppercase">
                                <th class="ps-4">Product</th>
                                <th>Orig. Price</th>
                                <th>Discount</th>
                                <th>New Price</th>
                                <th>Duration</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model.PendingDiscounts)
                            {
                                var discountedPrice = d.OriginalPrice - (d.OriginalPrice * d.TotalDiscountPercent / 100);
                                <tr>
                                    <td class="ps-4">
                                        <span class="fw-bold small d-block">@d.ProductName</span>
                                        <span class="text-muted tiny">By @d.ShopName</span>
                                    </td>
                                    <td class="text-muted small">₱@d.OriginalPrice.ToString("N2")</td>
                                    <td><span class="badge bg-danger-subtle text-danger fw-bold">-@d.TotalDiscountPercent%</span></td>
                                    <td class="fw-bold">₱@discountedPrice.ToString("N2")</td>
                                    <td class="small">@d.CreatedAt.ToString("MM/dd") - @d.CreatedAt.AddDays(7).ToString("MM/dd")</td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-dark rounded-pill px-4 shadow-sm"
                                                onclick="openDiscountReviewModal(@d.Id, '@d.ProductName', @d.TotalDiscountPercent, @discountedPrice, '@d.CreatedAt.ToString("MMM dd") - @d.CreatedAt.AddDays(7).ToString("MMM dd")', '@(d.ProductImage ?? "")')">
                                            Review
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* --- Global Promotions Tab --- *@
        <div class="tab-pane fade" id="admin-discounts" role="tabpanel">
            <div class="row g-4">
                @* LEFT: Launch Form *@
                <div class="col-lg-5">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h6 class="fw-bold mb-3" id="adminPromoFormTitle">Launch Global Promotion</h6>
                        <form id="adminDiscountForm" onsubmit="handleGlobalPromoSubmission(event)">
                            <div class="mb-3 text-center">
                                <label class="d-block mb-2 tiny fw-bold text-muted text-uppercase">Promotion Banner</label>
                                <div class="promo-upload-zone rounded-4 border-dashed p-3 d-flex flex-column align-items-center justify-content-center"
                                     onclick="document.getElementById('promoImage').click()"
                                     style="min-height: 150px; cursor: pointer; background-color: #f8f9fa; border: 2px dashed #ddd;">
                                    <img id="promoPreview" class="img-fluid rounded-3 mb-2 d-none" style="max-height: 120px;">
                                    <div id="uploadZoneText">
                                        <i class="bi bi-image fs-2 text-muted"></i>
                                        <p class="tiny text-muted mb-0">Click to upload banner</p>
                                    </div>
                                    <input type="file" id="promoImage" class="d-none" accept="image/*" onchange="handleImageSelection(this)">
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="tiny fw-bold text-muted text-uppercase">Campaign Name</label>
                                <input type="text" class="form-control rounded-3" id="promoTitle" placeholder="e.g. 3.3 Mega Sale" required>
                            </div>

                            <div class="mb-3">
                                <label class="tiny fw-bold text-muted text-uppercase">Description</label>
                                <textarea class="form-control rounded-3" id="promoDesc" rows="3" placeholder="Brief details about this promo..."></textarea>
                            </div>

                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="tiny fw-bold text-muted text-uppercase">Discount %</label>
                                    <input type="number" class="form-control rounded-3" id="promoPercent" placeholder="10" required>
                                </div>
                                <div class="col-6">
                                    <label class="tiny fw-bold text-muted text-uppercase">Start Date</label>
                                    <input type="date" class="form-control rounded-3" id="promoStart" required>
                                </div>
                            </div>

                            <div class="mb-4">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <label class="tiny fw-bold text-muted text-uppercase mb-0">End Date</label>
                                    <div class="form-check form-switch p-0">
                                        <label class="tiny text-muted me-4" style="font-size: 0.7rem;">Indefinite</label>
                                        <input class="form-check-input ms-0" type="checkbox" id="noEndDate" onchange="toggleEndDate(this)">
                                    </div>
                                </div>
                                <input type="date" class="form-control rounded-3" id="promoEnd">
                            </div>

                            <div id="promoFormActions" class="d-flex gap-2">
                                <button type="submit" class="btn btn-dark w-100 rounded-pill fw-bold py-2" id="submitPromoBtn">
                                    Launch Promotion
                                </button>
                                <button type="button" class="btn btn-light border w-100 rounded-pill fw-bold py-2 d-none" id="cancelPromoBtn" onclick="resetPromoForm()">
                                    Cancel
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                @* RIGHT: Scrollable Live Campaigns List *@
                <div class="col-lg-7">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h6 class="fw-bold mb-3">Live Campaigns</h6>
                        <div id="activePromoList" class="d-flex flex-column gap-3">
                            <div id="emptyPromoState" class="text-center py-5">
                                <i class="bi bi-calendar2-x text-muted fs-1"></i>
                                <p class="text-muted small mt-2">No promotions currently running.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* --- MODALS --- *@

<div class="modal fade" id="financeActionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-body p-4 text-center">
                <div id="financeIconContainer" class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-wallet2 fs-3"></i>
                </div>
                <h5 class="fw-bold" id="financeTitle">Confirm Action</h5>
                <p class="text-muted small" id="financeMessage"></p>

                <div id="sellerReasonDisplay" class="bg-light p-3 rounded-3 mb-3 border-start border-4 border-primary d-none text-start">
                    <label class="tiny text-uppercase fw-bold text-muted d-block mb-1">Seller's Note:</label>
                    <p id="sellerReasonText" class="small mb-0 italic"></p>
                </div>

                <textarea id="financeNote" class="form-control rounded-3 mb-3" placeholder="Add a note or reason..." rows="3"></textarea>
                <div id="rejectionFeedback" class="invalid-feedback text-start mb-3" style="display:none;">A reason is required for rejection.</div>
                <div class="d-flex gap-2">
                    <button class="btn btn-light w-100 rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-dark w-100 rounded-pill" id="financeConfirmBtn">Confirm</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="discountReviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-body p-4 text-center">
                <div class="mb-3 text-center">
                    <img id="revProdImage" src="/images/placeholder-product.png" alt="Product"
                         class="rounded-3 shadow-sm border"
                         style="width: 120px; height: 120px; object-fit: cover;">
                </div>
                <h5 class="fw-bold mb-1">Review Discount Request</h5>
                <p class="text-muted small mb-3" id="revProdName">Product Name</p>
                <div class="bg-light p-3 rounded-4 mb-3 text-start">
                    <div class="d-flex justify-content-between mb-2 border-bottom pb-2">
                        <span class="tiny text-muted text-uppercase">Price Change:</span>
                        <span class="small fw-bold text-danger">
                            <span id="revProdPercent"></span> (<span id="revProdPrice"></span>)
                        </span>
                    </div>
                    <div class="d-flex justify-content-between pt-1">
                        <span class="tiny text-muted text-uppercase">Duration:</span>
                        <span class="small fw-bold text-dark" id="revProdDates">---</span>
                    </div>
                </div>
                <div id="rejectionReasonContainer" style="display: none;" class="mb-3 text-start">
                    <label class="tiny fw-bold text-danger text-uppercase">Reason for Rejection *</label>
                    <textarea id="discountReviewNote" class="form-control rounded-3" placeholder="Explain why this was rejected..." rows="3"></textarea>
                    <div id="discountNoteFeedback" class="text-danger tiny mt-1" style="display:none;">A reason is required to reject this request.</div>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-danger w-100 rounded-pill" id="btnRejectInitial" onclick="showRejectionInput()">Reject</button>
                    <button class="btn btn-success w-100 rounded-pill" id="btnApproveFinal" onclick="handleDiscountAction('approve')">Approve</button>
                </div>
            </div>
        </div>
    </div>
</div>

@* --- Toast --- *@
<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1080">
    <div id="financeToast" class="toast hide border-0 shadow-lg rounded-4" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex p-3 align-items-center">
            <div id="financeToastIcon" class="me-3"></div>
            <div class="flex-grow-1">
                <h6 class="mb-0 fw-bold small text-dark">System Notification</h6>
                <p id="financeToastMessage" class="mb-0 tiny text-muted"></p>
            </div>
            <button type="button" class="btn-close ms-2" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin_js/financeRequest.js" asp-append-version="true"></script>
}