@{
    ViewData["Title"] = "Admin Portal - Task and Challenges";
    Layout = "_AdminLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin_css/tasks.css" asp-append-version="true" />
}

<div class="container-fluid py-4 bg-light">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-4 gap-3">
        <div>
            <h4 class="fw-bold mb-3"><i class="bi bi-lightning-charge-fill text-warning me-2"></i>Community Challenges</h4>
            <div class="d-flex border-bottom overflow-auto text-nowrap custom-tabs">
                <button id="tab-leaderboard" onclick="switchChallengeTab('leaderboard')"
                        class="btn btn-sm fw-bold bg-dark text-white rounded-0 px-3 py-2 active-tab me-1">
                    Global Leaderboard
                </button>
                <button id="tab-active-tasks" onclick="switchChallengeTab('active-tasks')"
                        class="btn btn-sm text-muted rounded-0 px-3 py-2 me-1">
                    Active & Upcoming
                </button>
            </div>
        </div>

        <button class="btn btn-dark rounded-pill px-4 shadow-sm" onclick="openCreateChallengeModal()">
            <i class="bi bi-plus-circle me-2"></i>Launch New Challenge
        </button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="p-3 bg-white rounded-4 shadow-sm border-start border-primary border-4 stat-card"
                 onclick="window.location.href='/Admin/Users'" style="cursor: pointer;">
                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Total Athletes</small>
                <h4 class="fw-bold mb-0">12,402 <i class="bi bi-chevron-right fs-6 text-muted float-end"></i></h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="p-3 bg-white rounded-4 shadow-sm border-start border-success border-4 stat-card"
                 onclick="switchChallengeTab('active-tasks')" style="cursor: pointer;">
                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Active Challenges</small>
                <h4 class="fw-bold mb-0">8 <i class="bi bi-chevron-right fs-6 text-muted float-end"></i></h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="p-3 bg-white rounded-4 shadow-sm border-start border-warning border-4 stat-card"
                 onclick="window.location.href='/Admin/Tasks'" style="cursor: pointer;">
                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Completion Rate</small>
                <h4 class="fw-bold mb-0">64% <i class="bi bi-chevron-right fs-6 text-muted float-end"></i></h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="p-3 bg-white rounded-4 shadow-sm border-start border-danger border-4 stat-card"
                 onclick="window.location.href='/Admin/Moderation'" style="cursor: pointer;">
                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Flagged Entries</small>
                <h4 class="fw-bold mb-0 text-danger">14 <i class="bi bi-chevron-right fs-6 text-muted float-end"></i></h4>
            </div>
        </div>
    </div>

    <div class="row g-2 mb-4 align-items-center">
        <div class="col-md-4">
            <div class="input-group bg-white rounded-pill shadow-sm px-3 py-1 border">
                <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" class="form-control border-0 bg-transparent" placeholder="Search athlete..." id="leaderboardSearch">
            </div>
        </div>
        <div class="col-md-3">
            <select class="form-select border shadow-sm rounded-pill px-3" id="categoryFilter" onchange="filterLeaderboard()">
                <option value="All">All Categories</option>
                <option value="Running">🏃 Running</option>
                <option value="Cycling">🚴 Cycling</option>
                <option value="Swimming">🏊 Swimming</option>
                <option value="Walking">🚶 Walking</option>
            </select>
        </div>
    </div>

    <div id="view-leaderboard" class="row g-4">
        <div class="col-12 mb-2">
            <div class="row justify-content-center align-items-end text-center g-0">
                <div class="col-3">
                    <div class="card border-0 shadow-sm rounded-4 p-3 bg-white mb-2" style="cursor:pointer" onclick="openUserView('Run_Master', '#2', '42.5 km', '12', '2450')">
                        <div class="avatar-placeholder mx-auto mb-2 bg-light rounded-circle d-flex align-items-center justify-content-center" style="width:50px; height:50px;">🥈</div>
                        <h6 class="fw-bold mb-0 small">Run_Master</h6>
                        <small class="text-muted">42.5 km</small>
                    </div>
                    <div class="bg-secondary opacity-25 rounded-top" style="height: 60px;"></div>
                </div>
                <div class="col-4">
                    <div class="card border-0 shadow-lg rounded-4 p-4 bg-white mb-2 border-top border-warning border-5" style="cursor:pointer" onclick="openUserView('Speedy_Gonzalez', '#1', '58.2 km', '18', '3100')">
                        <div class="avatar-placeholder mx-auto mb-2 bg-warning text-white rounded-circle d-flex align-items-center justify-content-center" style="width:70px; height:70px;">🥇</div>
                        <h5 class="fw-bold mb-0">Speedy_Gonzalez</h5>
                        <small class="text-muted">58.2 km</small>
                    </div>
                    <div class="bg-warning opacity-50 rounded-top" style="height: 100px;"></div>
                </div>
                <div class="col-3">
                    <div class="card border-0 shadow-sm rounded-4 p-3 bg-white mb-2" style="cursor:pointer" onclick="openUserView('Cyclist_99', '#3', '39.1 km', '9', '1900')">
                        <div class="avatar-placeholder mx-auto mb-2 bg-light rounded-circle d-flex align-items-center justify-content-center" style="width:50px; height:50px;">🥉</div>
                        <h6 class="fw-bold mb-0 small">Cyclist_99</h6>
                        <small class="text-muted">39.1 km</small>
                    </div>
                    <div class="bg-danger opacity-25 rounded-top" style="height: 40px;"></div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="consumer-grid-wrapper bg-white shadow-sm rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table mb-0 align-middle text-center" id="leaderboardTable">
                        <thead class="bg-light">
                            <tr>
                                <th>Rank</th>
                                <th>User</th>
                                <th>Category</th>
                                <th>Total Distance</th>
                                <th>Activities</th>
                                <th>Points</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 4; i <= 8; i++)
                            {
                                string cat = (i % 2 == 0) ? "Running" : "Cycling";
                                <tr>
                                    <td>#@i</td>
                                    <td class="fw-bold text-primary" style="cursor: pointer;"
                                        onclick="openUserView('@@consumer_user_@i', '#@i', '@(35 - i).4 km', '@(10 - i)', '@(1500 - (i * 50))')">
                                        @@consumer_user_@i
                                    </td>
                                    <td><span class="badge rounded-pill @(cat == "Running" ? "bg-light text-danger border border-danger" : "bg-light text-primary border border-primary")">@cat</span></td>
                                    <td>@(35 - i).4 km</td>
                                    <td>@(10 - i)</td>
                                    <td>@(1500 - (i * 50))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div id="view-active-tasks" class="d-none">
        <div class="row g-3">
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 challenge-card-hover"
                     onclick="window.location.href='/Admin/ChallengeDetails/101'" style="cursor:pointer;">
                    <div class="position-relative">
                        <img src="..." class="card-img-top" style="height: 150px; object-fit: cover;">
                        <span class="position-absolute top-0 end-0 m-2 badge bg-success shadow-sm">Live</span>
                    </div>
                    <div class="p-3">
                        <h6 class="fw-bold mb-0 text-dark">Morning 5K Streak</h6>
                        <p class="text-muted mb-2" style="font-size: 0.75rem;">March 01 - March 31</p>

                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="small text-primary fw-bold">View Participants <i class="bi bi-arrow-right"></i></span>
                            <span class="text-muted small"><i class="bi bi-people"></i> 1,420</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="launchChallengeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="fw-bold mb-0"><i class="bi bi-rocket-takeoff me-2 text-primary"></i>Launch Challenge</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4">
                <form id="launchForm">
                    <div class="mb-3">
                        <label class="small fw-bold text-secondary mb-1 d-block text-center">Challenge Cover Image</label>
                        <div class="challenge-upload-container position-relative bg-light rounded-4 d-flex flex-column align-items-center justify-content-center border-dashed p-3" style="min-height: 140px; border: 2px dashed #dee2e6;">
                            <img id="imagePreview" src="#" alt="Preview" class="img-fluid rounded-3 d-none mb-2" style="max-height: 100px; object-fit: cover;">
                            <div id="uploadPlaceholder" class="text-center">
                                <i class="bi bi-image text-muted fs-1"></i>
                                <p class="small text-muted mb-0">Click to upload 400x150 image</p>
                            </div>
                            <input type="file" id="challengeImgInput" class="position-absolute opacity-0 w-100 h-100" style="cursor: pointer;" accept="image/*" onchange="previewChallengeImage(this)">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="small fw-bold text-secondary mb-1">Challenge Name</label>
                        <input type="text" class="form-control rounded-3" placeholder="e.g., Tour de Cebu 100K">
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="small fw-bold text-secondary mb-1">Start Date</label>
                            <input type="date" class="form-control rounded-3" id="startDate">
                        </div>
                        <div class="col-6">
                            <label class="small fw-bold text-secondary mb-1">End Date</label>
                            <input type="date" class="form-control rounded-3" id="endDate">
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="small fw-bold text-secondary mb-1">Activity Type</label>
                            <select class="form-select rounded-3" id="challengeType">
                                <option value="Running">🏃 Running</option>
                                <option value="Cycling">🚴 Cycling</option>
                                <option value="Walking">🚶 Walking</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="small fw-bold text-secondary mb-1">Goal (KM)</label>
                            <input type="number" class="form-control rounded-3" placeholder="50">
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pb-4 px-4">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Discard</button>
                <button type="button" class="btn btn-dark rounded-pill px-4" onclick="saveChallengeAction()">Launch Now</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="userViewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4 overflow-hidden">
            <div class="p-4 bg-dark text-white text-center position-relative">
                <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" data-bs-dismiss="modal"></button>
                <div class="avatar-circle mx-auto mb-2 bg-warning text-dark d-flex align-items-center justify-content-center fw-bold fs-3 rounded-circle shadow" style="width: 80px; height: 80px;">
                    <span id="userInitial">U</span>
                </div>
                <h5 class="fw-bold mb-0" id="userNameView">@@username</h5>
                <p class="small opacity-75 mb-0" id="userRankView">Ranked #1 Global</p>
            </div>
            <div class="modal-body p-4">
                <div class="row text-center g-3">
                    <div class="col-4 border-end">
                        <label class="small text-muted d-block">Distance</label>
                        <span class="fw-bold fs-5" id="userDistView">0 km</span>
                    </div>
                    <div class="col-4 border-end">
                        <label class="small text-muted d-block">Activities</label>
                        <span class="fw-bold fs-5" id="userActView">0</span>
                    </div>
                    <div class="col-4">
                        <label class="small text-muted d-block">Points</label>
                        <span class="fw-bold fs-5 text-warning" id="userPtsView">0</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0 px-4 pb-4">
                <button class="btn btn-outline-danger w-100 rounded-pill" onclick="confirmAction('User entry flagged for review.', 'text-danger', 'bi-flag-fill')">
                    <i class="bi bi-flag me-2"></i>Flag for Verification
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="overrideModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4 text-center">
            <div class="modal-body p-4">
                <i class="bi bi-exclamation-triangle text-danger fs-1 mb-3"></i>
                <h5 class="fw-bold">Close Challenge?</h5>
                <p class="small text-secondary">This will end the challenge immediately for all participants.</p>
                <div class="d-flex gap-2 justify-content-center mt-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger rounded-pill px-4" onclick="confirmOverride()">Close Now</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 2000;">
    <div id="challengeToast" class="toast border-0 shadow rounded-4" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex align-items-center bg-dark text-white rounded-4 p-2">
            <div class="toast-body d-flex align-items-center gap-2">
                <i id="toastIcon" class="bi bi-check-circle-fill text-success fs-5"></i>
                <span id="toastMsg">Action Successful!</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin_js/tasks.js" asp-append-version="true"></script>
}