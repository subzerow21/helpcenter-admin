﻿@{
    ViewData["Title"] = "Admin Portal - Task and Challenges";
    Layout = "_AdminLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin_css/tasks.css" asp-append-version="true" />
}

<div class="container-fluid py-4 bg-light">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-4 gap-3">
        <div>
            <h4 class="fw-bold mb-3"><i class="bi bi-lightning-charge-fill text-warning me-2"></i>Community Challenges</h4>
            <div class="d-flex border-bottom overflow-auto text-nowrap custom-tabs">
                <button id="tab-leaderboard" onclick="switchChallengeTab('leaderboard')"
                        class="btn btn-sm fw-bold bg-dark text-white rounded-0 px-3 py-2 active-tab me-1">
                    Global Leaderboard
                </button>
                <button id="tab-active-tasks" onclick="switchChallengeTab('active-tasks')"
                        class="btn btn-sm text-muted rounded-0 px-3 py-2 me-1">
                    Active & Upcoming
                </button>
            </div>
        </div>

        <button class="btn btn-dark rounded-pill px-4 shadow-sm" onclick="openCreateChallengeModal()">
            <i class="bi bi-plus-circle me-2"></i>Launch New Challenge
        </button>
    </div>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4" id="statsCards">
        <div class="col-md-3">
            <div class="p-3 bg-white rounded-4 shadow-sm border-start border-primary border-4 stat-card">
                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Total Athletes</small>
                <h4 class="fw-bold mb-0" id="totalAthletes">--</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3 bg-white rounded-4 shadow-sm border-start border-success border-4 stat-card">
                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Active Challenges</small>
                <h4 class="fw-bold mb-0" id="activeChallenges">--</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3 bg-white rounded-4 shadow-sm border-start border-warning border-4 stat-card">
                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Avg. Distance</small>
                <h4 class="fw-bold mb-0" id="avgDistance">-- km</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3 bg-white rounded-4 shadow-sm border-start border-info border-4 stat-card">
                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Total Time Logged</small>
                <h4 class="fw-bold mb-0 text-info" id="totalTime">-- h</h4>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="row g-2 mb-4 align-items-center">
        <div class="col-md-4">
            <div class="input-group bg-white rounded-pill shadow-sm px-3 py-1 border">
                <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" class="form-control border-0 bg-transparent" placeholder="Search athlete..." id="leaderboardSearch">
            </div>
        </div>
        <div class="col-md-3">
            <select class="form-select border shadow-sm rounded-pill px-3" id="categoryFilter" onchange="filterLeaderboard()">
                <option value="All">All Categories</option>
                <option value="Running">🏃 Running</option>
                <option value="Cycling">🚴 Cycling</option>
                <option value="Walking">🚶 Walking</option>
            </select>
        </div>
    </div>

    <!-- Leaderboard View -->
    <div id="view-leaderboard" class="row g-4">
        <div class="col-12">
            <div class="consumer-grid-wrapper bg-white shadow-sm rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table mb-0 align-middle text-center" id="leaderboardTable">
                        <thead class="bg-light">
                            <tr class="tiny text-uppercase fw-bold text-muted">
                                <th>Rank</th>
                                <th class="text-start ps-4">User</th>
                                <th>Category</th>
                                <th>Total Distance</th>
                                <th>Activities</th>
                                <th>Total Time</th>
                                <th>Progress</th>
                              </tr>
                        </thead>
                        <tbody id="leaderboardBody">
                            <tr><td colspan="7" class="text-center py-4">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Active Challenges View -->
    <div id="view-active-tasks" class="d-none">
        <div class="row g-3" id="challengesList">
            <div class="col-12 text-center py-5">Loading challenges...</div>
        </div>
    </div>
</div>

<!-- Launch/Edit Challenge Modal -->
<div class="modal fade" id="launchChallengeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow rounded-4">
            <form id="launchForm" onsubmit="handleChallengeSubmit(event)">
                <div class="modal-header border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0" id="modalTitle"><i class="bi bi-rocket-takeoff me-2 text-primary"></i>Launch Challenge</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body px-4">
                    <input type="hidden" id="editChallengeId" value="">
                    <div class="row">
                        <div class="col-md-5 mb-3 border-end">
                            <label class="small fw-bold text-secondary mb-2 d-block text-center">Challenge Cover Image</label>
                            <div class="challenge-upload-container position-relative bg-light rounded-4 d-flex flex-column align-items-center justify-content-center border-dashed p-3" style="min-height: 200px; border: 2px dashed #dee2e6;">
                                <img id="imagePreview" src="#" alt="Preview" class="img-fluid rounded-3 d-none mb-2" style="max-height: 150px; object-fit: cover;">
                                <div id="uploadPlaceholder" class="text-center">
                                    <i class="bi bi-image text-muted fs-1"></i>
                                    <p class="small text-muted mb-0">Click to upload banner</p>
                                </div>
                               <input type="file" id="challengeImgInput" class="position-absolute opacity-0 w-100 h-100" style="cursor: pointer;" accept="image/*" onchange="previewChallengeImage(this)">
                            </div>
                        </div>
                        <div class="col-md-7">
                            <div class="mb-3">
                                <label class="small fw-bold text-secondary mb-1">Challenge Name</label>
                                <input type="text" id="challengeTitle" class="form-control rounded-3" placeholder="e.g., Morning 5K Streak" required>
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="small fw-bold text-secondary mb-1">Start Date</label>
                                    <input type="date" id="startDate" class="form-control rounded-3" required>
                                </div>
                                <div class="col-6">
                                    <label class="small fw-bold text-secondary mb-1">End Date</label>
                                    <input type="date" id="endDate" class="form-control rounded-3" required>
                                </div>
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="small fw-bold text-secondary mb-1">Activity Type</label>
                                    <select id="activityType" class="form-select rounded-3" required>
                                        <option value="">Select Type</option>
                                        <option value="Running">🏃 Running</option>
                                        <option value="Cycling">🚴 Cycling</option>
                                        <option value="Walking">🚶 Walking</option>
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="small fw-bold text-secondary mb-1">Goal (KM)</label>
                                    <input type="number" id="goalKm" class="form-control rounded-3" placeholder="50" min="1" required>
                                </div>
                            </div>
                            <div class="mb-3" id="statusField" style="display:none;">
                                <label class="small fw-bold text-secondary mb-1">Status</label>
                                <select id="challengeStatus" class="form-select rounded-3">
                                    <option value="Upcoming">Upcoming</option>
                                    <option value="Live">Live</option>
                                    <option value="Completed">Completed</option>
                                    <option value="Cancelled">Cancelled</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <hr class="my-3 opacity-50">

                    <div class="mb-3">
                        <label class="small fw-bold text-secondary mb-1">Description</label>
                        <textarea id="challengeDesc" class="form-control rounded-3" rows="2" placeholder="Tell athletes what this challenge is about..." required></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="small fw-bold text-secondary mb-1">Rules & Regulations</label>
                        <textarea id="challengeRules" class="form-control rounded-3" rows="3" placeholder="List the rules here..." required></textarea>
                    </div>

                    <div class="mb-2">
                        <label class="small fw-bold text-secondary mb-1">Prizes & Rewards</label>
                        <textarea id="challengePrizes" class="form-control rounded-3" rows="2" placeholder="What do they win?" required></textarea>
                    </div>

                    <!-- Prize Management Section -->
                    <div class="mb-3">
                        <label class="small fw-bold text-secondary mb-1">Does this challenge have prizes?</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="hasPrizes" id="hasPrizesYes" value="yes" onchange="togglePrizeManagement('yes')">
                                <label class="form-check-label" for="hasPrizesYes">Yes, there are prizes</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="hasPrizes" id="hasPrizesNo" value="no" onchange="togglePrizeManagement('no')" checked>
                                <label class="form-check-label" for="hasPrizesNo">No prizes</label>
                            </div>
                        </div>
                    </div>

                    <div id="prizeManagementSection" style="display: none;">
                        <hr class="my-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="fw-bold text-secondary">
                                <i class="bi bi-trophy me-1 text-warning"></i>Prize Structure
                            </label>
                            <button type="button" class="btn btn-sm btn-outline-primary rounded-pill" onclick="addPrizeTier()">
                                <i class="bi bi-plus-circle me-1"></i>Add Prize Tier
                            </button>
                        </div>
                        <div id="prizeTiersContainer"></div>
                        <small class="text-muted">Configure prizes for 1st, 2nd, 3rd place, etc.</small>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4 px-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-dark rounded-pill px-4">Save Challenge</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Prize Type Template (Hidden) -->
<div id="prizeTypeTemplate" style="display: none;">
    <div class="prize-tier-card border rounded-3 p-3 mb-3 bg-light">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h6 class="fw-bold mb-0">Tier <span class="tier-number"></span></h6>
            <button type="button" class="btn btn-sm btn-link text-danger p-0" onclick="removePrizeTier(this)">
                <i class="bi bi-trash"></i>
            </button>
        </div>
        <div class="row g-2">
            <div class="col-md-4">
                <label class="small fw-bold">Prize Type</label>
                <select class="form-select form-select-sm prize-type-select" onchange="togglePrizeFields(this)">
                    <option value="">Select Type</option>
                    <option value="cash">💰 Cash Prize</option>
                    <option value="shipping_voucher">📦 Free Shipping Voucher</option>
                    <option value="product_voucher">🏷️ Product Discount Voucher</option>
                    <option value="reward">🎁 Physical Reward</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="small fw-bold">Tier Name</label>
                <input type="text" class="form-control form-control-sm tier-name" placeholder="e.g., Gold, 1st Place">
            </div>
            <div class="col-md-4">
                <label class="small fw-bold">Description</label>
                <input type="text" class="form-control form-control-sm prize-description" placeholder="Describe the prize">
            </div>
        </div>
        
        <!-- Cash Prize Fields -->
        <div class="cash-fields mt-2" style="display: none;">
            <div class="row g-2">
                <div class="col-md-12">
                    <label class="small fw-bold">Cash Amount (PHP)</label>
                    <input type="number" class="form-control form-control-sm cash-amount" placeholder="e.g., 5000">
                </div>
            </div>
        </div>
        
        <!-- Voucher Fields -->
        <div class="voucher-fields mt-2" style="display: none;">
            <div class="row g-2">
                <div class="col-md-4">
                    <label class="small fw-bold">Discount (%)</label>
                    <input type="number" class="form-control form-control-sm voucher-percent" placeholder="e.g., 20">
                </div>
                <div class="col-md-4">
                    <label class="small fw-bold">Discount (Fixed)</label>
                    <input type="number" class="form-control form-control-sm voucher-fixed" placeholder="e.g., 500">
                </div>
                <div class="col-md-4">
                    <label class="small fw-bold">Min. Purchase</label>
                    <input type="number" class="form-control form-control-sm voucher-min-purchase" placeholder="e.g., 1000">
                </div>
            </div>
        </div>
        
        <!-- Reward Fields -->
        <div class="reward-fields mt-2" style="display: none;">
            <div class="row g-2">
                <div class="col-md-6">
                    <label class="small fw-bold">Reward Name</label>
                    <input type="text" class="form-control form-control-sm reward-name" placeholder="e.g., Premium Water Bottle">
                </div>
                <div class="col-md-6">
                    <label class="small fw-bold">Reward Value (PHP)</label>
                    <input type="number" class="form-control form-control-sm reward-value" placeholder="e.g., 1500">
                </div>
            </div>
        </div>
        
        <input type="hidden" class="prize-type-id" value="">
        <input type="hidden" class="voucher-type" value="">
    </div>
</div>

<!-- Confirmation Modal -->
<div class="modal fade" id="confirmLaunchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4 text-center">
            <div class="modal-body p-4">
                <div class="mb-3"><i class="bi bi-question-circle text-primary fs-1"></i></div>
                <h5 class="fw-bold" id="confirmTitle">Save Changes?</h5>
                <p class="small text-secondary" id="confirmMessage">Updates will be visible to all active participants immediately.</p>
                <div class="d-flex gap-2 justify-content-center mt-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-dark rounded-pill px-4" id="confirmExecuteBtn">Confirm</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- User View Modal -->
<div class="modal fade" id="userViewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4 overflow-hidden">
            <div class="p-4 bg-dark text-white text-center position-relative">
                <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" data-bs-dismiss="modal"></button>
                <div class="avatar-wrapper mx-auto mb-2 shadow rounded-circle border border-3 border-warning overflow-hidden" style="width: 100px; height: 100px;">
                    <img id="userModalPic" src="" class="w-100 h-100 object-fit-cover">
                </div>
                <h5 class="fw-bold mb-0" id="userNameView"></h5>
                <p class="small opacity-75 mb-0" id="userRankView"></p>
            </div>
            <div class="modal-body p-4">
                <div class="row text-center g-3">
                    <div class="col-4 border-end">
                        <label class="small text-muted d-block">Total Distance</label>
                        <span class="fw-bold fs-5" id="userDistView">0 km</span>
                    </div>
                    <div class="col-4 border-end">
                        <label class="small text-muted d-block">Activities</label>
                        <span class="fw-bold fs-5" id="userActView">0</span>
                    </div>
                    <div class="col-4">
                        <label class="small text-muted d-block">Total Time</label>
                        <span class="fw-bold fs-5 text-warning" id="userTimeView">00:00:00</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0 px-4 pb-4">
                <button class="btn btn-outline-dark w-100 rounded-pill" data-bs-dismiss="modal">Close Profile</button>
            </div>
        </div>
    </div>
</div>

<!-- Toast Notification -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="challengeToast" class="toast border-0 shadow rounded-4" role="alert">
        <div class="d-flex align-items-center bg-dark text-white rounded-4 p-2">
            <div class="toast-body d-flex align-items-center gap-2">
                <i id="toastIcon" class="bi bi-check-circle-fill text-success fs-5"></i>
                <span id="toastMsg">Action Successful!</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin_js/adminutils.js" asp-append-version="true"></script>
    <script src="~/js/admin_js/tasks.js" asp-append-version="true"></script>
}