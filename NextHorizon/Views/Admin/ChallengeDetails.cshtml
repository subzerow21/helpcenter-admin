﻿@{
    ViewData["Title"] = "Challenge Details";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4 bg-light">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Admin/Tasks" class="text-decoration-none text-muted">Challenges</a></li>
            <li class="breadcrumb-item active fw-bold" id="challengeTitleBreadcrumb">Loading...</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4" id="challengeHeader">
        <div class="d-flex align-items-center gap-3">
            <img id="challengeBanner" src="" class="rounded-3 shadow-sm border" style="width: 60px; height: 60px; object-fit: cover;">
            <div>
                <h3 class="fw-bold mb-0" id="challengeTitle2">Loading...</h3>
                <span id="challengeStatusBadge" class="badge rounded-pill"></span>
                <span class="text-muted small ms-2" id="challengeDates"></span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-dark rounded-pill px-3" onclick="exportParticipants()">
                <i class="bi bi-download me-2"></i>Export CSV
            </button>
            <button class="btn btn-dark rounded-pill px-3" onclick="openEditChallengeModalFromDetails()">
                <i class="bi bi-pencil-square me-2"></i>Edit Challenge
            </button>
        </div>
    </div>

    <div class="row g-3 mb-4 text-center" id="challengeStats">
        <div class="col-md-3">
            <div class="bg-white p-3 rounded-4 shadow-sm border-bottom border-primary border-4">
                <h4 class="fw-bold mb-0" id="totalParticipants">0</h4>
                <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Participants</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-white p-3 rounded-4 shadow-sm border-bottom border-success border-4">
                <h4 class="fw-bold mb-0" id="totalCompleted">0</h4>
                <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Completed</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-white p-3 rounded-4 shadow-sm border-bottom border-info border-4">
                <h4 class="fw-bold mb-0" id="avgDistance">0 km</h4>
                <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Avg. Distance / User</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-white p-3 rounded-4 shadow-sm border-bottom border-dark border-4">
                <h4 class="fw-bold mb-0" id="avgTime">0 min</h4>
                <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Avg. Time / User</small>
            </div>
        </div>
    </div>

    <!-- Prize Claim Section -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4" id="prizeSection">
        <div class="card-header bg-white border-0 py-3 px-4">
            <h5 class="fw-bold mb-0">
                <i class="bi bi-gift text-warning me-2"></i>Your Prizes
            </h5>
        </div>
        <div class="card-body" id="prizeListContainer">
            <div class="text-center py-4" id="noPrizeMessage">
                <i class="bi bi-trophy text-muted fs-1"></i>
                <p class="text-muted mt-2">No prizes available for this challenge</p>
            </div>
            <div id="prizeList" style="display: none;"></div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white border-0 py-3 px-4">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="fw-bold mb-0">Challenge Leaderboard</h5>
                </div>
                <div class="col-md-4">
                    <div class="input-group input-group-sm border rounded-pill px-2">
                        <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" id="leaderboardSearch" class="form-control border-0 bg-transparent" placeholder="Search participant name...">
                    </div>
                </div>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="bg-light text-center">
                    <tr>
                        <th style="width: 80px;">Rank</th>
                        <th class="text-start">Athlete</th>
                        <th>Progress</th>
                        <th>Total Distance</th>
                        <th>Activities</th>
                        <th>Total Time</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="leaderboardBody" class="text-center">
                    <tr><td colspan="7" class="text-center py-4">Loading...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Activity Log Modal -->
<div class="modal fade" id="activityDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header bg-light border-0 py-3 px-4">
                <h6 class="fw-bold mb-0">Activity Log: <span id="detailAthleteName" class="text-primary">Athlete</span></h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div id="activityLogList" class="list-group list-group-flush" style="max-height: 400px; overflow-y: auto;">
                    <div class="text-center py-4">Loading activities...</div>
                </div>
            </div>
            <div class="modal-footer border-0 p-3">
                <button type="button" class="btn btn-sm btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Prize Claim Modal -->
<div class="modal fade" id="claimPrizeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="fw-bold mb-0">
                    <i class="bi bi-gift me-2"></i>Claim Your Prize
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4" id="claimPrizeForm">
                <!-- Dynamic form will be inserted here -->
            </div>
        </div>
    </div>
</div>

<!-- Prize Code Verification Modal -->
<div class="modal fade" id="verifyPrizeCodeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header bg-success text-white border-0">
                <h5 class="fw-bold mb-0">
                    <i class="bi bi-qr-code me-2"></i>Verify Prize Code
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="text-center mb-4">
                    <i class="bi bi-ticket-perforated fs-1 text-primary"></i>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Enter your prize claim code</label>
                    <input type="text" class="form-control form-control-lg text-center" id="claimCodeInput" 
                           placeholder="e.g., CH0001P0001-XXXXXXXX" style="font-family: monospace;">
                    <small class="text-muted">Enter the unique code you received for your prize</small>
                </div>
                <div class="d-grid gap-2">
                    <button class="btn btn-primary rounded-pill py-2" onclick="verifyAndClaimPrize()">
                        <i class="bi bi-check-circle me-2"></i>Verify & Claim
                    </button>
                    <button class="btn btn-light rounded-pill py-2" data-bs-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Challenge Modal (reuse from Tasks) -->
<div class="modal fade" id="launchChallengeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow rounded-4">
            <form id="launchForm" onsubmit="handleChallengeSubmit(event)">
                <div class="modal-header border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0"><i class="bi bi-pencil-square me-2 text-primary"></i>Edit Challenge</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body px-4">
                    <input type="hidden" id="editChallengeId">
                    <div class="row">
                        <div class="col-md-5 mb-3 border-end">
                            <label class="small fw-bold text-secondary mb-2 d-block text-center">Challenge Cover Image</label>
                            <div class="challenge-upload-container position-relative bg-light rounded-4 d-flex flex-column align-items-center justify-content-center border-dashed p-3" style="min-height: 200px; border: 2px dashed #dee2e6;">
                                <img id="imagePreview" src="#" class="img-fluid rounded-3 d-none mb-2" style="max-height: 150px; object-fit: cover;">
                                <div id="uploadPlaceholder" class="text-center">
                                    <i class="bi bi-image text-muted fs-1"></i>
                                    <p class="small text-muted mb-0">Click to change banner</p>
                                </div>
                                <input type="file" id="challengeImgInput" class="position-absolute opacity-0 w-100 h-100" accept="image/*" onchange="previewChallengeImage(this)">
                            </div>
                        </div>
                        <div class="col-md-7">
                            <div class="mb-3">
                                <label class="small fw-bold text-secondary mb-1">Challenge Name</label>
                                <input type="text" id="challengeTitle" class="form-control rounded-3" required>
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="small fw-bold text-secondary mb-1">Start Date</label>
                                    <input type="date" id="startDate" class="form-control rounded-3" required>
                                </div>
                                <div class="col-6">
                                    <label class="small fw-bold text-secondary mb-1">End Date</label>
                                    <input type="date" id="endDate" class="form-control rounded-3" required>
                                </div>
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="small fw-bold text-secondary mb-1">Activity Type</label>
                                    <select id="activityType" class="form-select rounded-3" required>
                                        <option value="Running">🏃 Running</option>
                                        <option value="Cycling">🚴 Cycling</option>
                                        <option value="Walking">🚶 Walking</option>
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="small fw-bold text-secondary mb-1">Goal (KM)</label>
                                    <input type="number" id="goalKm" class="form-control rounded-3" min="1" required>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="small fw-bold text-secondary mb-1">Status</label>
                                <select id="challengeStatus" class="form-select rounded-3">
                                    <option value="Upcoming">Upcoming</option>
                                    <option value="Live">Live</option>
                                    <option value="Completed">Completed</option>
                                    <option value="Cancelled">Cancelled</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="small fw-bold text-secondary mb-1">Description</label>
                        <textarea id="challengeDesc" class="form-control rounded-3" rows="2" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="small fw-bold text-secondary mb-1">Rules & Regulations</label>
                        <textarea id="challengeRules" class="form-control rounded-3" rows="3" required></textarea>
                    </div>
                    <div class="mb-2">
                        <label class="small fw-bold text-secondary mb-1">Prizes & Rewards</label>
                        <textarea id="challengePrizes" class="form-control rounded-3" rows="2" required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4 px-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-dark rounded-pill px-4">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div class="modal fade" id="confirmLaunchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4 text-center">
            <div class="modal-body p-4">
                <div class="mb-3"><i class="bi bi-question-circle text-primary fs-1"></i></div>
                <h5 class="fw-bold">Save Changes?</h5>
                <p class="small text-secondary">Updates will be visible to all active participants immediately.</p>
                <div class="d-flex gap-2 justify-content-center mt-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-dark rounded-pill px-4" id="confirmExecuteBtn">Confirm</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Image Proof Modal -->
<div class="modal fade" id="imageProofModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header bg-dark text-white border-0">
                <h6 class="fw-bold mb-0">Activity Proof Image</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <img id="proofImage" src="" class="img-fluid rounded-3" style="max-height: 70vh; object-fit: contain;">
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Toast Notification -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="challengeToast" class="toast border-0 shadow rounded-4">
        <div class="d-flex align-items-center bg-dark text-white rounded-4 p-2">
            <div class="toast-body d-flex align-items-center gap-2">
                <i id="toastIcon" class="bi bi-check-circle-fill text-success fs-5"></i>
                <span id="toastMsg">Action Successful!</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin_js/adminutils.js" asp-append-version="true"></script>
    <script src="~/js/admin_js/challengeDetails.js" asp-append-version="true"></script>
}