@{
    ViewData["Title"] = "Challenge Details";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4 bg-light">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Admin/Tasks" class="text-decoration-none text-muted">Challenges</a></li>
            <li class="breadcrumb-item active fw-bold">Morning 5K Streak</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <img src="https://images.unsplash.com/photo-1552674605-db6ffd4facb5?auto=format&fit=crop&q=80&w=100"
                 class="rounded-3 shadow-sm border" style="width: 60px; height: 60px; object-fit: cover;">
            <div>
                <h3 class="fw-bold mb-0">Morning 5K Streak</h3>
                <span class="badge bg-success rounded-pill">Live</span>
                <span class="text-muted small ms-2"><i class="bi bi-calendar3 me-1"></i> March 01 - March 31, 2026</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-dark rounded-pill px-3" onclick="exportParticipants()">
                <i class="bi bi-download me-2"></i>Export CSV
            </button>
            <button class="btn btn-dark rounded-pill px-3" onclick="openEditChallengeModal()">
                <i class="bi bi-pencil-square me-2"></i>Edit Challenge
            </button>
        </div>
    </div>

    <div class="row g-3 mb-4 text-center">
        <div class="col-md-3">
            <div class="bg-white p-3 rounded-4 shadow-sm border-bottom border-primary border-4">
                <h4 class="fw-bold mb-0">1,420</h4>
                <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Participants</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-white p-3 rounded-4 shadow-sm border-bottom border-success border-4">
                <h4 class="fw-bold mb-0">412</h4>
                <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Completed</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-white p-3 rounded-4 shadow-sm border-bottom border-info border-4">
                <h4 class="fw-bold mb-0">8.4 km</h4>
                <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Avg. Distance / User</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-white p-3 rounded-4 shadow-sm border-bottom border-dark border-4">
                <h4 class="fw-bold mb-0">00:52:10</h4>
                <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Avg. Time / User</small>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white border-0 py-3 px-4">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="fw-bold mb-0">Challenge Leaderboard</h5>
                </div>
                <div class="col-md-4">
                    <div class="input-group input-group-sm border rounded-pill px-2">
                        <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" class="form-control border-0 bg-transparent" placeholder="Search participant name...">
                    </div>
                </div>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="bg-light text-center">
                    <tr>
                        <th style="width: 80px;">Rank</th>
                        <th class="text-start">Athlete</th>
                        <th>Progress</th>
                        <th>Avg. KM</th>
                        <th>Avg. Time</th>
                        <th>Last Log</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody class="text-center">
                    <tr>
                        <td class="fw-bold">#1</td>
                        <td class="text-start">
                            <div class="d-flex align-items-center gap-2">
                                <img src="https://ui-avatars.com/api/?name=John+Smith&background=random" class="rounded-circle" width="32" height="32">
                                <div>
                                    <div class="fw-bold mb-0">John Smith</div>
                                    <small class="text-muted">john.s@example.com</small>
                                </div>
                            </div>
                        </td>
                        <td style="width: 180px;">
                            <div class="d-flex align-items-center gap-2">
                                <div class="progress flex-grow-1" style="height: 6px;">
                                    <div class="progress-bar bg-success" style="width: 100%"></div>
                                </div>
                                <small class="fw-bold">100%</small>
                            </div>
                        </td>
                        <td>12.2 km</td>
                        <td>01:10:00</td>
                        <td class="small">2 hours ago</td>
                        <td>
                            <button class="btn btn-sm btn-light border rounded-pill px-3"
                                    onclick="viewActivityLog('John Smith')">
                                View Logs
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>


<div class="modal fade" id="activityDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header bg-light border-0 py-3 px-4">
                <h6 class="fw-bold mb-0">Activity Log: <span id="detailAthleteName" class="text-primary">Athlete</span></h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="list-group list-group-flush" style="max-height: 400px; overflow-y: auto;">
                    <div class="list-group-item p-3 border-0 border-bottom text-start">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="fw-bold small text-dark">Morning Run</span>
                            <span class="badge bg-light text-dark border">5.2 km</span>
                        </div>
                        <div class="d-flex justify-content-between small text-muted">
                            <span>March 05, 2026 • 06:30 AM</span>
                            <span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>Verified</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 p-3">
                <button type="button" class="btn btn-sm btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="launchChallengeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow rounded-4">
            <form id="launchForm" onsubmit="handleChallengeSubmit(event)">
                <div class="modal-header border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0"><i class="bi bi-pencil-square me-2 text-primary"></i>Modify Challenge</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body px-4">
                    <div class="row">
                        <div class="col-md-5 mb-3 border-end">
                            <label class="small fw-bold text-secondary mb-2 d-block">Challenge Cover</label>
                            <div class="challenge-upload-container position-relative bg-light rounded-4 d-flex flex-column align-items-center justify-content-center border-dashed p-3" style="min-height: 200px; border: 2px dashed #dee2e6;">
                                <img id="imagePreview" src="https://images.unsplash.com/photo-1552674605-db6ffd4facb5?auto=format&fit=crop&q=80&w=400"
                                     class="img-fluid rounded-3 mb-2" style="max-height: 150px; object-fit: cover;">
                                <input type="file" id="challengeImgInput" class="position-absolute opacity-0 w-100 h-100" style="cursor: pointer;" accept="image/*" onchange="previewChallengeImage(this)">
                                <button type="button" class="btn btn-sm btn-dark rounded-pill">Change Image</button>
                            </div>
                        </div>
                        <div class="col-md-7">
                            <div class="mb-3">
                                <label class="small fw-bold text-secondary mb-1">Challenge Name</label>
                                <input type="text" class="form-control rounded-3" value="Morning 5K Streak" required>
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="small fw-bold text-secondary mb-1">Status</label>
                                    <select class="form-select rounded-3">
                                        <option selected>Live</option>
                                        <option>Paused</option>
                                        <option>Closed</option>
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="small fw-bold text-secondary mb-1">Goal (KM)</label>
                                    <input type="number" class="form-control rounded-3" value="5" required>
                                </div>
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="small fw-bold text-secondary mb-1">Start Date</label>
                                    <input type="date" id="startDate" class="form-control rounded-3" value="2026-03-01" required>
                                </div>
                                <div class="col-6">
                                    <label class="small fw-bold text-secondary mb-1">End Date</label>
                                    <input type="date" id="endDate" class="form-control rounded-3" value="2026-03-31" required>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="my-3 opacity-50">

                    <div class="mb-3">
                        <label class="small fw-bold text-secondary mb-1">Description</label>
                        <textarea class="form-control rounded-3" rows="2" required>Run 5 kilometers every single morning for 30 days straight.</textarea>
                    </div>

                    <div class="mb-3">
                        <label class="small fw-bold text-secondary mb-1">Rules</label>
                        <textarea class="form-control rounded-3" rows="2" required>Activity must be logged between 5:00 AM and 9:00 AM. Indoor treadmill runs are allowed.</textarea>
                    </div>

                    <div class="mb-2">
                        <label class="small fw-bold text-secondary mb-1">Prizes</label>
                        <textarea class="form-control rounded-3" rows="2" required>Exclusive "Early Bird" digital badge and a 20% discount coupon for sports gear.</textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4 px-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Discard</button>
                    <button type="submit" class="btn btn-dark rounded-pill px-4">Update Challenge</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmLaunchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4 text-center">
            <div class="modal-body p-4">
                <div class="mb-3"><i class="bi bi-question-circle text-primary fs-1"></i></div>
                <h5 class="fw-bold">Save Changes?</h5>
                <p class="small text-secondary">Updates will be visible to all active participants immediately.</p>
                <div class="d-flex gap-2 justify-content-center mt-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-dark rounded-pill px-4" onclick="executeLaunch()">Confirm</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 2000;">
    <div id="challengeToast" class="toast border-0 shadow rounded-4" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex align-items-center bg-dark text-white rounded-4 p-2">
            <div class="toast-body d-flex align-items-center gap-2">
                <i id="toastIcon" class="bi bi-check-circle-fill text-success fs-5"></i>
                <span id="toastMsg">Action Successful!</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/admin_css/challengeDetails.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/admin_js/challengeDetails.js" asp-append-version="true"></script>
}