﻿@{
    ViewData["Title"] = "Admin Portal - Consumers";
    Layout = "_AdminLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin_css/users.css" asp-append-version="true" />
}

<div class="container-fluid py-4 bg-light">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-4 gap-3">
        <div>
            <div class="d-flex border-bottom overflow-auto text-nowrap custom-tabs">
                <button id="tab-active" onclick="switchUserTab('active')"
                        class="btn btn-sm fw-bold bg-dark text-white rounded-0 px-3 py-2 active-tab me-1">
                    Active Consumers
                </button>
                <button id="tab-archived" onclick="switchUserTab('archived')"
                        class="btn btn-sm text-muted rounded-0 px-3 py-2">
                    Archived
                </button>
            </div>
        </div>

        <div class="d-flex align-items-center gap-2 w-100-sm">
            <div class="search-container shadow-sm flex-grow-1">
                <input type="text" id="searchInput" class="form-control rounded-pill border-0 px-3 py-2" placeholder="Search Consumer">
                <i class="bi bi-search"></i>
            </div>
        </div>
    </div>

    <!-- Active Consumers View -->
    <div id="view-active" class="consumer-grid-wrapper bg-white shadow-sm overflow-hidden rounded-4">
        <div class="table-responsive">
            <table class="table mb-0 align-middle text-center" style="min-width: 800px;">
                <thead>
                    <tr>
                        <th class="border-start">Name</th>
                        <th class="border-start">Number</th>
                        <th class="border-start">Email</th>
                        <th class="border-start">Address</th>
                        <th class="border-start">Date Joined</th>
                        <th class="border-start">Action</th>
                    </tr>
                </thead>
                <tbody id="activeConsumersBody">
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">Loading consumers...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Archived Consumers View -->
    <div id="view-archived" class="consumer-grid-wrapper bg-white shadow-sm d-none overflow-hidden rounded-4">
        <div class="table-responsive">
            <table class="table mb-0 align-middle text-center" style="min-width: 800px;">
                <thead class="bg-light">
                    <tr>
                        <th class="border-start">Name</th>
                        <th class="border-start">Number</th>
                        <th class="border-start">Email</th>
                        <th class="border-start">Address</th>
                        <th class="border-start">Action</th>
                    </tr>
                </thead>
                <tbody id="archivedConsumersBody">
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">Loading archived consumers...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="fw-bold">Edit Consumer Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4">
                <form id="editForm">
                    <input type="hidden" id="editConsumerId">
                    <div class="mb-3">
                        <label class="small fw-bold text-secondary">Full Name</label>
                        <input type="text" class="form-control rounded-3" id="editName">
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="small fw-bold text-secondary">Number</label>
                            <input type="text" class="form-control rounded-3" id="editNumber">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="small fw-bold text-secondary">Email Address</label>
                        <input type="email" class="form-control rounded-3" id="editEmail">
                    </div>
                    <div class="mb-3">
                        <label class="small fw-bold text-secondary">Address</label>
                        <textarea class="form-control rounded-3" id="editAddress" rows="2"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pb-4 px-4">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-dark rounded-pill px-4" onclick="saveChanges()">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4 text-center">
            <div class="modal-body p-4">
                <div id="confirmIcon" class="mb-3"></div>
                <h5 class="fw-bold" id="confirmTitle">Are you sure?</h5>
                <p class="small text-secondary" id="confirmMessage">This action cannot be undone.</p>
                <div class="d-flex gap-2 justify-content-center mt-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">No</button>
                    <button type="button" id="confirmBtn" class="btn rounded-pill px-4 text-white">Yes, Proceed</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Toast Notification -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1060;">
    <div id="actionToast" class="toast border-0 shadow rounded-4" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex align-items-center bg-dark text-white rounded-4 p-2">
            <div class="toast-body d-flex align-items-center gap-2">
                <i id="toastIcon" class="bi bi-check-circle-fill text-success fs-5"></i>
                <span id="toastMessage">Action completed successfully!</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin_js/users.js" asp-append-version="true"></script>
}