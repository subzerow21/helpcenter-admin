@{
    ViewData["Title"] = "Moderation Queue";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4 bg-light min-vh-100">
    <div class="d-flex justify-content-between align-items-center mb-4 max-container">
        <div>
            <h4 class="fw-bold text-dark mb-1">Notifications</h4>
            <p class="text-secondary small mb-0">System updates and user activity logs.</p>
        </div>
        <button class="btn btn-dark rounded-pill px-4 btn-sm fw-bold shadow-sm" onclick="markAllAsRead()">
            <i class="bi bi-check-all me-1"></i>Mark all read
        </button>
    </div>

    <div class="notification-feed" id="notificationContainer">

        <div class="notif-card unread" id="notif-1">
            <div class="notif-icon bg-dark text-white shadow-sm">
                <i class="bi bi-person-plus"></i>
            </div>
            <div class="notif-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="pe-3">
                        <span class="notif-title">New User Registered</span>
                        <p class="notif-text mb-1">Sarah Jenkins created a new administrator account.</p>
                        <span class="notif-time text-uppercase">Just now</span>
                    </div>

                    <div class="dropdown">
                        <button class="btn btn-link text-dark p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-three-dots-vertical"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow border rounded-3 p-2">
                            <li><a class="dropdown-item small fw-bold" href="javascript:void(0)" onclick="toggleRead(1, true)"><i class="bi bi-check2 me-2"></i>Mark as Read</a></li>
                            <li><a class="dropdown-item small fw-bold" href="javascript:void(0)" onclick="toggleRead(1, false)"><i class="bi bi-envelope me-2"></i>Mark as Unread</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item small fw-bold text-danger" href="javascript:void(0)" onclick="deleteNotif(1)"><i class="bi bi-trash3 me-2"></i>Delete</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="notif-card read" id="notif-2">
            <div class="notif-icon bg-white border border-secondary-subtle text-dark shadow-sm">
                <i class="bi bi-shield-check"></i>
            </div>
            <div class="notif-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="pe-3">
                        <span class="notif-title">Security Scan Complete</span>
                        <p class="notif-text mb-1">Weekly platform security audit completed with 0 vulnerabilities found.</p>
                        <span class="notif-time text-uppercase">2 hours ago</span>
                    </div>

                    <div class="dropdown">
                        <button class="btn btn-link text-dark p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-three-dots-vertical"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow border rounded-3 p-2">
                            <li><a class="dropdown-item small fw-bold" href="javascript:void(0)" onclick="toggleRead(2, true)"><i class="bi bi-check2 me-2"></i>Mark as Read</a></li>
                            <li><a class="dropdown-item small fw-bold" href="javascript:void(0)" onclick="toggleRead(2, false)"><i class="bi bi-envelope me-2"></i>Mark as Unread</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item small fw-bold text-danger" href="javascript:void(0)" onclick="deleteNotif(2)"><i class="bi bi-trash3 me-2"></i>Delete</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/admin_js/notifications.js" asp-append-version="true"></script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin_css/notifications.css" asp-append-version="true" />
}