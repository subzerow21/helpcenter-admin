@{
    ViewData["Title"] = "Payment Methods";
    Layout = "_ProfileLayout";

    // Simulation: Replace with your actual Model
    var savedCards = new List<dynamic>
    {
        /* new { Id = 1, Brand = "Visa", Last4 = "4242", Expiry = "12/26", IsDefault = true,
              Region = "Metro Manila", Province = "Makati", City = "Makati City", Barangay = "Bel-Air",
              Postal = "1200", Street = "123 Ayala Ave", House = "Unit 402", Building = "Tower A" } */
    };

    bool hasSavedCard = savedCards.Any();
}

<div class="profile-layout-container">
    <div class="main-content-wrapper">
        <div class="profile-card-content">
            <div class="header-with-action">
               
            </div>

            <div id="payment-view-section">
                @if (hasSavedCard)
                {
                    <div class="section-header-row mb-4">
                        <h2 class="section-title">SAVED PAYMENT METHODS</h2>
                        <button class="btn-primary-action" onclick="prepareAddForm()">
                            <i class="bi bi-plus-lg"></i> ADD PAYMENT METHOD
                        </button>
                    </div>

                    @foreach (var card in savedCards)
                    {
                        <div class="saved-card-item @(card.IsDefault ? "active-selection" : "")" id="card-@card.Id">
                            <div class="card-info-left">
                                <i class="bi bi-credit-card-2-front"></i>
                                <div class="card-details">
                                    <span class="card-brand">@card.Brand Ending in @card.Last4</span>
                                    <span class="card-expiry">Expires @card.Expiry</span>
                                </div>
                            </div>

                            <div class="card-actions-right" id="actions-@card.Id">
                                <button class="btn-edit-card" title="Edit" onclick="editCard(event, @card.Id, {
                                                            number: '@card.Last4',
                                                            name: 'Angela Matugas',
                                                            region: '@card.Region',
                                                            province: '@card.Province',
                                                            city: '@card.City',
                                                            barangay: '@card.Barangay',
                                                            postal: '@card.Postal',
                                                            street: '@card.Street',
                                                            house: '@card.House',
                                                            building: '@card.Building'
                                                        })">
                                    <i class="bi bi-pencil"></i>
                                </button>

                                @if (card.IsDefault)
                                {
                                    <span class="badge-default">DEFAULT</span>
                                }
                                else
                                {
                                    <button class="btn-set-default" onclick="setDefault(event, @card.Id)">SET DEFAULT</button>
                                }
                                <button class="btn-remove" onclick="removeCard(event, @card.Id)">Remove</button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <h2 class="page-title">Payment Methods</h2>
                    <div class="empty-state-container">
                        <div class="empty-state-icon">
                            <i class="bi bi-credit-card-2-front"></i>
                            <div class="plus-badge"><i class="bi bi-plus"></i></div>
                        </div>
                        <h3 class="empty-state-title">NO PAYMENT METHODS</h3>
                        <p class="empty-state-text">Save your credit or debit cards for a faster checkout experience.</p>
                        <button class="btn-primary-action empty-state-btn" onclick="prepareAddForm()">
                            <i class="bi bi-plus-lg"></i> ADD PAYMENT METHOD
                        </button>
                    </div>
                }
            </div>

            <div id="payment-form-section" style="display: none;">
                <div class="form-navigation">
                    <a href="javascript:void(0)" onclick="togglePaymentForm()" class="back-link">
                        <i class="bi bi-chevron-left"></i> BACK TO SAVED METHODS
                    </a>
                </div>

                <form id="paymentForm">
                    <div class="payment-form-grid">
                        <div class="form-column">
                            <h3 class="form-section-header">DEBIT OR CREDIT CARD</h3>

                            <div class="input-group">
                                <label>CARD NUMBER</label>
                                <input type="text" id="cardNumber" placeholder="0000 0000 0000 0000">
                            </div>

                            <div class="input-row-split">
                                <div class="input-group">
                                    <label>EXPIRATION DATE</label>
                                    <div class="expiry-dropdown-container">
                                        <select class="form-select-custom" id="expiryMonth">
                                            <option disabled selected>MM</option>
                                            @for (int i = 1; i <= 12; i++)
                                            {
                                                <option>@i.ToString("D2")</option>
                                            }
                                        </select>
                                        <select class="form-select-custom" id="expiryYear">
                                            <option disabled selected>YYYY</option>
                                            @for (int i = 0; i <= 10; i++)
                                            {
                                                <option>@(DateTime.Now.Year + i)</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="input-group">
                                    <label>SECURITY CODE</label>
                                    <input type="text" id="cardCvv" placeholder="CVV">
                                </div>
                            </div>

                            <div class="input-group">
                                <label>CARDHOLDER NAME</label>
                                <input type="text" id="cardHolderName" placeholder="Enter name on card">
                            </div>

                            <div class="security-notice">
                                <i class="bi bi-lock-fill"></i>
                                <p>Secure SSL encrypted payment processing.</p>
                            </div>
                        </div>

                        <div class="form-column">
                            <h3 class="form-section-header">BILLING ADDRESS</h3>

                            <div class="input-row-split">
                                <div class="input-group">
                                    <label>REGION</label>
                                    <input type="text" id="billingRegionInput" list="billingRegionList" placeholder="Select">
                                    <datalist id="billingRegionList"></datalist>
                                </div>
                                <div class="input-group">
                                    <label>POSTAL CODE</label>
                                    <input type="text" id="billingPostalInput" placeholder="0000">
                                </div>
                            </div>

                            <div class="input-row-split">
                                <div class="input-group">
                                    <label>PROVINCE</label>
                                    <input type="text" id="billingProvinceInput" placeholder="Select">
                                </div>
                                <div class="input-group">
                                    <label>CITY</label>
                                    <input type="text" id="billingCityInput" placeholder="Select">
                                </div>
                            </div>

                            <div class="input-group">
                                <label>BARANGAY</label>
                                <input type="text" id="billingBarangayInput" placeholder="Select">
                            </div>

                            <div class="input-row-split">
                                <div class="input-group">
                                    <label>HOUSE NO.</label>
                                    <input type="text" id="billingHouseInput" placeholder="Unit/House No.">
                                </div>
                                <div class="input-group">
                                    <label>BUILDING (OPTIONAL)</label>
                                    <input type="text" id="billingBuildingInput" placeholder="Building name">
                                </div>
                            </div>

                            <div class="input-group">
                                <label>STREET NAME</label>
                                <input type="text" id="billingStreetInput" placeholder="Street name">
                            </div>
                        </div>
                    </div>
                  
                    <div class="form-actions">
                        <button type="button" class="btn-submit" id="mainSubmitBtn">SAVE PAYMENT METHOD</button>
                        <p class="privacy-policy-text">
                            Your data is encrypted. By submitting, you agree to our Terms.
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/paymentMethods.css" asp-append-version="true" />
}
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/paymentMethods.js" asp-append-version="true"></script>
}