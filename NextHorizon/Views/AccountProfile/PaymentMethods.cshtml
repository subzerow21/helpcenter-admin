@{
    ViewData["Title"] = "Payment Methods";
    Layout = "_ProfileLayout";

    // Simulation: Combined list for Cards and E-Wallets
    var savedMethods = new List<dynamic>
    {
        new { Id = 1, Type = "Card", Brand = "Visa", Last4 = "4242", Expiry = "12/26", IsDefault = true,
              Region = "Metro Manila", Province = "Makati", City = "Makati City", Barangay = "Bel-Air",
              Postal = "1200", Street = "123 Ayala Ave", House = "Unit 402", Building = "Tower A" },
        new { Id = 2, Type = "EWallet", Brand = "GCash", Account = "0917****123", IsDefault = false }
    };

    bool hasMethods = savedMethods.Any();
}

<div class="profile-layout-container">
    <div class="main-content-wrapper">
        <div class="profile-card-content">

            @* --- VIEW SECTION --- *@
            <div id="payment-view-section">
                @if (hasMethods)
                {
                    <div class="section-header-row mb-4">
                        <h2 class="section-title">SAVED PAYMENT METHODS</h2>
                        <button class="btn-primary-action" onclick="prepareAddForm()">
                            <i class="bi bi-plus-lg"></i> ADD PAYMENT METHOD
                        </button>
                    </div>

                    @foreach (var method in savedMethods)
                    {
                        <div class="saved-card-item @(method.IsDefault ? "active-selection" : "")" id="method-@method.Id">
                            <div class="card-info-left">
                                <i class="bi @(method.Type == "Card" ? "bi-credit-card-2-front" : "bi-wallet2")"></i>
                                <div class="card-details">
                                    @if (method.Type == "Card")
                                    {
                                        <span class="card-brand">@method.Brand Ending in @method.Last4</span>
                                        <span class="card-expiry">Expires @method.Expiry</span>
                                    }
                                    else
                                    {
                                        <span class="card-brand">@method.Brand Account</span>
                                        <span class="card-expiry">@method.Account</span>
                                    }
                                </div>
                            </div>

                            <div class="card-actions-right">
                                <button class="btn-edit-card" title="Edit" onclick="prepareEditForm(@Json.Serialize(method))">
                                    <i class="bi bi-pencil"></i>
                                </button>

                                @if (method.IsDefault)
                                {
                                    <span class="badge-default">DEFAULT</span>
                                }
                                else
                                {
                                    <button class="btn-set-default" onclick="setDefault(@method.Id)">SET DEFAULT</button>
                                }
                                <button class="btn-remove" onclick="removeCard(@method.Id)">Remove</button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <h2 class="page-title">Payment Methods</h2>
                    <div class="empty-state-container">
                        <div class="empty-state-icon">
                            <i class="bi bi-credit-card-2-front"></i>
                            <div class="plus-badge"><i class="bi bi-plus"></i></div>
                        </div>
                        <h3 class="empty-state-title">NO PAYMENT METHODS</h3>
                        <p class="empty-state-text">Save your cards or e-wallets for a faster checkout experience.</p>
                        <button class="btn-primary-action empty-state-btn" onclick="prepareAddForm()">
                            <i class="bi bi-plus-lg"></i> ADD PAYMENT METHOD
                        </button>
                    </div>
                }
            </div>

            <div id="payment-form-section" style="display: none;">
                <div class="form-navigation">
                    <a href="javascript:void(0)" onclick="toggleView()" class="back-link">
                        <i class="bi bi-chevron-left"></i> BACK TO SAVED METHODS
                    </a>
                </div>

                <form id="paymentForm">
                    <input type="hidden" id="methodId" name="Id" />

                    @* Payment Type Selector *@
                    <div class="payment-type-toggle mb-4">
                        <button type="button" id="type-card" class="btn-toggle active" onclick="setPaymentType('Card')">
                            <i class="bi bi-credit-card"></i> DEBIT/CREDIT CARD
                        </button>
                        <button type="button" id="type-ewallet" class="btn-toggle" onclick="setPaymentType('EWallet')">
                            <i class="bi bi-wallet2"></i> E-WALLET
                        </button>
                        <input type="hidden" id="selectedPaymentType" name="Type" value="Card" />
                    </div>

                    <div class="payment-form-grid">

                        @* --- LEFT COLUMN (Only shows for Card) --- *@
                        <div class="form-column" id="card-left-column">
                            <div id="card-fields">
                                <h3 class="form-section-header">CARD DETAILS</h3>
                                <div class="input-group">
                                    <label>CARD NUMBER</label>
                                    <input type="text" name="CardNumber" placeholder="0000 0000 0000 0000">
                                </div>
                                <div class="input-row-split">
                                    <div class="input-group">
                                        <label>EXPIRATION</label>
                                        <div class="expiry-dropdown-container">
                                            <select class="form-select-custom" name="ExpiryMonth">
                                                <option disabled selected>MM</option>
                                                @for (int i = 1; i <= 12; i++)
                                                {
                                                    <option>@i.ToString("D2")</option>
                                                }
                                            </select>
                                            <select class="form-select-custom" name="ExpiryYear">
                                                <option disabled selected>YYYY</option>
                                                @for (int i = 0; i <= 10; i++)
                                                {
                                                    <option>@(DateTime.Now.Year + i)</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                    <div class="input-group">
                                        <label>CVV</label>
                                        <input type="password" name="CVV" placeholder="***">
                                    </div>
                                </div>

                                <div class="input-group mt-3 card-only-element">
                                <label>ACCOUNT HOLDER NAME</label>
                                <input type="text" name="HolderName" placeholder="Full Name">
                            </div>

                            <div class="security-notice card-only-element">
                                <i class="bi bi-lock-fill"></i>
                                <p>Secure SSL encrypted processing.</p>
                            </div>
                            </div>

                            
                            
                        </div>

                        @* --- E-WALLET SECTION (Direct child of grid so it can span 100%) --- *@
                        <div id="ewallet-fields" style="display:none;">
                            <h3 class="form-section-header">E-WALLET DETAILS</h3>
                            <div class="input-group">
                                <label>PROVIDER</label>
                                <select class="form-select-custom" name="Brand">
                                    <option value="GCash">GCash</option>
                                    <option value="Maya">Maya</option>
                                    <option value="PayPal">PayPal</option>
                                </select>
                            </div>
                            <div class="input-group">
                                <label>ACCOUNT NUMBER (MOBILE)</label>
                                <input type="text" name="Account" placeholder="0917 XXX XXXX">
                            </div>
                            @* Duplicate holder name inside e-wallet div to keep it full width *@
                            <div class="input-group">
                                <label>ACCOUNT HOLDER NAME</label>
                                <input type="text" name="HolderNameEwallet" placeholder="Full Name">
                            </div>
                        </div>

                        @* --- RIGHT COLUMN: Billing Address --- *@
                        <div class="form-column" id="billing-address-section">
                            <h3 class="form-section-header">BILLING ADDRESS</h3>
                            <div class="input-row-split">
                                <div class="input-group">
                                    <label>REGION</label>
                                    <input type="text" name="Region" placeholder="Select">
                                </div>
                                <div class="input-group">
                                    <label>POSTAL</label>
                                    <input type="text" name="Postal" placeholder="0000">
                                </div>
                            </div>
                            <div class="input-row-split">
                                <div class="input-group">
                                    <label>PROVINCE</label>
                                    <input type="text" name="Province" placeholder="Select">
                                </div>
                                <div class="input-group">
                                    <label>CITY</label>
                                    <input type="text" name="City" placeholder="Select">
                                </div>
                            </div>
                            <div class="input-group">
                                <label>BARANGAY</label>
                                <input type="text" name="Barangay" placeholder="Select">
                            </div>
                            <div class="input-group">
                                <label>STREET & BLDG</label>
                                <input type="text" name="Street" placeholder="Street/House/Building">
                            </div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn-submit">SAVE PAYMENT METHOD</button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/paymentMethods.css" asp-append-version="true" />
}
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/paymentMethods.js" asp-append-version="true"></script>
}